# ============================================================================
#  FOLD EVALUATION -- exact meaning of a lawful program prefix.
# ============================================================================
#
#  -- WHY --------------------------------------------------------------------
#  Evaluation is not selected from a strategy.  A lawful program already contains
#  one generated source path and a counted number of Fold observations; applying
#  those observations forces its result.
#
#  -- DERIVATION -------------------------------------------------------------
#  Rewriting s leading labels gives the residual word and its decoded rank on the
#  depth-(k-s) grid.  Rebuilding that coordinate equals direct universal Fold
#  execution as an exact fraction.  Every program admitted by Step 373 is
#  evaluated.  Overlong evaluation and outside syntax reject.
# ============================================================================

import "../foundation/enforcement.ep"
import "../constants/semantics_binding_substitution.ep"


define fold_evaluate_program_rank with word as List and steps as Int returning Int:
    set depth to length_list(word)
    if fold_program_syntax_is_lawful(word and steps) == false:
        return 0
    set source_rank to decode_computation_codeword(word)
    return recursive_fold_index(source_rank and depth and steps)


define fold_evaluate_program_value with word as List and steps as Int returning Fraction:
    set depth to length_list(word)
    set rank to fold_evaluate_program_rank(word and steps)
    if rank < 1:
        return fraction_from_whole_number(0)
    return computation_state(rank and depth - steps)


define fold_program_evaluation_is_exact with rank as Int and depth as Int and steps as Int returning Bool:
    set evaluated to fold_evaluate_program_value(enumerate_fold_word(rank and depth) and steps)
    set direct to universal_fold_execute_state(computation_state(rank and depth) and steps)
    return fraction_is_equal(evaluated and direct)


define complete_fold_program_evaluation_census returning Bool:
    set depth to 1
    repeat while depth < computation_census_depth() + 1:
        set rank to 1
        repeat while rank < computation_state_count(depth) + 1:
            set steps to 0
            repeat while steps < depth + 1:
                if fold_program_evaluation_is_exact(rank and depth and steps) == false:
                    return false
                set steps to steps + 1
            set rank to rank + 1
        set depth to depth + 1
    return true


define overlong_evaluation_is_rejected with depth as Int returning Bool:
    return fold_evaluate_program_rank(enumerate_fold_word(1 and depth) and depth + 1) == 0


define changed_evaluation_result_is_rejected with rank as Int and depth as Int and steps as Int returning Bool:
    set lawful to fold_evaluate_program_rank(enumerate_fold_word(rank and depth) and steps)
    set changed to lawful + 1
    if changed > computation_state_count(depth - steps):
        set changed to 1
    return lawful != changed
