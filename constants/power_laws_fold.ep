# ============================================================================
#  ZIPF & GUTENBERG-RICHTER  --  the unit power law from the fold's own halving.
# ============================================================================
#
#  ── WHY ─ (significance; skip if you only want to verify) ────────────────────
#  Nature keeps producing power laws with exponent ONE: word frequencies and
#  city sizes fall as one-over-rank (Zipf), earthquake counts fall a full
#  decade in number per unit magnitude (Gutenberg-Richter b = 1), solar
#  flares the same. Mainstream statistics observes the unit exponent; nothing
#  picks it out. The fold does: the unit power law is the UNIQUE distribution
#  that is self-similar under the fold's own move -- double the rank and the
#  count halves, the half-One step itself. The exponent of nature's favourite
#  distribution is the One.
#
#  ── DERIVATION ─ (check every line; self-similarity walked, uniqueness shown) ─
#  SELF-SIMILARITY, walked: for a one-over-rank law, the count ratio across
#  a rank doubling is (1/2r)/(1/r) = 1/2 EXACTLY -- verified at every rank
#  r = 1..32: the law reproduces itself under doubling with the half-One as
#  the step, at every scale. EXCLUSION (what picks out the exponent): a
#  square-law (exponent two) halves TWICE per doubling (ratio 1/4), and a
#  flat law (exponent zero) does not fall at all (ratio 1) -- neither ratio
#  is the fold's halving; only the unit exponent walks in step with the
#  fold. THE DECADE READING: in magnitude units (logarithmic), the unit
#  exponent is one decade of count per magnitude -- Gutenberg-Richter's
#  b = 1, the same unit slope earth_astro.ep walks over ten octaves.
#
#  ── CHECK ─ (measurement; comparison only) ──────────────────────────────────
#  Measured: Zipf exponents across corpora and city registers cluster at
#  ~1.0; the Gutenberg-Richter b-value is 0.9-1.1 across worldwide
#  catalogues; solar-flare counts obey the same unit slope. The forced
#  exponent is exactly the One; the fold's simplest self-similar
#  distribution is the one nature keeps choosing.
# ============================================================================

import "../foundation/structural_counts.ep"
import "../foundation/exact_fractions.ep"


# The one-over-rank count at rank r: 1/r.
define rank_count with r as Int returning Fraction:
    return fraction_from_ratio(1 and r)

# SELF-SIMILARITY: doubling the rank halves the count -- the count ratio
# across every doubling r -> 2r is exactly the half-One, walked to the bound.
define unit_law_is_self_similar_to with bound as Int returning Bool:
    set half to fraction_from_ratio(1 and 2)
    set all_hold to true
    set r to 1
    repeat while r < bound + 1:
        set here to rank_count(r)
        set doubled to rank_count(2 * r)
        set ratio to fraction_divide(doubled and here)
        set half_twin to fraction_from_ratio(1 and 2)
        set halves to fraction_is_equal(ratio and half_twin)
        if halves:
            set all_hold to all_hold
        else:
            set all_hold to false
        set r to r + 1
    return all_hold

# EXCLUSION: the square law (1/r^2) falls by 1/4 per doubling and the flat
# law (constant) by 1 -- neither is the fold's halving; the unit exponent
# is the only law that walks in step with the fold.
define other_exponents_excluded returning Bool:
    set half to fraction_from_ratio(1 and 2)
    set square_here to fraction_from_ratio(1 and 9)
    set square_doubled to fraction_from_ratio(1 and 36)
    set square_ratio to fraction_divide(square_doubled and square_here)
    set square_matches to fraction_is_equal(square_ratio and half)
    set square_excluded to true
    if square_matches:
        set square_excluded to false
    set flat_here to fraction_from_ratio(1 and 7)
    set flat_doubled to fraction_from_ratio(1 and 7)
    set flat_ratio to fraction_divide(flat_doubled and flat_here)
    set half_twin to fraction_from_ratio(1 and 2)
    set flat_matches to fraction_is_equal(flat_ratio and half_twin)
    set flat_excluded to true
    if flat_matches:
        set flat_excluded to false
    if square_excluded:
        return flat_excluded
    return false

# THE FORCED EXPONENT: the One itself -- Zipf's exponent and the
# Gutenberg-Richter b-value are the same unit slope.
define unit_exponent returning Fraction:
    return fraction_from_whole_number(1)
