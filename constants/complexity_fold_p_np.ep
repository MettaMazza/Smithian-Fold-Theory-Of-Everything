# ============================================================================
#  FOLD-P VERSUS FOLD-NP -- EXACT EQUALITY IN THE ADMITTED FOLD GRAMMAR.
# ============================================================================
#
#  -- WHY --------------------------------------------------------------------
#  P and NP cannot be imported with an outside machine, polynomial convention,
#  or problem encoding.  The native comparison must use the exact Fold process
#  and proof systems already derived.
#
#  -- DERIVATION -------------------------------------------------------------
#  Fold-P contains the decisions obtained by the unique depth-bounded Fold
#  evaluator.  Fold-NP contains assertions accompanied by a lawful Fold proof
#  trace of the same supplied depth.  Every deterministic evaluation emits its
#  compiled trace, so Fold-P is contained in Fold-NP.  Conversely, proof
#  soundness forces every accepted trace to be the unique deterministic Fold
#  evaluation, so Fold-NP is contained in Fold-P.  Both consume exactly the
#  description depth in the closing case.  Hence P_F = NP_F over every process
#  generated by the admitted Fold grammar.
#
#  This equality does not decide conventional P versus NP for arbitrary external
#  languages, encodings, nondeterministic machines, or Boolean circuit bases.
# ============================================================================

import "../constants/computability_busy_beaver_unrestricted.ep"


define fold_p_decision_time with depth as Int returning Int:
    return fold_busy_beaver_value(depth)


define fold_np_verification_time with depth as Int returning Int:
    if depth < 1:
        return 0
    set trace to fold_compile_program_trace(1 and depth and depth)
    return fold_circuit_gate_count(trace)


define fold_p_is_contained_in_fold_np with rank as Int and depth as Int returning Bool:
    set asserted to fold_evaluate_program_rank(enumerate_fold_word(rank and depth) and depth)
    set trace to fold_compile_program_trace(rank and depth and depth)
    return fold_verify_program_proof(rank and depth and depth and asserted and trace)


define accepted_fold_np_proof_is_in_fold_p with rank as Int and depth as Int and asserted as Int and trace as List returning Bool:
    if fold_verify_program_proof(rank and depth and depth and asserted and trace) == false:
        return true
    set deterministic to fold_evaluate_program_rank(enumerate_fold_word(rank and depth) and depth)
    return deterministic == asserted


define fold_np_is_contained_in_fold_p with rank as Int and depth as Int returning Bool:
    set trace to fold_compile_program_trace(rank and depth and depth)
    set asserted to fold_execute_compiled_trace(trace)
    return accepted_fold_np_proof_is_in_fold_p(rank and depth and asserted and trace)


define fold_p_equals_fold_np_at_depth with depth as Int returning Bool:
    if depth < 1:
        return false
    if fold_p_decision_time(depth) != fold_np_verification_time(depth):
        return false
    set rank to 1
    repeat while rank < computation_state_count(depth) + 1:
        if fold_p_is_contained_in_fold_np(rank and depth) == false:
            return false
        if fold_np_is_contained_in_fold_p(rank and depth) == false:
            return false
        set rank to rank + 1
    return true


define complete_fold_p_np_census returning Bool:
    set depth to 1
    repeat while depth < computation_census_depth() + 1:
        if fold_p_equals_fold_np_at_depth(depth) == false:
            return false
        set depth to depth + 1
    return true


define fold_p_np_depth_induction_certificate with supplied_depth as Int returning Bool:
    if fold_busy_beaver_unrestricted_certificate(supplied_depth) == false:
        return false
    if fold_circuit_depth(supplied_depth) != supplied_depth:
        return false
    return fold_reverse_record_induction_step(supplied_depth)


define tampered_fold_np_branch_is_rejected with rank as Int and depth as Int returning Bool:
    return tampered_program_proof_is_rejected(rank and depth and depth)


define false_fold_p_np_separation_is_rejected with depth as Int returning Bool:
    return fold_p_decision_time(depth) == fold_np_verification_time(depth)

