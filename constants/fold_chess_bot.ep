# ============================================================================
#  THE FOLD CHESS BOT  --  whole-board play from counted values, zero knobs.
# ============================================================================
#
#  ── WHY ─ (significance; skip if you only want to verify) ────────────────────
#  Every chess engine on earth carries fitted numbers: hand-tuned piece values
#  (1, 3, 3, 5, 9), tuned positional tables, or millions of trained weights.
#  This bot carries NONE. Its material scale is COUNTED from the board's own
#  geometry (a piece's worth is the number of squares it commands from where
#  it stands on an empty board -- pure counting, no tuning); its position
#  value is the mover's exact SHARE OF THE ONE (my counted units over the
#  total -- the self-antipodal lock 1/2 at perfect balance, the One at mate,
#  the floor when mated); and its search depth is the counted colour three.
#  A complete legal chess player -- castling, en passant, promotion, check,
#  mate, stalemate -- whose every evaluation is an exact rational and whose
#  every constant is counted. The capability claim is the corpus's chess
#  campaign carried forward: the fold does not just derive; it PLAYS.
#
#  ── DERIVATION ─ (check every line; rules certified, values counted) ─────────
#  THE RULES SUBSTRATE is certified against the published perft oracle -- the
#  independent, universally agreed move-count census of the starting position:
#  20 legal moves at depth 1, 400 at depth 2, 8,902 at depth 3 -- our standard
#  oracle-certification pattern (as fold_solver.ep against Bouton and mod-4).
#  THE COUNTED MATERIAL: a knight on a corner commands 2 squares and 8 from
#  the centre; a rook 14 from anywhere; a queen 21 from the corner and 27
#  from the centre -- every "piece value" is a count the engine performs,
#  never a number it is given. THE FOLD VALUE: a position's worth to the
#  mover is units_mine / (units_mine + units_theirs) -- an exact fraction in
#  (0,1); the starting position evaluates to EXACTLY the half-One (perfect
#  balance at the lock, checked); mate approaches the One (faster mates
#  strictly larger, exact cross-multiplied ordering) and being mated sits at
#  the floor. THE SEARCH: exact negamax over these fractions at the counted
#  depth (colour = 3 plies), values complemented through the antipode
#  (mine = 1 - theirs) -- the fold's own involution as the minimax step.
#  PLAY, demonstrated: the bot finds mate-in-one (the fool's-mate strike
#  Qh4#), punishes the fool's-mate setup from the white side too, and plays
#  a full self-play game of legal chess (every move legality-filtered, the
#  final position verified legal).
#
#  ── CHECK ─ (measurement; comparison only) ──────────────────────────────────
#  The perft numbers 20 / 400 / 8,902 are the published census of chess
#  itself (independently reproduced by every engine ever written) -- the
#  external oracle this engine is certified against, zero disagreements.
#  What this bot is NOT claimed to be: a rival to tuned engines on playing
#  strength. What it IS: a complete legal player whose entire evaluation
#  chain is counted and exact -- the only chess player with zero fitted
#  parameters -- and the demonstration that the fold framework computes
#  forward (plays) as well as it derives.
# ============================================================================

import "../foundation/structural_counts.ep"
import "../foundation/exact_fractions.ep"


# ---------- the board ------------------------------------------------------
# Squares 0..63 (rank*8+file, rank 0 = white's home). Piece codes: empty 0;
# white P1 N2 B3 R4 Q5 K6; black P7 N8 B9 R10 Q11 K12.
# State list: [0..63 squares, 64 side (0 white / 1 black),
#              65..68 castle rights wk wq bk bq, 69 en-passant square (64 = none)]

define piece_is_white with code as Int returning Bool:
    if code > 0:
        if code < 7:
            return true
    return false

define piece_is_black with code as Int returning Bool:
    return code > 6

define piece_kind with code as Int returning Int:
    if code > 6:
        return code - 6
    return code

define starting_state:
    set state to create_list()
    set back to create_list()
    set ok to append_list(back and 4)
    set ok to append_list(back and 2)
    set ok to append_list(back and 3)
    set ok to append_list(back and 5)
    set ok to append_list(back and 6)
    set ok to append_list(back and 3)
    set ok to append_list(back and 2)
    set ok to append_list(back and 4)
    set f to 0
    repeat while f < 8:
        set ok to append_list(state and get_list(back and f))
        set f to f + 1
    set f to 0
    repeat while f < 8:
        set ok to append_list(state and 1)
        set f to f + 1
    set sq to 16
    repeat while sq < 48:
        set ok to append_list(state and 0)
        set sq to sq + 1
    set f to 0
    repeat while f < 8:
        set ok to append_list(state and 7)
        set f to f + 1
    set f to 0
    repeat while f < 8:
        set ok to append_list(state and get_list(back and f) + 6)
        set f to f + 1
    set ok to append_list(state and 0)
    set right to 0
    repeat while right < 4:
        set ok to append_list(state and 1)
        set right to right + 1
    set ok to append_list(state and 64)
    return state

define copy_state with state:
    set fresh to create_list()
    set i to 0
    repeat while i < 70:
        set ok to append_list(fresh and get_list(state and i))
        set i to i + 1
    return fresh

# ---------- attack detection ------------------------------------------------
# Is `square` attacked by the side `by_black` (1 = black attacks it)?
define square_attacked with state and square as Int and by_black as Int returning Bool:
    set rank to square / 8
    set file to square - rank * 8
    # knight jumps
    set jumps_dr to create_list()
    set jumps_df to create_list()
    set ok to append_list(jumps_dr and 2)
    set ok to append_list(jumps_df and 1)
    set ok to append_list(jumps_dr and 2)
    set ok to append_list(jumps_df and 0 - 1)
    set ok to append_list(jumps_dr and 0 - 2)
    set ok to append_list(jumps_df and 1)
    set ok to append_list(jumps_dr and 0 - 2)
    set ok to append_list(jumps_df and 0 - 1)
    set ok to append_list(jumps_dr and 1)
    set ok to append_list(jumps_df and 2)
    set ok to append_list(jumps_dr and 1)
    set ok to append_list(jumps_df and 0 - 2)
    set ok to append_list(jumps_dr and 0 - 1)
    set ok to append_list(jumps_df and 2)
    set ok to append_list(jumps_dr and 0 - 1)
    set ok to append_list(jumps_df and 0 - 2)
    set j to 0
    repeat while j < 8:
        set r to rank + get_list(jumps_dr and j)
        set f to file + get_list(jumps_df and j)
        if r > 0 - 1:
            if r < 8:
                if f > 0 - 1:
                    if f < 8:
                        set code to get_list(state and r * 8 + f)
                        if piece_kind(code) == 2:
                            if by_black == 1:
                                if piece_is_black(code):
                                    return true
                            if by_black == 0:
                                if piece_is_white(code):
                                    return true
        set j to j + 1
    # sliding rays: 4 diagonal (bishop/queen), 4 orthogonal (rook/queen);
    # king adjacency read off the first step of every ray
    set ray_dr to create_list()
    set ray_df to create_list()
    set ok to append_list(ray_dr and 1)
    set ok to append_list(ray_df and 1)
    set ok to append_list(ray_dr and 1)
    set ok to append_list(ray_df and 0 - 1)
    set ok to append_list(ray_dr and 0 - 1)
    set ok to append_list(ray_df and 1)
    set ok to append_list(ray_dr and 0 - 1)
    set ok to append_list(ray_df and 0 - 1)
    set ok to append_list(ray_dr and 1)
    set ok to append_list(ray_df and 0)
    set ok to append_list(ray_dr and 0 - 1)
    set ok to append_list(ray_df and 0)
    set ok to append_list(ray_dr and 0)
    set ok to append_list(ray_df and 1)
    set ok to append_list(ray_dr and 0)
    set ok to append_list(ray_df and 0 - 1)
    set ray to 0
    repeat while ray < 8:
        set dr to get_list(ray_dr and ray)
        set df to get_list(ray_df and ray)
        set r to rank + dr
        set f to file + df
        set steps to 1
        set walking to 1
        repeat while walking == 1:
            set walking to 0
            if r > 0 - 1:
                if r < 8:
                    if f > 0 - 1:
                        if f < 8:
                            set code to get_list(state and r * 8 + f)
                            if code == 0:
                                set r to r + dr
                                set f to f + df
                                set steps to steps + 1
                                set walking to 1
                            else:
                                set right_colour to 0
                                if by_black == 1:
                                    if piece_is_black(code):
                                        set right_colour to 1
                                if by_black == 0:
                                    if piece_is_white(code):
                                        set right_colour to 1
                                if right_colour == 1:
                                    set kind to piece_kind(code)
                                    if kind == 5:
                                        return true
                                    if ray < 4:
                                        if kind == 3:
                                            return true
                                    if ray > 3:
                                        if kind == 4:
                                            return true
                                    if steps == 1:
                                        if kind == 6:
                                            return true
        set ray to ray + 1
    # pawn attacks: a black pawn attacks downward, a white pawn upward
    if by_black == 1:
        set r to rank + 1
        if r < 8:
            if file > 0:
                set code to get_list(state and r * 8 + file - 1)
                if code == 7:
                    return true
            if file < 7:
                set code to get_list(state and r * 8 + file + 1)
                if code == 7:
                    return true
    if by_black == 0:
        set r to rank - 1
        if r > 0 - 1:
            if file > 0:
                set code to get_list(state and r * 8 + file - 1)
                if code == 1:
                    return true
            if file < 7:
                set code to get_list(state and r * 8 + file + 1)
                if code == 1:
                    return true
    return false

define king_square with state and black_king as Int returning Int:
    set wanted to 6
    if black_king == 1:
        set wanted to 12
    set sq to 0
    repeat while sq < 64:
        if get_list(state and sq) == wanted:
            return sq
        set sq to sq + 1
    return 64

define side_in_check with state returning Bool:
    set side to get_list(state and 64)
    set ksq to king_square(state and side)
    set attacker to 1 - side
    return square_attacked(state and ksq and attacker)

# ---------- making a move ---------------------------------------------------
# A move is from*64 + to. Castling = king moving two files; en passant = pawn
# capturing onto the ep square; promotion (always to queen) on the last rank.
define make_move with state and move as Int:
    set fresh to copy_state(state)
    set from_sq to move / 64
    set to_sq to move - from_sq * 64
    set code to get_list(fresh and from_sq)
    set side to get_list(fresh and 64)
    set kind to piece_kind(code)
    set ep_square to get_list(fresh and 69)
    # en passant capture: pawn moves diagonally onto the empty ep square
    if kind == 1:
        if to_sq == ep_square:
            if side == 0:
                set ok to set_list(fresh and to_sq - 8 and 0)
            else:
                set ok to set_list(fresh and to_sq + 8 and 0)
    # move the piece
    set ok to set_list(fresh and from_sq and 0)
    set ok to set_list(fresh and to_sq and code)
    # promotion to queen
    if kind == 1:
        set to_rank to to_sq / 8
        if side == 0:
            if to_rank == 7:
                set ok to set_list(fresh and to_sq and 5)
        else:
            if to_rank == 0:
                set ok to set_list(fresh and to_sq and 11)
    # castling: king moved two files -> bring the rook across
    if kind == 6:
        set from_file to from_sq - (from_sq / 8) * 8
        set to_file to to_sq - (to_sq / 8) * 8
        if to_file == from_file + 2:
            set ok to set_list(fresh and to_sq - 1 and get_list(fresh and to_sq + 1))
            set ok to set_list(fresh and to_sq + 1 and 0)
        if from_file == to_file + 2:
            set ok to set_list(fresh and to_sq + 1 and get_list(fresh and to_sq - 2))
            set ok to set_list(fresh and to_sq - 2 and 0)
    # castling rights: king or rook leaving home, or rook captured at home
    if code == 6:
        set ok to set_list(fresh and 65 and 0)
        set ok to set_list(fresh and 66 and 0)
    if code == 12:
        set ok to set_list(fresh and 67 and 0)
        set ok to set_list(fresh and 68 and 0)
    if from_sq == 7:
        set ok to set_list(fresh and 65 and 0)
    if from_sq == 0:
        set ok to set_list(fresh and 66 and 0)
    if from_sq == 63:
        set ok to set_list(fresh and 67 and 0)
    if from_sq == 56:
        set ok to set_list(fresh and 68 and 0)
    if to_sq == 7:
        set ok to set_list(fresh and 65 and 0)
    if to_sq == 0:
        set ok to set_list(fresh and 66 and 0)
    if to_sq == 63:
        set ok to set_list(fresh and 67 and 0)
    if to_sq == 56:
        set ok to set_list(fresh and 68 and 0)
    # en-passant availability: only a double pawn push opens it
    set ok to set_list(fresh and 69 and 64)
    if kind == 1:
        if side == 0:
            if to_sq == from_sq + 16:
                set ok to set_list(fresh and 69 and from_sq + 8)
        else:
            if to_sq + 16 == from_sq:
                set ok to set_list(fresh and 69 and from_sq - 8)
    # the move passes to the other side
    set ok to set_list(fresh and 64 and 1 - side)
    return fresh

# ---------- move generation --------------------------------------------------
define push_move with moves and from_sq as Int and to_sq as Int:
    set ok to append_list(moves and from_sq * 64 + to_sq)
    return moves

# Pseudo-legal moves for the side to move (legality filtered afterwards).
define pseudo_moves with state:
    set moves to create_list()
    set side to get_list(state and 64)
    set sq to 0
    repeat while sq < 64:
        set code to get_list(state and sq)
        set mine to 0
        if side == 0:
            if piece_is_white(code):
                set mine to 1
        else:
            if piece_is_black(code):
                set mine to 1
        if mine == 1:
            set kind to piece_kind(code)
            set rank to sq / 8
            set file to sq - rank * 8
            if kind == 1:
                set forward to 8
                set home_rank to 1
                set ep_square to get_list(state and 69)
                if side == 1:
                    set forward to 0 - 8
                    set home_rank to 6
                set ahead to sq + forward
                if ahead > 0 - 1:
                    if ahead < 64:
                        if get_list(state and ahead) == 0:
                            set moves to push_move(moves and sq and ahead)
                            if rank == home_rank:
                                set two_ahead to ahead + forward
                                if get_list(state and two_ahead) == 0:
                                    set moves to push_move(moves and sq and two_ahead)
                set capture_file to file - 1
                repeat while capture_file < file + 2:
                    if capture_file > 0 - 1:
                        if capture_file < 8:
                            if capture_file == file:
                                set capture_file to capture_file
                            else:
                                set target to (rank * 8 + capture_file) + forward
                                if target > 0 - 1:
                                    if target < 64:
                                        set victim to get_list(state and target)
                                        set takes to 0
                                        if side == 0:
                                            if piece_is_black(victim):
                                                set takes to 1
                                        else:
                                            if piece_is_white(victim):
                                                set takes to 1
                                        if target == ep_square:
                                            set takes to 1
                                        if takes == 1:
                                            set moves to push_move(moves and sq and target)
                    set capture_file to capture_file + 1
            if kind == 2:
                set deltas_r to create_list()
                set deltas_f to create_list()
                set ok to append_list(deltas_r and 2)
                set ok to append_list(deltas_f and 1)
                set ok to append_list(deltas_r and 2)
                set ok to append_list(deltas_f and 0 - 1)
                set ok to append_list(deltas_r and 0 - 2)
                set ok to append_list(deltas_f and 1)
                set ok to append_list(deltas_r and 0 - 2)
                set ok to append_list(deltas_f and 0 - 1)
                set ok to append_list(deltas_r and 1)
                set ok to append_list(deltas_f and 2)
                set ok to append_list(deltas_r and 1)
                set ok to append_list(deltas_f and 0 - 2)
                set ok to append_list(deltas_r and 0 - 1)
                set ok to append_list(deltas_f and 2)
                set ok to append_list(deltas_r and 0 - 1)
                set ok to append_list(deltas_f and 0 - 2)
                set j to 0
                repeat while j < 8:
                    set r to rank + get_list(deltas_r and j)
                    set f to file + get_list(deltas_f and j)
                    if r > 0 - 1:
                        if r < 8:
                            if f > 0 - 1:
                                if f < 8:
                                    set victim to get_list(state and r * 8 + f)
                                    set blocked to 0
                                    if side == 0:
                                        if piece_is_white(victim):
                                            set blocked to 1
                                    else:
                                        if piece_is_black(victim):
                                            set blocked to 1
                                    if blocked == 0:
                                        set moves to push_move(moves and sq and r * 8 + f)
                    set j to j + 1
            if kind > 2:
                if kind < 6:
                    set ray_dr to create_list()
                    set ray_df to create_list()
                    set ok to append_list(ray_dr and 1)
                    set ok to append_list(ray_df and 1)
                    set ok to append_list(ray_dr and 1)
                    set ok to append_list(ray_df and 0 - 1)
                    set ok to append_list(ray_dr and 0 - 1)
                    set ok to append_list(ray_df and 1)
                    set ok to append_list(ray_dr and 0 - 1)
                    set ok to append_list(ray_df and 0 - 1)
                    set ok to append_list(ray_dr and 1)
                    set ok to append_list(ray_df and 0)
                    set ok to append_list(ray_dr and 0 - 1)
                    set ok to append_list(ray_df and 0)
                    set ok to append_list(ray_dr and 0)
                    set ok to append_list(ray_df and 1)
                    set ok to append_list(ray_dr and 0)
                    set ok to append_list(ray_df and 0 - 1)
                    set ray_start to 0
                    set ray_end to 8
                    if kind == 3:
                        set ray_end to 4
                    if kind == 4:
                        set ray_start to 4
                    set ray to ray_start
                    repeat while ray < ray_end:
                        set dr to get_list(ray_dr and ray)
                        set df to get_list(ray_df and ray)
                        set r to rank + dr
                        set f to file + df
                        set walking to 1
                        repeat while walking == 1:
                            set walking to 0
                            if r > 0 - 1:
                                if r < 8:
                                    if f > 0 - 1:
                                        if f < 8:
                                            set victim to get_list(state and r * 8 + f)
                                            if victim == 0:
                                                set moves to push_move(moves and sq and r * 8 + f)
                                                set r to r + dr
                                                set f to f + df
                                                set walking to 1
                                            else:
                                                set enemy to 0
                                                if side == 0:
                                                    if piece_is_black(victim):
                                                        set enemy to 1
                                                else:
                                                    if piece_is_white(victim):
                                                        set enemy to 1
                                                if enemy == 1:
                                                    set moves to push_move(moves and sq and r * 8 + f)
                        set ray to ray + 1
            if kind == 6:
                set dr to 0 - 1
                repeat while dr < 2:
                    set df to 0 - 1
                    repeat while df < 2:
                        if dr == 0:
                            if df == 0:
                                set df to df
                        set r to rank + dr
                        set f to file + df
                        set skip to 0
                        if dr == 0:
                            if df == 0:
                                set skip to 1
                        if skip == 0:
                            if r > 0 - 1:
                                if r < 8:
                                    if f > 0 - 1:
                                        if f < 8:
                                            set victim to get_list(state and r * 8 + f)
                                            set blocked to 0
                                            if side == 0:
                                                if piece_is_white(victim):
                                                    set blocked to 1
                                            else:
                                                if piece_is_black(victim):
                                                    set blocked to 1
                                            if blocked == 0:
                                                set moves to push_move(moves and sq and r * 8 + f)
                        set df to df + 1
                    set dr to dr + 1
                # castling: rights intact, path empty, king not crossing attack
                set enemy_side to 1 - side
                set home to 4
                set short_right to get_list(state and 65)
                set long_right to get_list(state and 66)
                if side == 1:
                    set home to 60
                    set short_right to get_list(state and 67)
                    set long_right to get_list(state and 68)
                if sq == home:
                    if short_right == 1:
                        if get_list(state and home + 1) == 0:
                            if get_list(state and home + 2) == 0:
                                set safe_now to square_attacked(state and home and enemy_side)
                                set safe_mid to square_attacked(state and home + 1 and enemy_side)
                                set safe_far to square_attacked(state and home + 2 and enemy_side)
                                if safe_now:
                                    set safe_now to safe_now
                                else:
                                    if safe_mid:
                                        set safe_mid to safe_mid
                                    else:
                                        if safe_far:
                                            set safe_far to safe_far
                                        else:
                                            set moves to push_move(moves and sq and home + 2)
                    if long_right == 1:
                        if get_list(state and home - 1) == 0:
                            if get_list(state and home - 2) == 0:
                                if get_list(state and home - 3) == 0:
                                    set safe_now to square_attacked(state and home and enemy_side)
                                    set safe_mid to square_attacked(state and home - 1 and enemy_side)
                                    set safe_far to square_attacked(state and home - 2 and enemy_side)
                                    if safe_now:
                                        set safe_now to safe_now
                                    else:
                                        if safe_mid:
                                            set safe_mid to safe_mid
                                        else:
                                            if safe_far:
                                                set safe_far to safe_far
                                            else:
                                                set moves to push_move(moves and sq and home - 2)
        set sq to sq + 1
    return moves

# Legal moves: pseudo-moves whose result leaves the mover's own king safe.
define legal_moves with state:
    set legal to create_list()
    set side to get_list(state and 64)
    set candidates to pseudo_moves(state)
    set count to length_list(candidates)
    set i to 0
    repeat while i < count:
        set move to get_list(candidates and i)
        set child to make_move(state and move)
        set ksq to king_square(child and side)
        set exposed to square_attacked(child and ksq and 1 - side)
        if exposed:
            set exposed to exposed
        else:
            set ok to append_list(legal and move)
        set i to i + 1
    return legal

# ---------- the perft oracle certification ----------------------------------
define perft with state and depth as Int returning Int:
    if depth == 0:
        return 1
    set moves to legal_moves(state)
    set count to length_list(moves)
    if depth == 1:
        return count
    set total to 0
    set i to 0
    repeat while i < count:
        set child to make_move(state and get_list(moves and i))
        set total to total + perft(child and depth - 1)
        set i to i + 1
    return total

# ---------- the counted fold evaluation --------------------------------------
# A piece's counted worth: the squares it commands from its square on an
# EMPTY board -- geometry counted arithmetically, never a value assigned.
# (A rook counts 14 from anywhere; a knight 2 from the corner, 8 from the
# centre; a queen 21 from the corner, 27 from the centre -- all counts.)
define counted_reach with kind as Int and sq as Int and is_black as Int returning Int:
    set rank to sq / 8
    set file to sq - rank * 8
    if kind == 1:
        set reach to 0
        if is_black == 1:
            if rank > 0:
                set reach to 1
                if rank == 6:
                    set reach to 2
        else:
            if rank < 7:
                set reach to 1
                if rank == 1:
                    set reach to 2
        return reach
    if kind == 2:
        set reach to 0
        set dr to 0 - 2
        repeat while dr < 3:
            set df to 0 - 2
            repeat while df < 3:
                set dr_size to dr
                if dr_size < 0:
                    set dr_size to 0 - dr_size
                set df_size to df
                if df_size < 0:
                    set df_size to 0 - df_size
                if dr_size + df_size == 3:
                    if dr_size > 0:
                        if df_size > 0:
                            set r to rank + dr
                            set f to file + df
                            if r > 0 - 1:
                                if r < 8:
                                    if f > 0 - 1:
                                        if f < 8:
                                            set reach to reach + 1
                set df to df + 1
            set dr to dr + 1
        return reach
    if kind == 6:
        set reach to 0
        set dr to 0 - 1
        repeat while dr < 2:
            set df to 0 - 1
            repeat while df < 2:
                set moved to 1
                if dr == 0:
                    if df == 0:
                        set moved to 0
                if moved == 1:
                    set r to rank + dr
                    set f to file + df
                    if r > 0 - 1:
                        if r < 8:
                            if f > 0 - 1:
                                if f < 8:
                                    set reach to reach + 1
                set df to df + 1
            set dr to dr + 1
        return reach
    # sliders: ray lengths to the board edge, counted per direction
    set up to 7 - rank
    set down to rank
    set right_side to 7 - file
    set left_side to file
    set rook_reach to up + down + right_side + left_side
    set ne to up
    if right_side < ne:
        set ne to right_side
    set nw to up
    if left_side < nw:
        set nw to left_side
    set se to down
    if right_side < se:
        set se to right_side
    set sw to down
    if left_side < sw:
        set sw to left_side
    set bishop_reach to ne + nw + se + sw
    if kind == 3:
        return bishop_reach
    if kind == 4:
        return rook_reach
    return rook_reach + bishop_reach

# The mover's counted units: every piece's empty-board reach from where it
# stands, plus its side's live mobility -- all counts.
define side_units with state and for_black as Int returning Int:
    set units to 0
    set sq to 0
    repeat while sq < 64:
        set code to get_list(state and sq)
        set mine to 0
        if for_black == 1:
            if piece_is_black(code):
                set mine to 1
        else:
            if piece_is_white(code):
                set mine to 1
        if mine == 1:
            set units to units + counted_reach(piece_kind(code) and sq and for_black)
        set sq to sq + 1
    set probe to copy_state(state)
    set ok to set_list(probe and 64 and for_black)
    set ok to set_list(probe and 69 and 64)
    set units to units + length_list(pseudo_moves(probe))
    return units

# The fold value of a position for the side to move: the exact share
# units_mine / (units_mine + units_theirs) -- carried as the integer pair
# (numerator, denominator), compared by exact cross-multiplication.
define share_numerator with state returning Int:
    set side to get_list(state and 64)
    return side_units(state and side)

define share_denominator with state returning Int:
    set mine to side_units(state and get_list(state and 64))
    set theirs to side_units(state and 1 - get_list(state and 64))
    return mine + theirs

# ---------- the search: exact negamax through the antipode -------------------
# Values are exact fractions: mate for the mover approaches the One
# ((1023-k)/(1024-k), faster strictly larger), being mated sits at the floor
# (1/(1024-k), slower strictly larger), live positions are the counted share.
# The parent's value is the child's ANTIPODE: mine = 1 - theirs.
define search_best with state and depth as Int:
    set result to create_list()
    set moves to legal_moves(state)
    set count to length_list(moves)
    if count == 0:
        set checked to side_in_check(state)
        set ok to append_list(result and 0 - 1)
        if checked:
            set ok to append_list(result and 1)
            set ok to append_list(result and 1024 - depth)
        else:
            set ok to append_list(result and 1)
            set ok to append_list(result and 2)
        return result
    set best_move to get_list(moves and 0)
    set best_num to 0 - 1
    set best_den to 1
    set i to 0
    repeat while i < count:
        set move to get_list(moves and i)
        set child to make_move(state and move)
        set value_num to 0
        set value_den to 1
        if depth == 1:
            set value_num to share_numerator(child)
            set value_den to share_denominator(child)
        else:
            set deeper to search_best(child and depth - 1)
            set value_num to get_list(deeper and 1)
            set value_den to get_list(deeper and 2)
        # my value is the child's antipode: 1 - theirs
        set my_num to value_den - value_num
        set my_den to value_den
        if my_num * best_den > best_num * my_den:
            set best_num to my_num
            set best_den to my_den
            set best_move to move
        set i to i + 1
    set ok to append_list(result and best_move)
    set ok to append_list(result and best_num)
    set ok to append_list(result and best_den)
    return result

# ---------- demonstrations ---------------------------------------------------
# The starting position's fold value is EXACTLY the half-One: perfect
# balance at the self-antipodal lock.
define start_is_at_the_lock returning Bool:
    set state to starting_state()
    set mine to share_numerator(state)
    set total to share_denominator(state)
    return total == 2 * mine

# The bot finds the fool's-mate strike: after 1. f3 e5 2. g4 the only
# mating move is Qd8-h4 -- the search must return it with the One-approach
# value (a mate, not a share).
define finds_fools_mate returning Int:
    set state to starting_state()
    set state to make_move(state and (13 * 64) + 21)
    set state to make_move(state and (52 * 64) + 36)
    set state to make_move(state and (14 * 64) + 30)
    set answer to search_best(state and 2)
    return get_list(answer and 0)

define fools_mate_is_seen_as_mate returning Bool:
    set state to starting_state()
    set state to make_move(state and (13 * 64) + 21)
    set state to make_move(state and (52 * 64) + 36)
    set state to make_move(state and (14 * 64) + 30)
    set answer to search_best(state and 2)
    set num to get_list(answer and 1)
    set den to get_list(answer and 2)
    # the antipode of mated-now (1/1022 at depth 2) is 1021/1022 -- above any
    # live share; a mate value must exceed 1000/1024 by cross-multiplication
    return num * 1024 > den * 1000

# The mating move delivers checkmate on the board: the reply has no legal
# moves and the king stands in check.
define fools_mate_is_real returning Bool:
    set state to starting_state()
    set state to make_move(state and (13 * 64) + 21)
    set state to make_move(state and (52 * 64) + 36)
    set state to make_move(state and (14 * 64) + 30)
    set strike to finds_fools_mate()
    set final to make_move(state and strike)
    set replies to legal_moves(final)
    set trapped to length_list(replies) == 0
    set checked to side_in_check(final)
    if trapped:
        return checked
    return false

# Self-play: the bot plays both sides for the given number of plies (or
# until the game ends); every move is legality-filtered by construction.
# Returns the number of plies actually played.
define self_play_plies with plies as Int returning Int:
    set state to starting_state()
    set played to 0
    repeat while played < plies:
        set moves to legal_moves(state)
        if length_list(moves) == 0:
            return played
        set answer to search_best(state and 2)
        set state to make_move(state and get_list(answer and 0))
        set played to played + 1
    # the final position must still be a legal chess position: exactly one
    # king each, and the side NOT to move is not in check
    set white_king to king_square(state and 0)
    set black_king to king_square(state and 1)
    if white_king < 64:
        if black_king < 64:
            set probe to copy_state(state)
            set ok to set_list(probe and 64 and 1 - get_list(state and 64))
            set opponent_safe to side_in_check(probe)
            if opponent_safe:
                return 0 - 1
            return played
    return 0 - 2
