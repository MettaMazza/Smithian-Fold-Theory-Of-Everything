# ============================================================================
#  THE FOLD'S ORBITS ARE THE ORDER OF TWO
# ============================================================================
#
#  ── WHY ─ (significance; skip if you only want to verify) ────────────────────
#  The fold is doubling-and-cast-out. Run it on 1/p and it cycles; the length of
#  that cycle is not arbitrary -- it is a classical number-theory quantity, the
#  multiplicative order of 2 modulo p (the least k with 2^k leaving remainder 1 on
#  division by p). This is WHY the two generators are the numbers they are, and it
#  ties the whole theory to the primes: the generators are read off this order.
#
#  ── DERIVATION ─ (check every line; the fold and plain whole-number arithmetic) ─
#  The fold sends x to 2x with whole Ones cast out -- i.e. it multiplies by 2 modulo
#  1. So the orbit of 1/p walks 1/p, 2/p, 4/p, ... (each doubled, reduced back into
#  the domain), and it returns to 1/p after exactly as many steps as it takes 2^k to
#  leave remainder 1 on division by p. Therefore, for every odd p:
#       fold-orbit period of 1/p  =  multiplicative order of 2 mod p.
#  Both sides are computed here independently and checked equal for p = 3, 5, 7, 9,
#  11. The two generators are the first two distinct values of this order:
#       binary = order of 2 mod 3 = 2   (the period of 1/3)
#       colour = order of 2 mod 7 = 3   (the period of 1/7)
#  Nothing is chosen: the order of 2 mod p is a fixed fact of arithmetic, and the
#  fold reproduces it because the fold IS doubling.
#
#  ── CHECK ─ (measurement; comparison only) ──────────────────────────────────
#  There is nothing to measure against nature here -- this is the arithmetic that
#  underlies the generators. The "comparison" is that the fold's dynamics agree with
#  the independent number-theoretic order, which they do exactly.
# ============================================================================

import "../foundation/structural_counts.ep"
import "../foundation/counted_numbers.ep"
import "../foundation/enforcement.ep"


# The multiplicative order of 2 modulo the given modulus: the least k >= 1 with
# 2^k leaving remainder 1 on division by the modulus. Computed by doubling and
# reducing, with no reference to the fold.
define multiplicative_order_of_two with modulus as Int returning Int:
    set quotient to 2 / modulus
    set current to 2 - quotient * modulus
    set order to 1
    repeat while current > 1:
        set doubled to current + current
        set doubled_quotient to doubled / modulus
        set current to doubled - doubled_quotient * modulus
        set order to order + 1
    return order

# The fold-orbit period of 1/p equals the multiplicative order of 2 mod p. Both
# sides computed independently; forced_to_be halts if they ever disagree.
define fold_period_matches_order with p as Int returning Int:
    set by_fold to fold_period_of_unit_fraction(p)
    set by_arithmetic to multiplicative_order_of_two(p)
    return forced_to_be("fold-orbit period of 1/p = order of 2 mod p" and by_fold and by_arithmetic)

# The binary generator is the order of 2 mod 3 (the period of 1/3), which is 2.
define binary_is_order_of_two_mod_three returning Int:
    set by_generator to binary_count()
    set by_order to multiplicative_order_of_two(3)
    return forced_to_be("binary = order of 2 mod 3" and by_generator and by_order)

# The colour generator is the order of 2 mod 7 (the period of 1/7), which is 3.
define colour_is_order_of_two_mod_seven returning Int:
    set by_generator to colour_count()
    set by_order to multiplicative_order_of_two(7)
    return forced_to_be("colour = order of 2 mod 7" and by_generator and by_order)
