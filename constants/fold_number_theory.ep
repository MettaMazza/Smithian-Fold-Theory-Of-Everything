# ============================================================================
#  FOLD NUMBER THEORY  --  the integers as orbit dynamics of the doubling fold.
# ============================================================================
#
#  ── WHY ─ (significance; skip if you only want to verify) ────────────────────
#  Number theory studies the multiplicative order of 2, cyclotomic cosets,
#  Euler's phi, and Artin's primitive-root conjecture as separate classical
#  facts. The fold sees them all as ONE thing: its own orbit dynamics. A
#  reduced fraction p/q under the doubling fold IS the binary expansion of
#  p/q read as a dynamical system -- so "ord_q(2)" is an orbit length,
#  "phi(q)/ord_q(2)" is an orbit census, "2 is a primitive root mod q" means
#  "denominator q is a single fully-ergodic mode," and the transient decay of
#  even denominators is the 2-adic valuation. The fold does not borrow number
#  theory; number theory falls out of the fold.
#
#  ── DERIVATION ─ (check every line; four laws, each verified exhaustively) ───
#  [1] ORBIT-LENGTH LAW: for every odd q in [3, 99] and EVERY reduced p
#  (not one witness -- all of them), the doubling orbit of p/q closes in
#  exactly ord_q(2) steps: the length is independent of p; a denominator
#  class is one eternal mode with one period.
#  [2] ORBIT COUNT: the phi(q) reduced fractions partition into exactly
#  phi(q)/ord_q(2) orbits (the 2-cyclotomic cosets) -- divisibility AND the
#  exact tiling verified for every odd q in [3, 99]: every residue visited
#  once, no orbit overlaps. Named readings: q = 7 gives 2 modes, q = 31
#  gives 6, q = 73 gives 8.
#  [3] ANTIPODAL INVOLUTION: j/q + (q-j)/q = the One for EVERY pair to
#  q = 99, and the only self-antipodal point across the whole sweep is the
#  half-One (the seed of the critical line, riemann_critical_line.ep).
#  [4] ETERNAL vs TRANSIENT: an even denominator q = 2^a x odd DECAYS for
#  exactly a fold steps (the 2-adic valuation, computed independently) and
#  then locks into the eternal odd-core cycle -- walked for every even q to
#  64, the landing denominator checked odd and equal to the core.
#  [5] FULLY-ERGODIC DENOMINATORS: primes whose single orbit has the full
#  length q-1. Counted exactly to 4000: 214 of the 549 odd primes.
#
#  ── CHECK ─ (measurement; comparison only) ──────────────────────────────────
#  The five laws are exact and exhaustively machine-verified above their
#  stated bounds -- no sampling. Comparison: the counted fully-ergodic
#  density 214/549 = 0.3898 stands against Artin's constant 0.3739558...,
#  the conjectured limiting density (heuristically confirmed to enormous
#  bounds in the literature; the convergence from above is the known
#  behaviour). The fold renames the open conjecture: how often is a prime
#  denominator a single ergodic mode?
# ============================================================================

import "../foundation/structural_counts.ep"
import "../foundation/counted_numbers.ep"
import "../foundation/exact_fractions.ep"


# The greatest common divisor, by exact remainder descent.
define common_divisor with a as Int and b as Int returning Int:
    set big to a
    set small to b
    repeat while small > 0:
        set quotient to big / small
        set remainder to big - quotient * small
        set big to small
        set small to remainder
    return big

# The multiplicative order of 2 mod q (q odd, q > 1): the least k > 0 with
# 2^k leaving remainder 1 -- the eternal period of the denominator class.
define order_of_two with q as Int returning Int:
    set k to 1
    set r to 2 - (2 / q) * q
    repeat while r > 1:
        set doubled to r * 2
        set r to doubled - (doubled / q) * q
        set k to k + 1
    return k

# Euler's phi: how many of 1..q are coprime to q -- the reduced fractions.
define euler_phi with q as Int returning Int:
    set count to 0
    set a to 1
    repeat while a < q + 1:
        set shared to common_divisor(a and q)
        if shared == 1:
            set count to count + 1
        set a to a + 1
    return count

# The doubling-orbit length of the residue p mod q: steps for p -> 2p mod q
# to return to p. This IS the fold orbit of p/q, walked on the numerator.
define residue_orbit_length with p as Int and q as Int returning Int:
    set steps to 0
    set r to p
    set started to 0
    repeat while started == 0:
        set doubled to r * 2
        set r to doubled - (doubled / q) * q
        set steps to steps + 1
        if r == p:
            set started to 1
    return steps

# [1] THE ORBIT-LENGTH LAW: for every odd q in [3, bound] and EVERY reduced
# p, the orbit length equals ord_q(2) -- independent of p.
define orbit_length_law_to with bound as Int returning Bool:
    set all_hold to true
    set q to 3
    repeat while q < bound + 1:
        set expected to order_of_two(q)
        set p to 1
        repeat while p < q:
            set shared to common_divisor(p and q)
            if shared == 1:
                set walked to residue_orbit_length(p and q)
                if walked == expected:
                    set all_hold to all_hold
                else:
                    set all_hold to false
            set p to p + 1
        set q to q + 2
    return all_hold

# [2] THE ORBIT COUNT at one odd q: phi(q)/ord_q(2) orbits, verified by
# exact tiling -- every reduced residue visited exactly once.
define orbit_census with q as Int returning Int:
    set seen to create_list()
    set i to 0
    repeat while i < q:
        set ok to append_list(seen and 0)
        set i to i + 1
    set orbits to 0
    set covered to 0
    set start to 1
    repeat while start < q:
        set shared to common_divisor(start and q)
        if shared == 1:
            set already to get_list(seen and start)
            if already == 0:
                set orbits to orbits + 1
                set r to start
                set walking to 1
                repeat while walking == 1:
                    set ok to set_list(seen and r and 1)
                    set covered to covered + 1
                    set doubled to r * 2
                    set r to doubled - (doubled / q) * q
                    set visited to get_list(seen and r)
                    if visited == 1:
                        set walking to 0
        set start to start + 1
    set phi to euler_phi(q)
    set expected to phi / order_of_two(q)
    set divides to phi - expected * order_of_two(q)
    if divides == 0:
        if covered == phi:
            if orbits == expected:
                return orbits
    return 0 - 1

# [2] The census holds for every odd q in [3, bound].
define orbit_count_law_to with bound as Int returning Bool:
    set all_hold to true
    set q to 3
    repeat while q < bound + 1:
        set census to orbit_census(q)
        if census > 0:
            set all_hold to all_hold
        else:
            set all_hold to false
        set q to q + 2
    return all_hold

# [3] THE ANTIPODAL INVOLUTION: every pair j/q, (q-j)/q sums to the One,
# and the only self-antipodal point across the whole sweep is the half-One.
define antipodal_law_to with bound as Int returning Bool:
    set all_sum to true
    set fixed_points to 0
    set all_fixed_are_half to true
    set q to 2
    repeat while q < bound + 1:
        set j to 1
        repeat while j < q:
            set near to fraction_from_ratio(j and q)
            set far to fraction_from_ratio(q - j and q)
            set total to fraction_add(near and far)
            set one to fraction_from_whole_number(1)
            set sums to fraction_is_equal(total and one)
            if sums:
                set all_sum to all_sum
            else:
                set all_sum to false
            set near_twin to fraction_from_ratio(j and q)
            set far_twin to fraction_from_ratio(q - j and q)
            set self_paired to fraction_is_equal(near_twin and far_twin)
            if self_paired:
                set fixed_points to fixed_points + 1
                set candidate to fraction_from_ratio(j and q)
                set half to fraction_from_ratio(1 and 2)
                set is_half to fraction_is_equal(candidate and half)
                if is_half:
                    set all_fixed_are_half to all_fixed_are_half
                else:
                    set all_fixed_are_half to false
            set j to j + 1
        set q to q + 1
    if all_sum:
        if fixed_points > 0:
            return all_fixed_are_half
    return false

# The 2-adic valuation of q: how many times 2 divides it -- the forced
# transient length -- and the odd eternal core q / 2^a.
define transient_length with q as Int returning Int:
    set a to 0
    set qq to q
    set halving to 1
    repeat while halving == 1:
        set half to qq / 2
        set remainder to qq - half * 2
        if remainder == 0:
            set qq to half
            set a to a + 1
        else:
            set halving to 0
    return a

define eternal_core with q as Int returning Int:
    set a to transient_length(q)
    return q / whole_power(2 and a)

# [4] ETERNAL vs TRANSIENT: fold 1/q exactly a = valuation(q) times (walked
# on the reduced numerator/denominator pair) and land on the odd core.
define transient_law_to with bound as Int returning Bool:
    set all_hold to true
    set q to 2
    repeat while q < bound + 1:
        set a to transient_length(q)
        set core to eternal_core(q)
        set num to 1
        set den to q
        set step to 0
        repeat while step < a:
            set num to num * 2
            if num > den:
                set num to num - den
            set shared to common_divisor(num and den)
            set num to num / shared
            set den to den / shared
            set step to step + 1
        set landed_half to den / 2
        set landed_odd to den - landed_half * 2
        if landed_odd == 1:
            set all_hold to all_hold
        else:
            set all_hold to false
        if den == core:
            set all_hold to all_hold
        else:
            set all_hold to false
        set q to q + 2
    return all_hold

# Primality by exact trial division.
define q_is_prime with n as Int returning Bool:
    if n < 2:
        return false
    set divisor to 2
    repeat while divisor * divisor < n + 1:
        set quotient to n / divisor
        set remainder to n - quotient * divisor
        if remainder == 0:
            return false
        set divisor to divisor + 1
    return true

# [5] FULLY-ERGODIC DENOMINATORS: odd primes q <= bound whose single orbit
# has the full length q - 1 (2 a primitive root; one ergodic mode).
define fully_ergodic_count_to with bound as Int returning Int:
    set count to 0
    set q to 3
    repeat while q < bound + 1:
        set prime to q_is_prime(q)
        if prime:
            set order to order_of_two(q)
            if order == q - 1:
                set count to count + 1
        set q to q + 2
    return count

define odd_prime_count_to with bound as Int returning Int:
    set count to 0
    set q to 3
    repeat while q < bound + 1:
        set prime to q_is_prime(q)
        if prime:
            set count to count + 1
        set q to q + 2
    return count
