# Test generational GC, write barriers, promotion, and minor/major collection
define structure Node:
    field val as Int
    field next as Node

define allocate_garbage with count:
    set i to 0
    repeat while i < count:
        set dummy to create Node:
            val is i
        set i to i + 1
    return 0

define trigger_gc with x:
    if x > 0:
        return trigger_gc(x - 1)
    return 0

define main:
    display "--- Generational GC Test ---"

    # Start: minor count should be 0
    set c0 to ep_gc_get_minor_count()
    display f"Initial minor count: {c0}"

    # Allocate more than nursery threshold (512) to trigger minor GC
    set ok to allocate_garbage(1000)

    # Trigger GC check on function entry
    set ok to trigger_gc(1)

    set c1 to ep_gc_get_minor_count()
    display f"Minor count after trigger: {c1}"

    # Let's create an outer node and promote it to Gen 1
    # We can do this by keeping it in a variable and triggering more collections
    set root_node to create Node:
        val is 42
    set ok to allocate_garbage(1000) # This will run minor GC and promote root_node to Gen 1
    set ok to trigger_gc(1)

    # Now root_node is Gen 1. Let's create a new young node and point root_node.next to it.
    # This invokes the write barrier: Gen 1 (root_node) -> Gen 0 (young_node)
    set young_node to create Node:
        val is 99
    set root_node.next to young_node

    # Run another minor GC by allocating more garbage
    set ok to allocate_garbage(1000)
    set ok to trigger_gc(1)

    # If the write barrier worked correctly, young_node (value 99) survived.
    # Let's verify by checking its value.
    set next_node to root_node.next
    set val to next_node.val
    display f"Survived young node val: {val}"

    display "Generational GC test passed"
    return 0
