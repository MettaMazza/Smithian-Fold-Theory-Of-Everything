define worker with id and ch:
    set i to 0
    repeat while i < 500:
        send id * 1000 + i to ch
        set i to i + 1
    return 0

define main:
    set ch to channel
    spawn worker(1 and ch)
    spawn worker(2 and ch)
    spawn worker(3 and ch)
    spawn worker(4 and ch)
    set total to 0
    repeat while total < 2000:
        set v to receive from ch
        set total to total + 1
    display f"Received {total} messages from 4 workers"
    return 0
