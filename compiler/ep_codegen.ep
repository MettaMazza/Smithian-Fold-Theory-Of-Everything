    set ok to append_list(lines and "\n")
    set ok to append_list(lines and "void ep_md5_update(EP_MD5_CTX *ctx, const unsigned char *input, size_t input_len) {\n")
    set ok to append_list(lines and "    unsigned int i = 0, index = (ctx->count[0] >> 3) & 0x3F, part_len = 64 - index;\n")
    set ok to append_list(lines and "    ctx->count[0] += input_len << 3;\n")
    set ok to append_list(lines and "    if (ctx->count[0] < (input_len << 3)) ctx->count[1]++;\n")
