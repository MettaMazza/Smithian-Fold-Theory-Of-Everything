    set ok to append_list(lines and "        return empty;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    long long total_len = strlen(s);\n")
    set ok to append_list(lines and "    if (start < 0 || start >= total_len || len <= 0) {\n")
    set ok to append_list(lines and "        char* empty = malloc(1);\n")
    set ok to append_list(lines and "        if (empty) empty[0] = '\\0';\n")
    set ok to append_list(lines and "        ep_gc_register(empty, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "        return empty;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    if (start + len > total_len) {\n")
    set ok to append_list(lines and "        len = total_len - start;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    char* sub = malloc(len + 1);\n")
    set ok to append_list(lines and "    if (!sub) {\n")
    set ok to append_list(lines and "        char* empty = malloc(1);\n")
    set ok to append_list(lines and "        if (empty) empty[0] = '\\0';\n")
    set ok to append_list(lines and "        ep_gc_register(empty, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "        return empty;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    strncpy(sub, s + start, len);\n")
    set ok to append_list(lines and "    sub[len] = '\\0';\n")
    set ok to append_list(lines and "    ep_gc_register(sub, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "    return sub;\n")
    set ok to append_list(lines and "}\n")
    set ok to append_list(lines and "\n")
    set ok to append_list(lines and "char* string_from_list(long long list_ptr) {\n")
    set ok to append_list(lines and "    EpList* list = (EpList*)list_ptr;\n")
    set ok to append_list(lines and "    if (!list) {\n")
    set ok to append_list(lines and "        char* empty = malloc(1);\n")
    set ok to append_list(lines and "        if (empty) empty[0] = '\\0';\n")
    set ok to append_list(lines and "        ep_gc_register(empty, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "        return empty;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    char* s = malloc(list->length + 1);\n")
    set ok to append_list(lines and "    if (!s) {\n")
    set ok to append_list(lines and "        char* empty = malloc(1);\n")
    set ok to append_list(lines and "        if (empty) empty[0] = '\\0';\n")
    set ok to append_list(lines and "        ep_gc_register(empty, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "        return empty;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    for (long long i = 0; i < list->length; i++) {\n")
    set ok to append_list(lines and "        s[i] = (char)list->data[i];\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    s[list->length] = '\\0';\n")
    set ok to append_list(lines and "    ep_gc_register(s, EP_OBJ_STRING);\n")
    set ok to append_list(lines and "    return s;\n")
    set ok to append_list(lines and "}\n")
    set ok to append_list(lines and "\n")
    set ok to append_list(lines and "long long pop_list(long long list_ptr) {\n")
    set ok to append_list(lines and "    EpList* list = (EpList*)list_ptr;\n")
    set ok to append_list(lines and "    if (!list || list->length <= 0) return 0;\n")
    set ok to append_list(lines and "    list->length -= 1;\n")
    set ok to append_list(lines and "    return list->data[list->length];\n")
    set ok to append_list(lines and "}\n")
    set ok to append_list(lines and "\n")
    set ok to append_list(lines and "long long display_string(const char* s) {\n")
    set ok to append_list(lines and "    if (s) puts(s);\n")
    set ok to append_list(lines and "    return 0;\n")
    set ok to append_list(lines and "}\n")
    return join_strings(lines)

define get_c_main_source:
    set lines to create_list()
    set ok to append_list(lines and "\n/* Bootstrapper C main */\n")
    set ok to append_list(lines and "int main(int argc, char** argv) {\n")
    set ok to append_list(lines and "    init_ep_args(argc, argv);\n")
    set ok to append_list(lines and "    int result = (int)_main();\n")
    set ok to append_list(lines and "    ep_gc_shutdown();\n")
    set ok to append_list(lines and "    return result;\n")
    set ok to append_list(lines and "}\n")
    return join_strings(lines)

define get_c_test_main_source with program:
    set funcs to get_list(program and 3)
    set funcs_len to length_list(funcs)
    set test_cases to create_list()
    
    set idx to 0
    repeat while idx < funcs_len:
        set func to get_list(funcs and idx)
        set name to get_list(func and 1)
        set name_len to string_length(name)
        if name_len > 4:
            set prefix to substring(name and 0 and 5)
            if "test_" equals prefix:
                set ok to append_list(test_cases and name)
        set idx to idx + 1
        
    set test_count to length_list(test_cases)
    
    set lines to create_list()
    set ok to append_list(lines and "\n/* Test runner C main */\n")
    set ok to append_list(lines and "#include <sys/types.h>\n")
    set ok to append_list(lines and "#include <sys/wait.h>\n")
    set ok to append_list(lines and "#include <unistd.h>\n")
    set ok to append_list(lines and "#include <stdio.h>\n")
    set ok to append_list(lines and "#include <stdlib.h>\n\n")
    
    set ok to append_list(lines and "int run_test(long long (*test_func)(void), const char* name) {\n")
    set ok to append_list(lines and "    printf(\"test_%s ... \", name);\n")
    set ok to append_list(lines and "    fflush(stdout);\n")
    set ok to append_list(lines and "    pid_t pid = fork();\n")
    set ok to append_list(lines and "    if (pid < 0) {\n")
    set ok to append_list(lines and "        printf(\"FAILED (fork failed)\\n\");\n")
    set ok to append_list(lines and "        return 0;\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "    if (pid == 0) {\n")
    set ok to append_list(lines and "        exit((int)test_func());\n")
    set ok to append_list(lines and "    } else {\n")
    set ok to append_list(lines and "        int status;\n")
    set ok to append_list(lines and "        waitpid(pid, &status, 0);\n")
    set ok to append_list(lines and "        if (WIFEXITED(status)) {\n")
    set ok to append_list(lines and "            int exit_code = WEXITSTATUS(status);\n")
    set ok to append_list(lines and "            if (exit_code == 0) {\n")
    set ok to append_list(lines and "                printf(\"OK\\n\");\n")
    set ok to append_list(lines and "                return 1;\n")
    set ok to append_list(lines and "            } else {\n")
    set ok to append_list(lines and "                printf(\"FAILED (exit code %d)\\n\", exit_code);\n")
    set ok to append_list(lines and "                return 0;\n")
    set ok to append_list(lines and "            }\n")
    set ok to append_list(lines and "        } else if (WIFSIGNALED(status)) {\n")
    set ok to append_list(lines and "            int sig = WTERMSIG(status);\n")
    set ok to append_list(lines and "            printf(\"FAILED (crashed/signal %d)\\n\", sig);\n")
    set ok to append_list(lines and "            return 0;\n")
    set ok to append_list(lines and "        } else {\n")
    set ok to append_list(lines and "            printf(\"FAILED\\n\");\n")
    set ok to append_list(lines and "            return 0;\n")
    set ok to append_list(lines and "        }\n")
    set ok to append_list(lines and "    }\n")
    set ok to append_list(lines and "}\n\n")
    
    set ok to append_list(lines and "int main(int argc, char** argv) {\n")
    set ok to append_list(lines and "    init_ep_args(argc, argv);\n")
    
    set ok to append_list(lines and "    printf(\"Running ")
    set ok to append_list(lines and ep_int_to_str(test_count))
    set ok to append_list(lines and " tests...\\n\");\n")
    
    set ok to append_list(lines and "    int passed = 0;\n")
    set ok to append_list(lines and "    int failed = 0;\n")
    set ok to append_list(lines and "    int total = 0;\n\n")
    
    set idx2 to 0
    repeat while idx2 < test_count:
        set tc_name to get_list(test_cases and idx2)
        set ok to append_list(lines and "    total++;\n")
        set ok to append_list(lines and "    if (run_test(")
        set ok to append_list(lines and tc_name)
        set ok to append_list(lines and ", \"")
        set ok to append_list(lines and tc_name)
        set ok to append_list(lines and "\")) passed++; else failed++;\n")
        set idx2 to idx2 + 1
        
    set ok to append_list(lines and "\n    printf(\"\\nResult: %d passed; %d failed\\n\", passed, failed);\n")
    set ok to append_list(lines and "    if (failed > 0) return 1;\n")
    set ok to append_list(lines and "    return 0;\n")
    set ok to append_list(lines and "}\n")
    
    return join_strings(lines)

define collect_spawns_in_stmts with stmts and spawn_list:
    set len to length_list(stmts)
    set idx to 0
    repeat while idx < len:
        set stmt to get_list(stmts and idx)
        set type to get_list(stmt and 0)
        if type == 15: # NODE_SPAWN
            set ok to append_list(spawn_list and stmt)
        else:
            if type == 10: # NODE_IF
                set then_b to get_list(stmt and 2)
                set else_b to get_list(stmt and 3)
                set ok to collect_spawns_in_stmts(then_b and spawn_list)
                if else_b != 0:
                    set ok to collect_spawns_in_stmts(else_b and spawn_list)
            else:
                if type == 11: # NODE_REPEAT_WHILE
                    set body to get_list(stmt and 2)
                    set ok to collect_spawns_in_stmts(body and spawn_list)
        set idx to idx + 1
    return 0

define collect_all_spawns with program:
    set spawn_list to create_list()
    set funcs to get_list(program and 3)
    set len to length_list(funcs)
    set idx to 0
    repeat while idx < len:
        set func to get_list(funcs and idx)
        set body to get_list(func and 3)
        set ok to collect_spawns_in_stmts(body and spawn_list)
        set idx to idx + 1
    return spawn_list

define clone_list with lst:
    set new_lst to create_list()
    set len to length_list(lst)
    set idx to 0
    repeat while idx < len:
        set item to get_list(lst and idx)
        set ok to append_list(new_lst and item)
        set idx to idx + 1
    return new_lst

define check_expr_reads with expr and var_keys and var_values and state_keys and state_values:
    set type to get_list(expr and 0)
    if type == 1 || type == 2 || type == 17: # NODE_INT, NODE_STR, NODE_CHANNEL
        return 1
        
    if type == 3: # NODE_IDENT
        set name to get_list(expr and 1)
        set t to map_get(var_keys and var_values and name)
        set is_tracked to 0
        if t == 4 || t == 2 || t == 3 || t == 5 || t == 6: # TYPE_LIST, TYPE_STR, TYPE_DYNSTR, TYPE_REFLIST, TYPE_REFSTR
            set is_tracked to 1
        if is_tracked == 1:
            set st to map_get(state_keys and state_values and name)
            if st == 2: # OwnerState::Moved
                display "Safety Error: Use of moved value:"
                set ok to display_string(name)
                return 0
        return 1
        
    if type == 20: # NODE_BORROW
        set inner to get_list(expr and 1)
        return check_expr_reads(inner and var_keys and var_values and state_keys and state_values)
        
    if type == 21: # NODE_AWAIT
        set inner to get_list(expr and 1)
        return check_expr_reads(inner and var_keys and var_values and state_keys and state_values)
        
    if type == 4 || type == 5 || type == 14: # NODE_BINARY, NODE_COMP, NODE_LOGICAL
        set left to get_list(expr and 1)
        set right to get_list(expr and 3)
        set ok to check_expr_reads(left and var_keys and var_values and state_keys and state_values)
        if ok == 0:
            return 0
        set ok to check_expr_reads(right and var_keys and var_values and state_keys and state_values)
        if ok == 0:
            return 0
        return 1
        
    if type == 6: # NODE_CALL
        set name to get_list(expr and 1)
        set args to get_list(expr and 2)
        set args_len to length_list(args)
        set idx to 0
        repeat while idx < args_len:
            set arg to get_list(args and idx)
            set ok to check_expr_reads(arg and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
            set idx to idx + 1
        return 1
        
    if type == 18: # NODE_RECEIVE
        set chan to get_list(expr and 1)
        return check_expr_reads(chan and var_keys and var_values and state_keys and state_values)
        
    return 1

define dec_borrow_count with target and count_keys and count_values:
    set val to map_get(count_keys and count_values and target)
    if val != 0:
        if val > 0:
            set ok to map_put(count_keys and count_values and target and val - 1)
    return 0

define inc_borrow_count with target and count_keys and count_values:
    set val to map_get(count_keys and count_values and target)
    set ok to map_put(count_keys and count_values and target and val + 1)
    return 0

define check_safety_stmts with func and stmts and var_keys and var_values and state_keys and state_values and borrow_keys and borrow_values and count_keys and count_values:
    set len to length_list(stmts)
    set idx to 0
    repeat while idx < len:
        set stmt to get_list(stmts and idx)
        set type to get_list(stmt and 0)
        
        if type == 7: # NODE_SET
            set name to get_list(stmt and 1)
            set expr to get_list(stmt and 2)
            
            set ok to check_expr_reads(expr and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
                
            set old_target to map_get(borrow_keys and borrow_values and name)
            if old_target != 0:
                set ok to map_put(borrow_keys and borrow_values and name and 0)
                set ok to dec_borrow_count(old_target and count_keys and count_values)
                
            set expr_type to get_list(expr and 0)
            if expr_type == 20: # NODE_BORROW
                set inner to get_list(expr and 1)
                set inner_type to get_list(inner and 0)
                if inner_type == 3: # NODE_IDENT
                    set target to get_list(inner and 1)
                    set st to map_get(state_keys and state_values and target)
                    if st == 2:
                        display "Safety Error: Cannot borrow moved variable:"
                        set ok to display_string(target)
                        return 0
                    set ok to map_put(borrow_keys and borrow_values and name and target)
                    set ok to inc_borrow_count(target and count_keys and count_values)
                else:
                    display "Safety Error: Expected identifier in borrow expression"
                    return 0
            else:
                set bc to map_get(count_keys and count_values and name)
                if bc > 0:
                    display "Safety Error: Cannot modify variable because it is currently borrowed:"
                    set ok to display_string(name)
                    return 0
                    
                set t to map_get(var_keys and var_values and name)
                set is_tracked to 0
                if t == 4 || t == 2 || t == 3 || t == 5 || t == 6:
                    set is_tracked to 1
                    
                if is_tracked == 1:
                    if expr_type == 3: # NODE_IDENT
                        set src to get_list(expr and 1)
                        set src_t to map_get(var_keys and var_values and src)
                        set src_tracked to 0
                        if src_t == 4 || src_t == 2 || src_t == 3 || src_t == 5 || src_t == 6:
                            set src_tracked to 1
                        if src_tracked == 1:
                            set st to map_get(state_keys and state_values and src)
                            if st == 2:
                                display "Safety Error: Use of moved value:"
                                set ok to display_string(src)
                                return 0
                                
                            set src_bc to map_get(count_keys and count_values and src)
                            if src_bc > 0:
                                display "Safety Error: Cannot move variable because it is currently borrowed:"
                                set ok to display_string(src)
                                return 0
                                
                            if src_t != 5 && src_t != 6:
                                set ok to map_put(state_keys and state_values and src and 2)
                    set ok to map_put(state_keys and state_values and name and 1)
                
        if type == 16: # NODE_SEND
            set chan to get_list(stmt and 1)
            set val to get_list(stmt and 2)
            set ok to check_expr_reads(chan and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
            set val_type to get_list(val and 0)
            if val_type == 3: # NODE_IDENT
                set src to get_list(val and 1)
                set src_t to map_get(var_keys and var_values and src)
                set src_tracked to 0
                if src_t == 4 || src_t == 2 || src_t == 3 || src_t == 5 || src_t == 6:
                    set src_tracked to 1
                if src_tracked == 1:
                    set st to map_get(state_keys and state_values and src)
                    if st == 2:
                        display "Safety Error: Use of moved value:"
                        set ok to display_string(src)
                        return 0
                    set src_bc to map_get(count_keys and count_values and src)
                    if src_bc > 0:
                        display "Safety Error: Cannot move variable because it is currently borrowed:"
                        set ok to display_string(src)
                        return 0
                    if src_t != 5 && src_t != 6:
                        set ok to map_put(state_keys and state_values and src and 2)
                else:
                    set ok to check_expr_reads(val and var_keys and var_values and state_keys and state_values)
                    if ok == 0:
                        return 0
            else:
                set ok to check_expr_reads(val and var_keys and var_values and state_keys and state_values)
                if ok == 0:
                    return 0
                    
        if type == 15: # NODE_SPAWN
            set func_name to get_list(stmt and 1)
            set args to get_list(stmt and 2)
            set args_len to length_list(args)
            set a_idx to 0
            repeat while a_idx < args_len:
                set arg to get_list(args and a_idx)
                set arg_type to get_list(arg and 0)
                if arg_type == 3: # NODE_IDENT
                    set src to get_list(arg and 1)
                    set src_t to map_get(var_keys and var_values and src)
                    set src_tracked to 0
                    if src_t == 4 || src_t == 2 || src_t == 3 || src_t == 5 || src_t == 6:
                        set src_tracked to 1
                    if src_tracked == 1:
                        set st to map_get(state_keys and state_values and src)
                        if st == 2:
                            display "Safety Error: Use of moved value:"
                            set ok to display_string(src)
                            return 0
                        set src_bc to map_get(count_keys and count_values and src)
                        if src_bc > 0:
                            display "Safety Error: Cannot move variable because it is currently borrowed:"
                            set ok to display_string(src)
                            return 0
                        if src_t != 5 && src_t != 6:
                            set ok to map_put(state_keys and state_values and src and 2)
                    else:
                        set ok to check_expr_reads(arg and var_keys and var_values and state_keys and state_values)
                        if ok == 0:
                            return 0
                else:
                    set ok to check_expr_reads(arg and var_keys and var_values and state_keys and state_values)
                    if ok == 0:
                        return 0
                set a_idx to a_idx + 1
                
        if type == 9: # NODE_DISPLAY
            set expr to get_list(stmt and 1)
            set ok to check_expr_reads(expr and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
                
        if type == 8: # NODE_RETURN
            set expr to get_list(stmt and 1)
            set ok to check_expr_reads(expr and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
            set expr_type to get_list(expr and 0)
            if expr_type == 20: # NODE_BORROW
                set inner to get_list(expr and 1)
                set inner_type to get_list(inner and 0)
                if inner_type == 3: # NODE_IDENT
                    set target to get_list(inner and 1)
                    set params to get_list(func and 2)
                    set p_len to length_list(params)
                    set p_idx to 0
                    set is_borrowed_param to 0
                    repeat while p_idx < p_len:
                        set p_node to get_list(params and p_idx)
                        set p_name to get_list(p_node and 0)
                        set is_borrow to get_list(p_node and 1)
                        if string_concat(p_name and "") equals string_concat(target and ""):
                            if is_borrow == 1:
                                set is_borrowed_param to 1
                        set p_idx to p_idx + 1
                    if is_borrowed_param == 0:
                        display "Safety Error: Cannot return reference to local variable:"
                        set ok to display_string(target)
                        return 0
            else:
                if expr_type == 3: # NODE_IDENT
                    set name to get_list(expr and 1)
                    set t to map_get(var_keys and var_values and name)
                    if t == 5 || t == 6: # RefList or RefStr
                        set target to map_get(borrow_keys and borrow_values and name)
                        if target == 0:
                            set target to name
                        set params to get_list(func and 2)
                        set p_len to length_list(params)
                        set p_idx to 0
                        set is_borrowed_param to 0
                        repeat while p_idx < p_len:
                            set p_node to get_list(params and p_idx)
                            set p_name to get_list(p_node and 0)
                            set is_borrow to get_list(p_node and 1)
                            if string_concat(p_name and "") equals string_concat(target and ""):
                                if is_borrow == 1:
                                    set is_borrowed_param to 1
                            set p_idx to p_idx + 1
                        if is_borrowed_param == 0:
                            display "Safety Error: Cannot return reference to local variable:"
                            set ok to display_string(target)
                            return 0
                
        if type == 10: # NODE_IF
            set cond to get_list(stmt and 1)
            set then_b to get_list(stmt and 2)
            set else_b to get_list(stmt and 3)
            
            set ok to check_expr_reads(cond and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
                
            set then_state_keys to clone_list(state_keys)
            set then_state_values to clone_list(state_values)
            set then_borrow_keys to clone_list(borrow_keys)
            set then_borrow_values to clone_list(borrow_values)
            set then_count_keys to clone_list(count_keys)
            set then_count_values to clone_list(count_values)
            
            set ok to check_safety_stmts(func and then_b and var_keys and var_values and then_state_keys and then_state_values and then_borrow_keys and then_borrow_values and then_count_keys and then_count_values)
            if ok == 0:
                return 0
                
            set else_state_keys to clone_list(state_keys)
            set else_state_values to clone_list(state_values)
            set else_borrow_keys to clone_list(borrow_keys)
            set else_borrow_values to clone_list(borrow_values)
            set else_count_keys to clone_list(count_keys)
            set else_count_values to clone_list(count_values)
            if else_b != 0:
                set ok to check_safety_stmts(func and else_b and var_keys and var_values and else_state_keys and else_state_values and else_borrow_keys and else_borrow_values and else_count_keys and else_count_values)
                if ok == 0:
                    return 0
                    
            # Merge states
            set st_len to length_list(state_keys)
            set st_idx to 0
            repeat while st_idx < st_len:
                set var_name to get_list(state_keys and st_idx)
                set then_val to map_get(then_state_keys and then_state_values and var_name)
                set else_val to map_get(else_state_keys and else_state_values and var_name)
                if then_val == 2 || else_val == 2:
                    set ok to map_put(state_keys and state_values and var_name and 2)
                set st_idx to st_idx + 1
                
            # Merge borrows & borrow counts
            set b_len to length_list(then_borrow_keys)
            set b_idx to 0
            repeat while b_idx < b_len:
                set b_k to get_list(then_borrow_keys and b_idx)
                set b_v to get_list(then_borrow_values and b_idx)
                set ok to map_put(borrow_keys and borrow_values and b_k and b_v)
                set b_idx to b_idx + 1
            set b_len to length_list(else_borrow_keys)
            set b_idx to 0
            repeat while b_idx < b_len:
                set b_k to get_list(else_borrow_keys and b_idx)
                set b_v to get_list(else_borrow_values and b_idx)
                set ok to map_put(borrow_keys and borrow_values and b_k and b_v)
                set b_idx to b_idx + 1
                
            set bc_len to length_list(then_count_keys)
            set bc_idx to 0
            repeat while bc_idx < bc_len:
                set bc_k to get_list(then_count_keys and bc_idx)
                set bc_v to get_list(then_count_values and bc_idx)
                set cur_v to map_get(count_keys and count_values and bc_k)
                if bc_v > cur_v:
                    set ok to map_put(count_keys and count_values and bc_k and bc_v)
                set bc_idx to bc_idx + 1
            set bc_len to length_list(else_count_keys)
            set bc_idx to 0
            repeat while bc_idx < bc_len:
                set bc_k to get_list(else_count_keys and bc_idx)
                set bc_v to get_list(else_count_values and bc_idx)
                set cur_v to map_get(count_keys and count_values and bc_k)
                if bc_v > cur_v:
                    set ok to map_put(count_keys and count_values and bc_k and bc_v)
                set bc_idx to bc_idx + 1
                
        if type == 11: # NODE_REPEAT_WHILE
            set cond to get_list(stmt and 1)
            set body to get_list(stmt and 2)
            
            set ok to check_expr_reads(cond and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
                
            set start_state_keys to clone_list(state_keys)
            set start_state_values to clone_list(state_values)
            
            set ok to check_safety_stmts(func and body and var_keys and var_values and state_keys and state_values and borrow_keys and borrow_values and count_keys and count_values)
            if ok == 0:
                return 0
                
            set st_len to length_list(start_state_keys)
            set st_idx to 0
            repeat while st_idx < st_len:
                set var_name to get_list(start_state_keys and st_idx)
                set start_val to get_list(start_state_values and st_idx)
                set end_val to map_get(state_keys and state_values and var_name)
                if start_val == 1 && end_val == 2:
                    display "Safety Error: Variable is moved inside a loop and not reinitialized:"
                    set ok to display_string(var_name)
                    return 0
                set st_idx to st_idx + 1
                
            set ok to check_expr_reads(cond and var_keys and var_values and state_keys and state_values)
            if ok == 0:
                return 0
                
        set idx to idx + 1
    return 1

define analyze_safety with state and program:
    set funcs to get_list(program and 3)
    set funcs_len to length_list(funcs)
    set idx to 0
    repeat while idx < funcs_len:
        set func to get_list(funcs and idx)
        set name to get_list(func and 1)
        set params to get_list(func and 2)
        set body to get_list(func and 3)
        
        set var_keys to create_list() + 0
        set var_values to create_list() + 0
        
        set p_len to length_list(params)
        set p_idx to 0
        repeat while p_idx < p_len:
            set p_node to get_list(params and p_idx)
            set p_name to get_list(p_node and 0)
            set is_borrow to get_list(p_node and 1)
            set param_type to 1
            if is_borrow == 1:
                set param_type to 5
            set ok to map_put(var_keys and var_values and p_name and param_type)
            set p_idx to p_idx + 1
            
        set ok to collect_var_types(state and body and var_keys and var_values)
        
        set state_keys to create_list() + 0
        set state_values to create_list() + 0
        
        set p_idx to 0
        repeat while p_idx < p_len:
            set p_node to get_list(params and p_idx)
            set p_name to get_list(p_node and 0)
            set t to map_get(var_keys and var_values and p_name)
            if t == 4 || t == 2 || t == 3 || t == 5 || t == 6:
                set ok to map_put(state_keys and state_values and p_name and 1)
            set p_idx to p_idx + 1
            
        set borrow_keys to create_list() + 0
        set borrow_values to create_list() + 0
        set count_keys to create_list() + 0
        set count_values to create_list() + 0
        
        set ok to check_safety_stmts(func and body and var_keys and var_values and state_keys and state_values and borrow_keys and borrow_values and count_keys and count_values)
        if ok == 0:
            return 0
            
        set idx to idx + 1
    return 1

define generate_c with program and is_test_mode:
    set state to create_codegen_state()
    set ok to analyze_return_types(state and program)
    set safety_ok to analyze_safety(state and program)
    if safety_ok == 0:
        return ""
    
    # Emit headers and runtime
    set ok to emit(state and get_c_runtime_source())

    # Emit struct typedefs (if program has struct_defs at index 4)
    set prog_len to length_list(program)
    # Global field-slot registry: each distinct field name maps to one index used
    # by every struct, so a field name shared by two structs at different declared
    # positions can no longer collide on a conflicting #define (silent corruption).
    set field_slots to create_list()
    if prog_len > 4:
        set struct_defs to get_list(program and 4)
        set sd_len to length_list(struct_defs)
        if sd_len > 0:
            set ok to emit(state and "\n/* Struct Field Index Defines (global slots) */\n")
            # Pass 1: assign a global slot to every distinct field name.
            set sd_idx to 0
            repeat while sd_idx < sd_len:
                set sdef to get_list(struct_defs and sd_idx)
                set sfields to get_list(sdef and 2)
                set sf_len to length_list(sfields)
                set sf_idx to 0
                repeat while sf_idx < sf_len:
                    set sf to get_list(sfields and sf_idx)
                    set sf_name to get_list(sf and 0)
                    set slot to field_slot_index(field_slots and sf_name)
                    set sf_idx to sf_idx + 1
                set sd_idx to sd_idx + 1
            # Pass 2: emit one #define per distinct field name.
            set fs_len to length_list(field_slots)
            set fs_idx to 0
            repeat while fs_idx < fs_len:
                set fname to get_list(field_slots and fs_idx)
                set line to "#define EP_FIELD_"
                set line to string_concat(line and fname)
                set line to string_concat(line and " ")
                set line to string_concat(line and ep_int_to_str(fs_idx))
                set line to string_concat(line and "\n")
                set ok to emit(state and line)
                set fs_idx to fs_idx + 1
    # Every struct instance is allocated with room for any global field index.
    set slot_line to "#define EP_STRUCT_MAX_SLOTS "
    set slot_line to string_concat(slot_line and ep_int_to_str(length_list(field_slots) + 8))
    set slot_line to string_concat(slot_line and "\n")
    set ok to emit(state and slot_line)

    # Emit enum tag defines (if program has enum_defs at index 5)
    # Global tag registry: one tag per distinct variant name. Variant names are
    # unique within an enum, so within-enum tags stay distinct; sharing a tag
    # value across enums is harmless (tags are never compared across enum types)
    # and fixes the old bug where the same variant name in two enums received
    # mismatched tag numbers.
    set tag_slots to create_list()
    if prog_len > 5:
        set enum_defs to get_list(program and 5)
        set ed_len to length_list(enum_defs)
        if ed_len > 0:
            set ok to emit(state and "\n/* Enum Tag Defines (global slots) */\n")
            set ed_idx to 0
            repeat while ed_idx < ed_len:
                set edef to get_list(enum_defs and ed_idx)
                set evariants to get_list(edef and 2)
                set ev_len to length_list(evariants)
                set ev_idx to 0
                repeat while ev_idx < ev_len:
                    set ev to get_list(evariants and ev_idx)
                    set ev_name to get_list(ev and 0)
                    set tslot to field_slot_index(tag_slots and ev_name)
                    set ev_idx to ev_idx + 1
                set ed_idx to ed_idx + 1
            set ts_len to length_list(tag_slots)
            set ts_idx to 0
            repeat while ts_idx < ts_len:
                set tname to get_list(tag_slots and ts_idx)
                set line to "#define EP_TAG_"
                set line to string_concat(line and tname)
                set line to string_concat(line and " ")
                set line to string_concat(line and ep_int_to_str(ts_idx))
                set line to string_concat(line and "\n")
                set ok to emit(state and line)
                set ts_idx to ts_idx + 1
    
    # Emit FFI external prototypes
    set externals to get_list(program and 2)
    set ext_len to length_list(externals)
    set ok to emit(state and "\n/* External Function Prototypes (FFI) */\n")
    set idx to 0
    repeat while idx < ext_len:
        set ext to get_list(externals and idx)
        set name to get_list(ext and 1)
        set params to get_list(ext and 2)
        set p_len to length_list(params)
        
        set proto to "long long "
        set proto to string_concat(proto and name)
        set proto to string_concat(proto and "(")
        
        set p_i to 0
        repeat while p_i < p_len:
            set proto to string_concat(proto and "long long")
            if p_i < p_len - 1:
                set proto to string_concat(proto and ", ")
            set p_i to p_i + 1
        set proto to string_concat(proto and ");\n")
        set ok to emit(state and proto)
        set idx to idx + 1
    set ok to emit(state and "\n")
        
    # Emit function prototypes
    set funcs to get_list(program and 3)
    set len to length_list(funcs)
    
    set ok to emit(state and "\n/* User Function Prototypes */\n")
    set idx to 0
    repeat while idx < len:
        set func to get_list(funcs and idx)
        set name to get_list(func and 1)
        set params to get_list(func and 2)
        set p_len to length_list(params)
        
        set is_async to 0
        if length_list(func) > 4:
            set is_async to get_list(func and 4)
            
        set proto to "long long "
        set proto to string_concat(proto and get_fn_c_name(func))
        set proto to string_concat(proto and "(")
        
        set p_i to 0
        repeat while p_i < p_len:
            set proto to string_concat(proto and "long long")
            if p_i < p_len - 1:
                set proto to string_concat(proto and ", ")
            set p_i to p_i + 1
        set proto to string_concat(proto and ");\n")
        set ok to emit(state and proto)
        
        if is_async == 1:
            set proto2 to "long long "
            set proto2 to string_concat(proto2 and get_fn_c_name(func))
            set proto2 to string_concat(proto2 and "_impl(")
            set p_i to 0
            repeat while p_i < p_len:
                set proto2 to string_concat(proto2 and "long long")
                if p_i < p_len - 1:
                    set proto2 to string_concat(proto2 and ", ")
                set p_i to p_i + 1
            set proto2 to string_concat(proto2 and ");\n")
            set ok to emit(state and proto2)
            
            set proto3 to "void* "
            set proto3 to string_concat(proto3 and get_fn_c_name(func))
            set proto3 to string_concat(proto3 and "_async_wrapper(void* r);\n")
            set ok to emit(state and proto3)
            
        set idx to idx + 1
    set ok to emit(state and "\n")

    # Collect and emit thread spawn wrappers
    set spawn_list to collect_all_spawns(program)
    set dummy to set_codegen_spawn_list(state and spawn_list)
    set spawn_len to length_list(spawn_list)
    set ok to emit(state and "\n/* Thread Spawn Wrappers */\n")
    
    set idx to 0
    repeat while idx < spawn_len:
        set spawn_node to get_list(spawn_list and idx)
        set func_name to get_list(spawn_node and 1)
        set args to get_list(spawn_node and 2)
        set args_len to length_list(args)
        
        set struct_decl to "typedef struct {\n"
        set j to 0
        repeat while j < args_len:
            set struct_decl to string_concat(struct_decl and "    long long arg")
            set struct_decl to string_concat(struct_decl and ep_int_to_str(j))
            set struct_decl to string_concat(struct_decl and ";\n")
            set j to j + 1
        if args_len == 0:
            set struct_decl to string_concat(struct_decl and "    int dummy;\n")
        set struct_decl to string_concat(struct_decl and "} spawn_args_")
        set struct_decl to string_concat(struct_decl and ep_int_to_str(idx))
        set struct_decl to string_concat(struct_decl and ";\n\n")
        set ok to emit(state and struct_decl)
        
        set wrap_fn to "void* spawn_wrapper_"
        set wrap_fn to string_concat(wrap_fn and ep_int_to_str(idx))
        set wrap_fn to string_concat(wrap_fn and "(void* r) {\n")
        set wrap_fn to string_concat(wrap_fn and "    spawn_args_")
        set wrap_fn to string_concat(wrap_fn and ep_int_to_str(idx))
        set wrap_fn to string_concat(wrap_fn and "* args = (spawn_args_")
        set wrap_fn to string_concat(wrap_fn and ep_int_to_str(idx))
        set wrap_fn to string_concat(wrap_fn and "*)r;\n")
        set wrap_fn to string_concat(wrap_fn and "    ")
        set c_name to func_name
        if "main" equals func_name:
            set c_name to "_main"
        set wrap_fn to string_concat(wrap_fn and c_name)
        set wrap_fn to string_concat(wrap_fn and "(")
        set j to 0
        repeat while j < args_len:
            set wrap_fn to string_concat(wrap_fn and "args->arg")
            set wrap_fn to string_concat(wrap_fn and ep_int_to_str(j))
            if j < args_len - 1:
                set wrap_fn to string_concat(wrap_fn and ", ")
            set j to j + 1
        set wrap_fn to string_concat(wrap_fn and ");\n")
        set wrap_fn to string_concat(wrap_fn and "    free(args);\n")
        set wrap_fn to string_concat(wrap_fn and "    return NULL;\n")
        set wrap_fn to string_concat(wrap_fn and "}\n\n")
        set ok to emit(state and wrap_fn)
        set idx to idx + 1
    set ok to emit(state and "\n")
    
    # Reset spawn index
    set dummy to set_codegen_spawn_index(state and 0)

    # Emit method definitions (if present at index 6)
    if prog_len > 6:
        set method_defs to get_list(program and 6)
        set md_len to length_list(method_defs)
        set md_idx to 0
        repeat while md_idx < md_len:
            set mdef to get_list(method_defs and md_idx)
            # method_def: [39, method_name, struct_name, params, body]
            set mname to get_list(mdef and 1)
            set msname to get_list(mdef and 2)
            set mparams to get_list(mdef and 3)
            set mbody to get_list(mdef and 4)
            # Build a function node with self as first parameter
            set full_params to create_list() + 0
            set self_param to create_list() + 0
            set ok to append_list(self_param and "self")
            set ok to append_list(self_param and 0)
            set ok to append_list(full_params and self_param)
            set mp_len to length_list(mparams)
            set mp_idx to 0
            repeat while mp_idx < mp_len:
                set mp to get_list(mparams and mp_idx)
                set ok to append_list(full_params and mp)
                set mp_idx to mp_idx + 1
            set method_func to make_node_func(mname and full_params and mbody and 0) + 0
            set ok to gen_function(state and method_func)
            set md_idx to md_idx + 1
    
    # Emit functions
    set idx to 0
    repeat while idx < len:
        set func to get_list(funcs and idx)
        set ok to gen_function(state and func)
        set idx to idx + 1
        
    # Emit main bootstrapper
    if is_test_mode == 1:
        set ok to emit(state and get_c_test_main_source(program))
    else:
        set ok to emit(state and get_c_main_source())
    
    set lines to get_list(state and 0)
    set c_code to join_strings(lines)
    return c_code

