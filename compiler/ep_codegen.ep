    set ok to append_list(lines and "    buf[n] = '\\0';\n")
    set ok to append_list(lines and "    return buf;\n")
    set ok to append_list(lines and "}\n")
    set ok to append_list(lines and "\n")
    set ok to append_list(lines and "long long ep_net_close(long long fd) {\n")
