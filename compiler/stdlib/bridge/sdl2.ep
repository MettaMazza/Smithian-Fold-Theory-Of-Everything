# ============================================================
# Audio
# ============================================================
define sdl_open_audio with desired as Int and obtained as Int returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_OpenAudio")
    return ep_dlcall2(fn and desired and obtained)

define sdl_close_audio:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_CloseAudio")
    return ep_dlcall0(fn)

define sdl_pause_audio with pause_on as Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_PauseAudio")
    return ep_dlcall1(fn and pause_on)

# ============================================================
# Misc
# ============================================================
define sdl_get_platform returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_GetPlatform")
    return ep_dlcall0(fn)

define sdl_set_hint with name as Str and value as Str returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_SetHint")
    return ep_dlcall2(fn and name and value)

define sdl_log with message as Str:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_Log")
    return ep_dlcall1(fn and message)
