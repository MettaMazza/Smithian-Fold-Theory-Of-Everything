# Mouse
# ============================================================
define sdl_get_mouse_state with x_ptr as Int and y_ptr as Int returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_GetMouseState")
    return ep_dlcall2(fn and x_ptr and y_ptr)

define sdl_warp_mouse_in_window with win as Int and x as Int and y as Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_WarpMouseInWindow")
    return ep_dlcall3(fn and win and x and y)

define sdl_show_cursor with toggle as Int returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_ShowCursor")
    return ep_dlcall1(fn and toggle)

# ============================================================
# Clipboard
# ============================================================
define sdl_set_clipboard_text with text as Str returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_SetClipboardText")
    return ep_dlcall1(fn and text)

define sdl_get_clipboard_text returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_GetClipboardText")
    return ep_dlcall0(fn)

define sdl_has_clipboard_text returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_HasClipboardText")
    return ep_dlcall0(fn)

# ============================================================
# Timer
# ============================================================
define sdl_delay with ms as Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_Delay")
    return ep_dlcall1(fn and ms)

define sdl_get_ticks returning Int:
    set fn to ep_dlsym(SDL_HANDLE and "SDL_GetTicks")
