# ============================================================
# Transformations
# ============================================================
define cairo_translate with cr as Int and tx as Int and ty as Int:
    set fn to ep_dlsym(CAIRO_HANDLE and "cairo_translate")
    return ep_dlcall3(fn and cr and tx and ty)

define cairo_scale with cr as Int and sx as Int and sy as Int:
