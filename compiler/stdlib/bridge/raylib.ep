# ============================================================
# raylib Bridge for ErnosPlain
# 2D/3D game rendering, audio, input — raylib.com
# ============================================================
# Usage: import "stdlib/bridge/raylib"
# Requires: raylib installed (brew install raylib / apt install libraylib-dev)
# Library: libraylib.dylib (macOS) / libraylib.so (Linux)
# ============================================================

# Library handle (global)
set RAYLIB_HANDLE to 0

# ============================================================
# Color constants (RGBA packed as 32-bit: R | G<<8 | B<<16 | A<<24)
# ============================================================
set RAYLIB_WHITE to 4294967295
set RAYLIB_BLACK to 255
set RAYLIB_RED to 4278190335
set RAYLIB_GREEN to 4278255360
set RAYLIB_BLUE to 4294901760
set RAYLIB_YELLOW to 4278255615
set RAYLIB_ORANGE to 4278233343
set RAYLIB_PURPLE to 4286578943
set RAYLIB_PINK to 4290825215
set RAYLIB_LIGHTGRAY to 4291348680
set RAYLIB_DARKGRAY to 4283716692
set RAYLIB_GRAY to 4286611584
set RAYLIB_MAROON to 4278190208
set RAYLIB_LIME to 4278255104
set RAYLIB_DARKBLUE to 4289069056
set RAYLIB_DARKGREEN to 4278222848
set RAYLIB_DARKPURPLE to 4285595648
