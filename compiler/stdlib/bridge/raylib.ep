# ============================================================
# Collision detection
# ============================================================
define raylib_check_collision_recs with x1 as Int and y1 as Int and w1 as Int and h1 as Int and x2 as Int and y2 as Int and w2 as Int and h2 as Int returning Int:
    # Manual AABB collision since CheckCollisionRecs takes Rectangle structs by value
    if x1 < x2 + w2 and x1 + w1 > x2 and y1 < y2 + h2 and y1 + h1 > y2:
        return 1
    return 0

define raylib_check_collision_circles with cx1 as Int and cy1 as Int and r1 as Int and cx2 as Int and cy2 as Int and r2 as Int returning Int:
    # Manual circle collision (avoid struct-by-value)
    set dx to cx1 - cx2
    set dy to cy1 - cy2
    set dist_sq to dx * dx + dy * dy
    set rad_sum to r1 + r2
    if dist_sq < rad_sum * rad_sum:
        return 1
    return 0

define raylib_check_collision_point_rec with px as Int and py as Int and rx as Int and ry as Int and rw as Int and rh as Int returning Int:
    # Manual point-in-rectangle check
    if px >= rx and px <= rx + rw and py >= ry and py <= ry + rh:
        return 1
    return 0

# ============================================================
# Timing
# ============================================================
define raylib_get_frame_time returning Int:
    # Returns frame delta as integer milliseconds (raylib returns float)
    set fn to ep_dlsym(RAYLIB_HANDLE and "GetFrameTime")
    return ep_dlcall0(fn)

define raylib_get_time returning Int:
    # Returns elapsed time since InitWindow (raylib returns double)
    set fn to ep_dlsym(RAYLIB_HANDLE and "GetTime")
    return ep_dlcall0(fn)

define raylib_wait with seconds as Int:
    set fn to ep_dlsym(RAYLIB_HANDLE and "WaitTime")
    return ep_dlcall1(fn and seconds)

