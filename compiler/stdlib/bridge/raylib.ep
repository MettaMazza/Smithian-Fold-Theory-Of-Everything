# ============================================================
# Library initialization
# ============================================================
define raylib_load:
    set RAYLIB_HANDLE to ep_dlopen("libraylib.dylib")
    if RAYLIB_HANDLE equals 0:
        set RAYLIB_HANDLE to ep_dlopen("/opt/homebrew/lib/libraylib.dylib")
    if RAYLIB_HANDLE equals 0:
        set RAYLIB_HANDLE to ep_dlopen("/usr/local/lib/libraylib.dylib")
    if RAYLIB_HANDLE equals 0:
        set RAYLIB_HANDLE to ep_dlopen("libraylib.so")
    if RAYLIB_HANDLE equals 0:
        set RAYLIB_HANDLE to ep_dlopen("libraylib.so.5")
    if RAYLIB_HANDLE equals 0:
        set RAYLIB_HANDLE to ep_dlopen("/usr/lib/libraylib.so")
    return RAYLIB_HANDLE

# ============================================================
# Window management
# ============================================================
define raylib_init_window with width as Int and height as Int and title as Str:
    if RAYLIB_HANDLE equals 0:
        set ok to raylib_load()
    set fn to ep_dlsym(RAYLIB_HANDLE and "InitWindow")
    return ep_dlcall3(fn and width and height and title)

define raylib_close_window:
    set fn to ep_dlsym(RAYLIB_HANDLE and "CloseWindow")
    return ep_dlcall0(fn)

define raylib_window_should_close returning Int:
    set fn to ep_dlsym(RAYLIB_HANDLE and "WindowShouldClose")
    return ep_dlcall0(fn)

define raylib_set_target_fps with fps as Int:
    set fn to ep_dlsym(RAYLIB_HANDLE and "SetTargetFPS")
    return ep_dlcall1(fn and fps)

define raylib_get_fps returning Int:
    set fn to ep_dlsym(RAYLIB_HANDLE and "GetFPS")
    return ep_dlcall0(fn)

