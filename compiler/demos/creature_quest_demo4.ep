    set q5 to create_map()
    set ok to map_insert(q5 and "name" and "Master Crafter")
    set ok to map_insert(q5 and "target" and 5)
    set ok to map_insert(q5 and "current" and 0)
    set ok to map_insert(q5 and "reward" and 80)
    set ok to map_insert(q5 and "done" and 0)
    set ok to append_list(quests and q5)

    return quests

define update_quest_progress with quests as List and quest_idx as Int and amount as Int:
    set q to get_list(quests and quest_idx)
    set done to map_get_val(q and "done")
    if done == 1:
        return 0
    set current to map_get_val(q and "current")
    set ok to map_insert(q and "current" and current + amount)
    set target to map_get_val(q and "target")
    if current + amount >= target:
        set ok to map_insert(q and "done" and 1)
        set qname to map_get_val(q and "name")
        set reward to map_get_val(q and "reward")
        display f"  🏆 QUEST COMPLETE: {qname}! (+{reward} gold)"
        return reward
    return 0

define show_quests with quests as List:
    display ""
    display "  📜═══════ QUEST JOURNAL ═══════"
    set i to 0
    repeat while i < length_list(quests):
        set q to get_list(quests and i)
        set qname to map_get_val(q and "name")
        set current to map_get_val(q and "current")
        set target to map_get_val(q and "target")
        set done to map_get_val(q and "done")
        if done == 1:
            display f"    ✅ {qname} ({current}/{target}) — COMPLETE"
        else:
            display f"    📌 {qname} ({current}/{target})"
        set i to i + 1
    display "  ═══════════════════════════════"

# ───────────── 14. Achievement System ─────────────

define create_achievements returning Map:
    set ach to create_map()
    set ok to map_insert(ach and "First Blood" and 0)
    set ok to map_insert(ach and "Dragon Slayer" and 0)
    set ok to map_insert(ach and "Prestige I" and 0)
    set ok to map_insert(ach and "Companion Bond" and 0)
    set ok to map_insert(ach and "Floor 25" and 0)
    set ok to map_insert(ach and "Floor 50" and 0)
    set ok to map_insert(ach and "Floor 100" and 0)
    set ok to map_insert(ach and "Master Crafter" and 0)
    set ok to map_insert(ach and "Wealthy" and 0)
    set ok to map_insert(ach and "Veteran" and 0)
    return ach

define unlock_achievement with achievements as Map and name as Str returning Int:
    if map_contains(achievements and name):
        set val to map_get_val(achievements and name)
        if val == 0:
            set ok to map_insert(achievements and name and 1)
            display ""
            display f"  🏅════════════════════════════════════════"
            display f"    ACHIEVEMENT UNLOCKED: {name}!"
            display f"  🏅════════════════════════════════════════"
            return 1
    return 0

define count_achievements with achievements as Map returning Int:
    set keys to map_keys(achievements)
    set count to 0
    set i to 0
    repeat while i < length_list(keys):
        set k to get_list(keys and i)
        set val to map_get_val(achievements and k)
        if val == 1:
            set count to count + 1
        set i to i + 1
    return count

define show_achievements with achievements as Map:
    display ""
    display "  🏅═══════ ACHIEVEMENTS ═══════"
    set keys to map_keys(achievements)
    set i to 0
    repeat while i < length_list(keys):
        set k to get_list(keys and i)
        set val to map_get_val(achievements and k)
        if val == 1:
            display f"    ✅ {k}"
        else:
            display f"    🔒 {k}"
        set i to i + 1
    display "  ═════════════════════════════"

# ───────────── 15. Monster Generation ─────────────

define create_monster with floor as Int returning Monster:
    set base_hp to 20 + floor * 4
    set base_atk to 4 + floor * 2
    set base_def to 1 + floor / 2
    set base_spd to 3 + floor / 3
    set tier to 1
    if floor > 10:
        set tier to 2
    if floor > 25:
        set tier to 3
    if floor > 50:
        set tier to 4

    set biome to get_biome(floor)
    set roll to ep_random_int(1 and 6)

    if biome == "Mushroom Forest":
        if roll <= 2:
            return create Monster:
                name is "Spore Sprite"
                health is base_hp
                max_health is base_hp
                attack is base_atk
                defense is base_def
                speed is base_spd + 2
                xp_reward is 8 + floor * 2
                gold_reward is 5 + floor
                element is "poison"
                special_attack is "Spore Cloud"
                loot_tier is tier
        else if roll <= 4:
            return create Monster:
                name is "Fungal Golem"
                health is base_hp + 10
                max_health is base_hp + 10
                attack is base_atk - 1
                defense is base_def + 3
                speed is base_spd - 1
                xp_reward is 10 + floor * 2
                gold_reward is 7 + floor
                element is "poison"
                special_attack is "Toxic Slam"
                loot_tier is tier
        return create Monster:
            name is "Treant"
            health is base_hp + 15
            max_health is base_hp + 15
            attack is base_atk + 1
            defense is base_def + 2
            speed is base_spd - 2
            xp_reward is 12 + floor * 2
            gold_reward is 8 + floor
            element is "physical"
            special_attack is "Branch Whip"
            loot_tier is tier

    else if biome == "Lava Depths":
        if roll <= 3:
            return create Monster:
                name is "Magma Elemental"
                health is base_hp + 5
                max_health is base_hp + 5
                attack is base_atk + 3
                defense is base_def + 1
                speed is base_spd
                xp_reward is 12 + floor * 2
                gold_reward is 8 + floor
                element is "fire"
                special_attack is "Lava Burst"
                loot_tier is tier
        return create Monster:
            name is "Fire Drake"
            health is base_hp
            max_health is base_hp
            attack is base_atk + 2
            defense is base_def
            speed is base_spd + 3
            xp_reward is 11 + floor * 2
            gold_reward is 9 + floor
            element is "fire"
            special_attack is "Flame Jet"
            loot_tier is tier

    else if biome == "Frozen Halls":
        if roll <= 3:
            return create Monster:
                name is "Frost Wraith"
                health is base_hp
                max_health is base_hp
                attack is base_atk + 1
                defense is base_def
                speed is base_spd + 2
                xp_reward is 10 + floor * 2
                gold_reward is 7 + floor
                element is "ice"
                special_attack is "Frost Breath"
                loot_tier is tier
        return create Monster:
            name is "Ice Golem"
            health is base_hp + 15
            max_health is base_hp + 15
            attack is base_atk
            defense is base_def + 4
            speed is base_spd - 2
            xp_reward is 12 + floor * 2
            gold_reward is 9 + floor
            element is "ice"
            special_attack is "Glacier Crush"
            loot_tier is tier

    else if biome == "Shadow Ruins":
        if roll <= 3:
            return create Monster:
                name is "Shade Assassin"
                health is base_hp - 5
                max_health is base_hp - 5
                attack is base_atk + 4
                defense is base_def - 1
                speed is base_spd + 5
                xp_reward is 13 + floor * 2
                gold_reward is 10 + floor
                element is "poison"
                special_attack is "Shadow Strike"
                loot_tier is tier
        return create Monster:
            name is "Cursed Knight"
            health is base_hp + 10
            max_health is base_hp + 10
            attack is base_atk + 2
            defense is base_def + 3
            speed is base_spd
            xp_reward is 14 + floor * 2
            gold_reward is 11 + floor
            element is "physical"
            special_attack is "Cursed Blade"
            loot_tier is tier

    else if biome == "Sky Gardens":
        if roll <= 3:
            return create Monster:
                name is "Storm Harpy"
