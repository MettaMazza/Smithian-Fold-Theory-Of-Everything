                max_health is base_hp - 3
                attack is base_atk + 2
                defense is base_def
                speed is base_spd + 4
                xp_reward is 11 + floor * 2
                gold_reward is 8 + floor
                element is "physical"
                special_attack is "Wind Slash"
                loot_tier is tier
        return create Monster:
            name is "Cloud Serpent"
            health is base_hp + 8
            max_health is base_hp + 8
            attack is base_atk + 1
            defense is base_def + 2
            speed is base_spd + 2
            xp_reward is 12 + floor * 2
            gold_reward is 9 + floor
            element is "physical"
            special_attack is "Lightning Coil"
            loot_tier is tier

    else if biome == "Crystal Caverns":
        if roll <= 3:
            return create Monster:
                name is "Crystal Spider"
                health is base_hp - 2
                max_health is base_hp - 2
                attack is base_atk + 1
                defense is base_def + 2
                speed is base_spd + 3
                xp_reward is 10 + floor * 2
                gold_reward is 8 + floor
                element is "physical"
                special_attack is "Crystal Web"
