define structure Player:
    field name as Str is "Hero"
    field health as Int is 100
    field max_health as Int is 100
    field attack as Int is 8
    field defense as Int is 5
    field speed as Int is 5
    field gold as Int is 30
    field floor as Int is 1
    field turns_total as Int is 0
    field weapon_name as Str is "Rusty Blade"
    field weapon_damage as Int is 3
    field weapon_element as Str is "physical"
    field armor_name as Str is "Worn Leather"
    field armor_defense as Int is 2
    field xp as Int is 0
    field level as Int is 1
    field shield_turns as Int is 0
    field defend_active as Int is 0
    field lifetime_kills as Int is 0
    field lifetime_gold as Int is 0
    field lifetime_floors as Int is 0
    field runs_completed as Int is 0
    field prestige_level as Int is 0
    field boss_kills as Int is 0

define structure Companion:
    field name as Str is "Luna"
    field species as Str is "Drake"
    field health as Int is 20
    field max_health as Int is 20
    field hunger as Int is 80
    field happiness as Int is 70
    field bond as Int is 0
    field xp as Int is 0
    field level as Int is 0
    field stage as Int is 0
    field attack as Int is 4
    field ability1 as Str is "none"
    field ability2 as Str is "none"
    field ability3 as Str is "none"
    field personality as Str is "playful"
    field trust as Int is 10
    field kills_assisted as Int is 0

define structure Monster:
    field name as Str is "Slime"
    field health as Int is 25
    field max_health as Int is 25
    field attack as Int is 6
    field defense as Int is 2
    field speed as Int is 3
    field xp_reward as Int is 12
    field gold_reward as Int is 10
    field is_boss as Int is 0
    field element as Str is "physical"
    field special_attack as Str is "none"
    field loot_tier as Int is 1
    field phase as Int is 1

define structure Item:
    field name as Str is "Unknown"
    field item_type as Str is "consumable"
    field power as Int is 0
    field rarity as Str is "common"
    field description as Str is ""

define structure StatusEntry:
    field effect_name as Str is "none"
    field turns_remaining as Int is 0
    field potency as Int is 0

# ───────────── 6. Persistent Memory System ─────────────
# Conversation memory + gameplay journal — persists across sessions

define memory_create returning List:
    set mem to create_list()
    return mem

define memory_add with mem as List and role as Str and content as Str returning List:
    set entry to f"{role}: {content}"
    set ok to append_list(mem and entry)
    # Keep last 8 entries
    repeat while length_list(mem) > 8:
        set new_mem to create_list()
        set i to 1
        repeat while i < length_list(mem):
            set item to get_list(mem and i)
            set ok to append_list(new_mem and item)
            set i to i + 1
        return new_mem
    return mem

define memory_to_context with mem as List returning Str:
    set ctx to ""
    set i to 0
    repeat while i < length_list(mem):
        set entry to get_list(mem and i)
        set ctx to f"{ctx}\n  {entry}"
        set i to i + 1
    return ctx

define save_memory with mem as List:
    set data to ""
    set i to 0
    repeat while i < length_list(mem):
        set entry to get_list(mem and i)
        if i > 0:
            set data to f"{data}|||{entry}"
        else:
            set data to entry
        set i to i + 1
    set ok to file_write(get_memory_path() and data)

define load_memory returning List:
    set mem to create_list()
    if file_exists(get_memory_path()) == 0:
        return mem
    set data to file_read(get_memory_path())
    if string_length(data) < 3:
        return mem
    # Parse entries separated by |||
    set pos to 0
    set len to string_length(data)
    repeat while pos < len:
        set sep to string_index_of(substring(data and pos and len - pos) and "|||")
        if sep < 0:
            set entry to substring(data and pos and len - pos)
            if string_length(entry) > 0:
                set ok to append_list(mem and entry)
            set pos to len
        else:
            set entry to substring(data and pos and sep)
            if string_length(entry) > 0:
                set ok to append_list(mem and entry)
            set pos to pos + sep + 3
    return mem

# Gameplay journal — remembers key moments forever
define journal_add with event as Str and floor as Int and turn as Int:
    set entry to f"[Floor {floor}, Turn {turn}] {event}"
    set existing to ""
    if file_exists(get_journal_path()):
        set existing to file_read(get_journal_path())
    set updated to f"{existing}\n{entry}"
    set ok to file_write(get_journal_path() and updated)

define journal_get_recent with count as Int returning Str:
    if file_exists(get_journal_path()) == 0:
        return ""
    set data to file_read(get_journal_path())
    if string_length(data) < 3:
        return ""
    # Return last N lines worth
    set lines to create_list()
    set pos to 0
    set len to string_length(data)
    repeat while pos < len:
        set nl to string_index_of(substring(data and pos and len - pos) and "\n")
        if nl < 0:
            set line to substring(data and pos and len - pos)
            if string_length(line) > 1:
                set ok to append_list(lines and line)
            set pos to len
        else:
            set line to substring(data and pos and nl)
            if string_length(line) > 1:
                set ok to append_list(lines and line)
            set pos to pos + nl + 1
    # Get last count entries
    set result to ""
    set total to length_list(lines)
    set start to total - count
    if start < 0:
        set start to 0
    set i to start
    repeat while i < total:
        set line to get_list(lines and i)
        set result to f"{result}\n  {line}"
        set i to i + 1
    return result

# ───────────── 7. Companion Personality Engine ─────────────

define get_stage_name with stage as Int returning Str:
    if stage == 0:
        return "a glowing egg"
    else if stage == 1:
        return "a curious hatchling"
    else if stage == 2:
        return "an energetic juvenile"
    else if stage == 3:
        return "a powerful adult"
    else if stage == 4:
        return "a wise ancient elder"
    return "a mythic ascendant"

define get_stage_emoji with stage as Int returning Str:
    if stage == 0:
        return "🥚"
    else if stage == 1:
        return "🐣"
    else if stage == 2:
        return "🐾"
    else if stage == 3:
        return "🦁"
    else if stage == 4:
        return "👑"
    return "✨"

define get_species_emoji with species as Str returning Str:
    if species == "Drake":
        return "🐉"
    else if species == "Kitsune":
        return "🦊"
    else if species == "Griffin":
        return "🦅"
    else if species == "Phantom":
        return "👻"
    else if species == "Wyrm":
        return "🐍"
    else if species == "Golem":
        return "🪨"
    return "🐾"

define get_personality_desc with personality as Str and bond as Int returning Str:
    if personality == "brave":
        if bond > 60:
            return "fiercely loyal and encouraging, always ready to fight by your side"
        return "bold and courageous, eager to prove their bravery"
    else if personality == "shy":
        if bond > 60:
            return "quietly devoted, expressing care through small gestures"
        return "timid and cautious, hiding behind you but always watching"
    else if personality == "playful":
        if bond > 60:
            return "joyfully bonded, turning every moment into play"
        return "mischievous and energetic, always looking for fun"
    else if personality == "wise":
        if bond > 60:
            return "deeply insightful, sharing ancient wisdom with warmth"
        return "contemplative and observant, speaking in riddles"
    else if personality == "fierce":
        if bond > 60:
            return "passionately protective, growling at any threat to you"
        return "wild and untamed, struggling to control their power"
    else if personality == "gentle":
        if bond > 60:
            return "tender and nurturing, healing wounds with a touch"
        return "calm and serene, radiating peaceful energy"
    return "mysterious and unpredictable"

define get_mood_text with happiness as Int returning Str:
    if happiness >= 90:
        return "ecstatic and radiating joy"
    else if happiness >= 70:
        return "happy and content"
    else if happiness >= 50:
        return "calm but watchful"
    else if happiness >= 30:
        return "uneasy and a bit sad"
    return "distressed and withdrawn"

define build_companion_prompt with c as Companion and event as Str and memory as List and journal_ctx as Str returning Str:
    set stage_desc to get_stage_name(c.stage)
    set pers_desc to get_personality_desc(c.personality and c.bond)
    set mood to get_mood_text(c.happiness)
    set mem_ctx to memory_to_context(memory)
    set prompt to f"You are {c.name}, {stage_desc} {c.species} companion in a fantasy RPG. "
    set prompt to f"{prompt}Personality: {pers_desc}. "
    set prompt to f"{prompt}Mood: {mood}. Bond: {c.bond}/100. Hunger: {c.hunger}/100. Trust: {c.trust}/100. "
    set prompt to f"{prompt}You have assisted in {c.kills_assisted} kills. "
    if string_length(mem_ctx) > 2:
        set prompt to f"{prompt}Recent conversation:{mem_ctx} "
    if string_length(journal_ctx) > 2:
        set prompt to f"{prompt}Key memories from your journey:{journal_ctx} "
    set prompt to f"{prompt}Event: {event}. "
    set prompt to concat(prompt and "Respond in character in 1-2 short sentences. Do NOT mention being AI. Reference shared memories when relevant.")
    return prompt

define companion_speak with c as Companion and event as Str and llm_on as Int and memory as List and journal_ctx as Str returning Str:
    if llm_on == 0:
        return companion_fallback(c.name and c.stage and c.personality and event)
    if c.stage == 0:
        return companion_fallback(c.name and c.stage and c.personality and event)
    set raw_prompt to try build_companion_prompt(c and event and memory and journal_ctx)
    if raw_prompt == 0:
        return companion_fallback(c.name and c.stage and c.personality and event)
    set prompt to ep_auto_to_string(raw_prompt)
    set response to ask_llm(prompt)
    if string_length(response) < 3:
        return companion_fallback(c.name and c.stage and c.personality and event)
    return f"  {c.name}: \"{response}\""

define companion_fallback with cname as Str and stage as Int and personality as Str and event as Str returning Str:
    if stage == 0:
        set roll to ep_random_int(1 and 5)
        if roll == 1:
            return f"  *{cname} glows softly with warmth*"
        else if roll == 2:
            return f"  *{cname} pulses gently in rhythm with your heartbeat*"
        else if roll == 3:
            return f"  *{cname} vibrates happily*"
        else if roll == 4:
            return f"  *{cname} radiates a soothing light*"
        return f"  *{cname} hums with quiet energy*"

    # Personality-flavored responses
    if string_contains(event and "battle_won"):
        if personality == "brave":
            return f"  {cname}: \"Ha! They didn't stand a chance!\""
        else if personality == "shy":
            return f"  {cname}: \"I-I'm glad you're safe...\""
        else if personality == "playful":
            return f"  {cname}: \"That was fun! Again, again!\""
        else if personality == "wise":
            return f"  {cname}: \"Victory favors the prepared.\""
        else if personality == "fierce":
            return f"  {cname}: \"*growls triumphantly*\""
        return f"  {cname}: \"Well fought, friend.\""

    if string_contains(event and "battle_lost"):
        if personality == "brave":
            return f"  {cname}: \"We'll come back stronger!\""
        else if personality == "shy":
            return f"  *{cname} nuzzles you gently*"
        return f"  {cname}: \"Don't give up...\""

    if string_contains(event and "feed"):
        return f"  {cname}: \"Mmm, delicious! Thank you!\""
    if string_contains(event and "play"):
        return f"  *{cname} does a happy spin!*"
    if string_contains(event and "explore"):
        set roll to ep_random_int(1 and 4)
        if roll == 1:
            return f"  {cname}: \"What's that over there?\""
        else if roll == 2:
            return f"  {cname}: \"I sense something ahead...\""
        else if roll == 3:
            return f"  {cname}: \"Stay close to me!\""
        return f"  {cname}: \"Onward!\""
    if string_contains(event and "shop"):
        return f"  {cname}: \"Ooh, can we buy something shiny?\""
    if string_contains(event and "quest"):
        return f"  {cname}: \"An adventure within an adventure!\""
    if string_contains(event and "rest"):
        return f"  *{cname} curls up beside you contentedly*"
    if string_contains(event and "shrine"):
        return f"  *{cname} bows reverently before the shrine*"
    if string_contains(event and "craft"):
        return f"  {cname}: \"Ooh, what are we making?\""
    return f"  *{cname} looks at you fondly*"

# ───────────── 8. Species Configuration & Evolution ─────────────

define get_species_list returning List:
    return ["Drake", "Kitsune", "Griffin", "Phantom", "Wyrm", "Golem"]

define get_species_desc with species as Str returning Str:
    if species == "Drake":
        return "🐉 Drake — Fire-breathing dragon. High damage, balanced defense."
    else if species == "Kitsune":
        return "🦊 Kitsune — Mystical fox spirit. Tricky abilities, life drain."
    else if species == "Griffin":
        return "🦅 Griffin — Noble sky hunter. Fast strikes, wind shields."
    else if species == "Phantom":
        return "👻 Phantom — Ethereal ghost. Evasion, curse abilities."
    else if species == "Wyrm":
        return "🐍 Wyrm — Ancient serpent. Poison, constrict, regeneration."
    else if species == "Golem":
        return "🪨 Golem — Living stone. Massive defense, earthquake attacks."
    return "Unknown species"

define get_species_personality with species as Str returning Str:
    if species == "Drake":
        return "brave"
    else if species == "Kitsune":
        return "playful"
    else if species == "Griffin":
        return "fierce"
    else if species == "Phantom":
        return "wise"
    else if species == "Wyrm":
        return "shy"
    else if species == "Golem":
        return "gentle"
    return "playful"

define get_species_abilities with species as Str and stage as Int returning List:
    set abilities to create_list()
    if stage == 0:
        set ok to append_list(abilities and "none")
        set ok to append_list(abilities and "none")
        set ok to append_list(abilities and "none")
        return abilities

    if species == "Drake":
        if stage == 1:
            return ["Ember Spark", "Warm Shield", "none"]
        else if stage == 2:
            return ["Flame Breath", "Iron Guard", "Quick Strike"]
        else if stage == 3:
            return ["Dragon Fire", "Titan Shield", "Frenzy"]
        return ["Ancient Blaze", "Eternal Guard", "Inferno"]

    else if species == "Kitsune":
        if stage == 1:
            return ["Spirit Wisp", "Illusion", "none"]
        else if stage == 2:
            return ["Fox Fire", "Mirror Image", "Soul Drain"]
        else if stage == 3:
            return ["Nine Tails", "Phantom Veil", "Life Steal"]
        return ["Celestial Fire", "Void Shift", "Soul Rend"]

    else if species == "Griffin":
        if stage == 1:
            return ["Gust Slash", "Wind Shield", "none"]
        else if stage == 2:
            return ["Dive Bomb", "Gale Wall", "Talon Rend"]
        else if stage == 3:
            return ["Storm Strike", "Sky Fortress", "Sonic Boom"]
        return ["Tempest", "Divine Aegis", "Thunder God"]

    else if species == "Phantom":
        if stage == 1:
            return ["Shadow Bolt", "Phase Shift", "none"]
        else if stage == 2:
            return ["Curse Mark", "Ghost Veil", "Drain Touch"]
        else if stage == 3:
            return ["Nightmare", "Void Walk", "Death Mark"]
        return ["Soul Storm", "Eternity Shroud", "Reaper's Call"]

    else if species == "Wyrm":
        if stage == 1:
            return ["Venom Spit", "Coil Guard", "none"]
        else if stage == 2:
            return ["Poison Fang", "Shed Skin", "Constrict"]
        else if stage == 3:
            return ["Venom Storm", "Regenerate", "Crush"]
        return ["Blight Wave", "Immortal Coil", "World Serpent"]

    else if species == "Golem":
        if stage == 1:
            return ["Rock Throw", "Stone Skin", "none"]
        else if stage == 2:
            return ["Boulder Slam", "Fortress", "Ground Pound"]
        else if stage == 3:
            return ["Earthquake", "Mountain Wall", "Meteor Fist"]
        return ["Tectonic Fury", "Adamantine Shell", "Continental Crush"]

    # Default fallback
    set ok to append_list(abilities and "Strike")
    set ok to append_list(abilities and "Guard")
    set ok to append_list(abilities and "none")
    return abilities

define check_evolution with c as Companion returning Companion:
    set emoji to get_species_emoji(c.species)
    if c.stage == 0 && c.bond >= 5:
        set ok to sfx_evolve()
        display ""
        display f"  ✨════════════════════════════════════════✨"
        display f"    {c.name}'s egg is cracking!"
        display f"    {emoji} {c.name} has HATCHED into a tiny {c.species}!"
        display f"  ✨════════════════════════════════════════✨"
        set ok to show_companion_art(c.species and 1 and c.name)
        set c.stage to 1
        set c.max_health to 25
        set c.health to 25
        set c.attack to 5
        set abilities to get_species_abilities(c.species and 1)
        set c.ability1 to get_list(abilities and 0)
        set c.ability2 to get_list(abilities and 1)
        set c.ability3 to "none"
        set c.personality to get_species_personality(c.species)
        return c

    if c.stage == 1 && c.level >= 5:
        set ok to sfx_evolve()
        display ""
        display f"  ✨════════════════════════════════════════✨"
        display f"    {emoji} {c.name} is glowing brightly!"
        display f"    {c.name} evolved into a JUVENILE {c.species}!"
        display f"  ✨════════════════════════════════════════✨"
        set ok to show_companion_art(c.species and 2 and c.name)
        set c.stage to 2
        set c.max_health to 42
        set c.health to 42
        set c.attack to 10
        set abilities to get_species_abilities(c.species and 2)
        set c.ability1 to get_list(abilities and 0)
        set c.ability2 to get_list(abilities and 1)
        set c.ability3 to get_list(abilities and 2)
        return c

    if c.stage == 2 && c.level >= 15:
        set ok to sfx_evolve()
        display ""
        display f"  ✨════════════════════════════════════════✨"
        display f"    {emoji} {c.name} roars with power!"
        display f"    {c.name} evolved into an ADULT {c.species}!"
        display f"  ✨════════════════════════════════════════✨"
        set ok to show_companion_art(c.species and 3 and c.name)
        set c.stage to 3
        set c.max_health to 70
        set c.health to 70
        set c.attack to 18
        set abilities to get_species_abilities(c.species and 3)
        set c.ability1 to get_list(abilities and 0)
        set c.ability2 to get_list(abilities and 1)
        set c.ability3 to get_list(abilities and 2)
        return c

    if c.stage == 3 && c.level >= 30:
        set ok to sfx_evolve()
        display ""
        display f"  ✨════════════════════════════════════════✨"
        display f"    {emoji} {c.name} ascends to legendary power!"
        display f"    {c.name} has become an ELDER {c.species}!"
        display f"  ✨════════════════════════════════════════✨"
        set ok to show_companion_art(c.species and 4 and c.name)
        set c.stage to 4
        set c.max_health to 100
        set c.health to 100
        set c.attack to 28
        set abilities to get_species_abilities(c.species and 4)
        set c.ability1 to get_list(abilities and 0)
        set c.ability2 to get_list(abilities and 1)
        set c.ability3 to get_list(abilities and 2)
        return c

    if c.stage == 4 && c.level >= 50:
        set ok to sfx_prestige()
        display ""
        display f"  🌟════════════════════════════════════════🌟"
        display f"    {emoji} {c.name} TRANSCENDS mortal form!"
        display f"    {c.name} has become a MYTHIC {c.species}!"
        display f"  🌟════════════════════════════════════════🌟"
        set ok to show_companion_art(c.species and 5 and c.name)
        set c.stage to 5
        set c.max_health to 140
        set c.health to 140
        set c.attack to 40
        set abilities to get_species_abilities(c.species and 5)
        set c.ability1 to get_list(abilities and 0)
        set c.ability2 to get_list(abilities and 1)
        set c.ability3 to get_list(abilities and 2)
        return c

    return c

define gain_companion_xp with c as Companion and amount as Int returning Companion:
    set c.xp to c.xp + amount
    set xp_needed to (c.level + 1) * 8
    if c.xp >= xp_needed:
        set c.level to c.level + 1
        set c.xp to c.xp - xp_needed
        set c.attack to c.attack + 1
        set c.max_health to c.max_health + 3
        set emoji to get_species_emoji(c.species)
        display f"  {emoji} {c.name} reached level {c.level}!"
    set c to check_evolution(c)
    return c

# ───────────── 9. Companion Abilities in Combat ─────────────

define use_companion_ability with c as Companion and ability_num as Int and m as Monster and p as Player returning List:
    # Returns list of strings: [damage, heal, self_dmg, shield_turns]
    set result to create_list()
    set ability to c.ability1
    if ability_num == 2:
        set ability to c.ability2
    else if ability_num == 3:
        set ability to c.ability3

    if ability == "none":
        display f"  {c.name} doesn't know that ability!"
        return ["0", "0", "0", "0"]

    set dmg to 0
    set heal to 0
    set self_dmg to 0
    set shield to 0
    set emoji to get_species_emoji(c.species)

    # ── Damage abilities ──
    if ability == "Ember Spark" || ability == "Spirit Wisp" || ability == "Gust Slash" || ability == "Shadow Bolt" || ability == "Venom Spit" || ability == "Rock Throw":
        set dmg to c.attack
        display f"  {emoji} {c.name} uses {ability} for {dmg} damage!"

    else if ability == "Flame Breath" || ability == "Fox Fire" || ability == "Dive Bomb" || ability == "Curse Mark" || ability == "Poison Fang" || ability == "Boulder Slam":
        set dmg to c.attack * 2
        display f"  {emoji} {c.name} unleashes {ability} for {dmg} damage!"

    else if ability == "Dragon Fire" || ability == "Nine Tails" || ability == "Storm Strike" || ability == "Nightmare" || ability == "Venom Storm" || ability == "Earthquake":
        set dmg to c.attack * 3
        display f"  {emoji} {c.name} channels {ability} for {dmg} damage!"

    else if ability == "Ancient Blaze" || ability == "Celestial Fire" || ability == "Tempest" || ability == "Soul Storm" || ability == "Blight Wave" || ability == "Tectonic Fury":
        set dmg to c.attack * 4
        display f"  {emoji} {c.name} summons {ability} for {dmg} massive damage!"

    else if ability == "Quick Strike" || ability == "Talon Rend" || ability == "Sonic Boom":
        set dmg to c.attack + 6
        display f"  {emoji} {c.name} strikes fast with {ability} for {dmg} damage!"

    else if ability == "Constrict" || ability == "Crush" || ability == "Ground Pound":
        set dmg to c.attack * 2 + 4
        display f"  {emoji} {c.name} uses {ability} for {dmg} crushing damage!"

    else if ability == "Frenzy":
        set dmg to c.attack * 5 / 2
        set self_dmg to 3
        display f"  {emoji} {c.name} goes into FRENZY! {dmg} total damage! (takes {self_dmg} recoil)"

    else if ability == "Inferno":
        set dmg to c.attack * 5
        set self_dmg to 5
        display f"  {emoji} {c.name} erupts in INFERNO for {dmg} damage! (takes {self_dmg} recoil)"

    else if ability == "Meteor Fist" || ability == "Continental Crush":
        set dmg to c.attack * 5
        set self_dmg to 4
        display f"  {emoji} {c.name} slams down with {ability}! {dmg} damage! (takes {self_dmg} recoil)"

    else if ability == "Thunder God" || ability == "Reaper's Call" || ability == "World Serpent":
        set dmg to c.attack * 5
        display f"  {emoji} {c.name} invokes {ability} for {dmg} DEVASTATING damage!"

    # ── Shield abilities ──
    else if ability == "Warm Shield" || ability == "Wind Shield" || ability == "Phase Shift" || ability == "Coil Guard" || ability == "Stone Skin":
        set shield to 2
        set heal to 5
        display f"  {emoji} {c.name} raises {ability}! (+{heal} HP, shield {shield} turns)"

    else if ability == "Illusion" || ability == "Ghost Veil":
        set shield to 2
        display f"  {emoji} {c.name} creates {ability}! (shield {shield} turns)"

    else if ability == "Iron Guard" || ability == "Gale Wall" || ability == "Fortress":
        set shield to 3
        display f"  {emoji} {c.name} deploys {ability}! (shield {shield} turns)"

    else if ability == "Mirror Image":
        set shield to 3
        set heal to 8
        display f"  {emoji} {c.name} creates mirror images! (+{heal} HP, shield {shield} turns)"

    else if ability == "Titan Shield" || ability == "Sky Fortress" || ability == "Mountain Wall":
        set shield to 4
        display f"  {emoji} {c.name} raises {ability}! (shield {shield} turns)"

    else if ability == "Phantom Veil" || ability == "Void Walk":
        set shield to 4
        set heal to 12
        display f"  {emoji} {c.name} wraps you in {ability}! (+{heal} HP, shield {shield} turns)"

    else if ability == "Eternal Guard" || ability == "Divine Aegis" || ability == "Adamantine Shell" || ability == "Eternity Shroud" || ability == "Immortal Coil":
        set shield to 5
        set heal to 20
        display f"  {emoji} {c.name} invokes {ability}! (+{heal} HP, shield {shield} turns)"

    else if ability == "Void Shift":
        set shield to 5
        display f"  {emoji} {c.name} shifts you into the void! (shield {shield} turns)"

    # ── Drain abilities ──
    else if ability == "Soul Drain" || ability == "Drain Touch":
        set dmg to c.attack
        set heal to dmg / 2
        display f"  {emoji} {c.name} drains life! {dmg} damage, heals {heal}!"

    else if ability == "Life Steal" || ability == "Death Mark" || ability == "Soul Rend":
        set dmg to c.attack * 3
        set heal to dmg / 3
        display f"  {emoji} {c.name} uses {ability}! {dmg} damage, heals {heal}!"

    # ── Healing abilities ──
    else if ability == "Shed Skin" || ability == "Regenerate":
        set heal to c.attack * 2
        display f"  {emoji} {c.name} regenerates! Heals {heal} HP!"

    else:
        set dmg to c.attack
        display f"  {emoji} {c.name} attacks for {dmg} damage!"

    set ok to append_list(result and int_to_string(dmg))
    set ok to append_list(result and int_to_string(heal))
    set ok to append_list(result and int_to_string(self_dmg))
    set ok to append_list(result and int_to_string(shield))
    return result

# ───────────── 10. Inventory & Equipment System ─────────────

define create_inventory returning Map:
    set inv to create_map()
    set ok to map_insert(inv and "Healing Potion" and 3)
    set ok to map_insert(inv and "Antidote" and 1)
    set ok to map_insert(inv and "Bomb" and 0)
    set ok to map_insert(inv and "Elixir" and 0)
    set ok to map_insert(inv and "Dungeon Key" and 0)
    set ok to map_insert(inv and "Raw Meat" and 2)
    set ok to map_insert(inv and "Herb" and 1)
    set ok to map_insert(inv and "Iron Ore" and 0)
    set ok to map_insert(inv and "Crystal Shard" and 0)
    set ok to map_insert(inv and "Dragon Scale" and 0)
    set ok to map_insert(inv and "Shadow Essence" and 0)
    set ok to map_insert(inv and "Phoenix Feather" and 0)
    return inv

define get_item_count with inv as Map and item_name as Str returning Int:
    if map_contains(inv and item_name):
        return map_get_val(inv and item_name)
    return 0

define add_item with inv as Map and item_name as Str and amount as Int returning Int:
    set current to get_item_count(inv and item_name)
    set ok to map_insert(inv and item_name and current + amount)
    return current + amount

define remove_item with inv as Map and item_name as Str and amount as Int returning Int:
    set current to get_item_count(inv and item_name)
    set new_count to current - amount
    if new_count < 0:
        set new_count to 0
    set ok to map_insert(inv and item_name and new_count)
    return new_count

define show_inventory with inv as Map:
    display ""
    display "  🎒═══════ INVENTORY ═══════"
    set keys to map_keys(inv)
    set has_items to 0
    set i to 0
    repeat while i < length_list(keys):
        set item_name to get_list(keys and i)
        set count to map_get_val(inv and item_name)
        if count > 0:
            display f"    {item_name} ×{count}"
            set has_items to 1
        set i to i + 1
    if has_items == 0:
        display "    (empty)"
    display "  ══════════════════════════"

# ───────────── 11. Crafting System ─────────────

define create_recipes returning Map:
    # Recipe format: "result_name" -> "ingredient1:count1|ingredient2:count2"
    set recipes to create_map()
    set ok to map_insert(recipes and "Healing Potion" and "Herb:2")
    set ok to map_insert(recipes and "Antidote" and "Herb:1|Raw Meat:1")
    set ok to map_insert(recipes and "Elixir" and "Healing Potion:2|Crystal Shard:1")
    set ok to map_insert(recipes and "Bomb" and "Iron Ore:2|Crystal Shard:1")
    set ok to map_insert(recipes and "Companion Feast" and "Raw Meat:3|Herb:1")
    set ok to map_insert(recipes and "Iron Blade" and "Iron Ore:3")
    set ok to map_insert(recipes and "Crystal Edge" and "Iron Ore:2|Crystal Shard:2")
    set ok to map_insert(recipes and "Dragon Fang" and "Dragon Scale:2|Iron Ore:1")
    set ok to map_insert(recipes and "Shadow Cloak" and "Shadow Essence:3")
    set ok to map_insert(recipes and "Phoenix Charm" and "Phoenix Feather:2|Crystal Shard:1")
    return recipes

define show_recipes with recipes as Map and inv as Map:
    display ""
    display "  🔨═══════ CRAFTING ═══════"
    set recipe_names to map_keys(recipes)
    set idx to 1
    set i to 0
    repeat while i < length_list(recipe_names):
        set rname to get_list(recipe_names and i)
        set recipe_str to map_get_val(recipes and rname)
        display f"    {idx}) {rname} — needs: {recipe_str}"
        set idx to idx + 1
        set i to i + 1
    display "    0) Back"
    display "  ═════════════════════════"

define can_craft with inv as Map and recipe_str as Str returning Int:
    # Parse recipe string "item1:count1|item2:count2" and check inventory
    set pos to 0
    set len to string_length(recipe_str)
    repeat while pos < len:
        set pipe to string_index_of(substring(recipe_str and pos and len - pos) and "|")
        set segment to ""
        if pipe < 0:
            set segment to substring(recipe_str and pos and len - pos)
            set pos to len
        else:
            set segment to substring(recipe_str and pos and pipe)
            set pos to pos + pipe + 1
        # Parse "item_name:count"
        set colon to string_index_of(segment and ":")
        if colon > 0:
            set ing_name to substring(segment and 0 and colon)
            set ing_count to string_to_int(substring(segment and colon + 1 and string_length(segment) - colon - 1))
            set have to get_item_count(inv and ing_name)
            if have < ing_count:
                return 0
    return 1

define do_craft with inv as Map and recipe_str as Str and result_name as Str returning Int:
    if can_craft(inv and recipe_str) == 0:
        display "  ❌ Not enough materials!"
        return 0
    # Consume ingredients
    set pos to 0
    set len to string_length(recipe_str)
    repeat while pos < len:
        set pipe to string_index_of(substring(recipe_str and pos and len - pos) and "|")
        set segment to ""
        if pipe < 0:
            set segment to substring(recipe_str and pos and len - pos)
            set pos to len
        else:
            set segment to substring(recipe_str and pos and pipe)
            set pos to pos + pipe + 1
        set colon to string_index_of(segment and ":")
        if colon > 0:
            set ing_name to substring(segment and 0 and colon)
            set ing_count to string_to_int(substring(segment and colon + 1 and string_length(segment) - colon - 1))
            set ok to remove_item(inv and ing_name and ing_count)
    # Add result
    set ok to add_item(inv and result_name and 1)
    display f"  ✅ Crafted: {result_name}!"
    return 1

# ───────────── 12. Status Effect System ─────────────

define create_status_map returning Map:
    set effects to create_map()
    return effects

define apply_status with effects as Map and effect_name as Str and turns as Int and potency as Int:
    # Store as turns * 1000 + potency for simple encoding
    set encoded to turns * 1000 + potency
    set ok to map_insert(effects and effect_name and encoded)

define has_status with effects as Map and effect_name as Str returning Int:
    if map_contains(effects and effect_name):
        set val to map_get_val(effects and effect_name)
        if val > 0:
            return 1
    return 0

define get_status_turns with effects as Map and effect_name as Str returning Int:
    if map_contains(effects and effect_name) == 0:
        return 0
    set val to map_get_val(effects and effect_name)
    return val / 1000

define get_status_potency with effects as Map and effect_name as Str returning Int:
    if map_contains(effects and effect_name) == 0:
        return 0
    set val to map_get_val(effects and effect_name)
    return val % 1000

define tick_status_effects with effects as Map and target_name as Str returning Int:
    # Returns total damage dealt this tick
    set total_dmg to 0
    set effect_names to ["poison", "burn", "freeze", "bless", "shield", "weaken"]
    set i to 0
    repeat while i < length_list(effect_names):
        set ename to get_list(effect_names and i)
        if has_status(effects and ename):
            set turns to get_status_turns(effects and ename)
            set pot to get_status_potency(effects and ename)
            if turns > 0:
                if ename == "poison":
                    display f"  🟢 {target_name} takes {pot} poison damage!"
                    set total_dmg to total_dmg + pot
                else if ename == "burn":
                    display f"  🔥 {target_name} takes {pot} burn damage!"
                    set total_dmg to total_dmg + pot
                else if ename == "freeze":
                    display f"  ❄️ {target_name} is frozen! (skips action)"
                else if ename == "bless":
                    display f"  ✨ {target_name} is blessed! (+{pot} to next attack)"
                else if ename == "weaken":
                    display f"  💔 {target_name} is weakened! (-{pot} attack)"
                # Tick down
                set new_turns to turns - 1
                if new_turns <= 0:
                    set ok to map_insert(effects and ename and 0)
                    display f"  {ename} wore off on {target_name}."
                else:
                    set ok to apply_status(effects and ename and new_turns and pot)
        set i to i + 1
    return total_dmg

# ───────────── 13. Quest System ─────────────

define create_quests returning List:
    # Each quest stored as a map with name, desc, type, target, current, reward
    set quests to create_list()

    set q1 to create_map()
    set ok to map_insert(q1 and "name" and "Monster Hunter")
    set ok to map_insert(q1 and "target" and 10)
    set ok to map_insert(q1 and "current" and 0)
    set ok to map_insert(q1 and "reward" and 50)
    set ok to map_insert(q1 and "done" and 0)
    set ok to append_list(quests and q1)

    set q2 to create_map()
    set ok to map_insert(q2 and "name" and "Deep Explorer")
    set ok to map_insert(q2 and "target" and 10)
    set ok to map_insert(q2 and "current" and 0)
    set ok to map_insert(q2 and "reward" and 75)
    set ok to map_insert(q2 and "done" and 0)
    set ok to append_list(quests and q2)

    set q3 to create_map()
    set ok to map_insert(q3 and "name" and "Bond of Trust")
    set ok to map_insert(q3 and "target" and 50)
    set ok to map_insert(q3 and "current" and 0)
    set ok to map_insert(q3 and "reward" and 100)
    set ok to map_insert(q3 and "done" and 0)
    set ok to append_list(quests and q3)

    set q4 to create_map()
    set ok to map_insert(q4 and "name" and "Boss Slayer")
    set ok to map_insert(q4 and "target" and 3)
    set ok to map_insert(q4 and "current" and 0)
    set ok to map_insert(q4 and "reward" and 150)
    set ok to map_insert(q4 and "done" and 0)
