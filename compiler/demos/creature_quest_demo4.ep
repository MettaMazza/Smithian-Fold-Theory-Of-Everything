        max_health is base_hp + 35
        attack is base_atk + 4
        defense is base_def + 4
        speed is base_spd + 1
        xp_reward is 55 + floor * 5
        gold_reward is 45 + floor * 3
        is_boss is 1
        element is "physical"
        special_attack is "Thunder Apocalypse"
        loot_tier is tier

# ───────────── 16. World / Biome Generation ─────────────

define get_biome with floor as Int returning Str:
    set zone to floor % 8
    if zone == 0:
        return "Crystal Caverns"
    else if zone == 1:
        return "Enchanted Meadow"
    else if zone == 2:
        return "Mushroom Forest"
    else if zone == 3:
        return "Lava Depths"
    else if zone == 4:
        return "Frozen Halls"
    else if zone == 5:
        return "Shadow Ruins"
    else if zone == 6:
        return "Sky Gardens"
    return "Abyssal Depths"

define get_biome_emoji with biome as Str returning Str:
    if biome == "Crystal Caverns":
        return "💎"
    else if biome == "Enchanted Meadow":
        return "🌿"
    else if biome == "Mushroom Forest":
        return "🍄"
    else if biome == "Lava Depths":
        return "🌋"
    else if biome == "Frozen Halls":
        return "❄️"
    else if biome == "Shadow Ruins":
        return "🌑"
    else if biome == "Sky Gardens":
        return "☁️"
    else if biome == "Abyssal Depths":
        return "🌊"
    return "🏔️"

define get_room_desc with floor as Int and turn as Int returning Str:
    set roll to (floor * 7 + turn * 13) % 10
    if roll == 0:
        return "Bones crunch underfoot. Something was here before you."
    else if roll == 1:
        return "Strange runes glow faintly on the walls."
    else if roll == 2:
        return "A cold draft whispers through the corridor."
    else if roll == 3:
        return "The air hums with ancient magical energy."
    else if roll == 4:
        return "Crystalline formations catch the torchlight."
    else if roll == 5:
        return "A distant rumbling echoes from deep below."
    else if roll == 6:
        return "The shadows seem to dance just beyond the light."
    else if roll == 7:
        return "A faint melody drifts from an unknown source."
    else if roll == 8:
        return "Scattered coins glint in the dim light."
    return "The passage widens into a vast echoing chamber."

# ───────────── 17. Loot Drop System ─────────────

define get_loot_drop with tier as Int and inv as Map:
    set roll to ep_random_int(1 and 100)
    if tier >= 4:
        if roll <= 15:
            set ok to add_item(inv and "Dragon Scale" and 1)
            display "    💎 Dropped: Dragon Scale!"
        else if roll <= 30:
            set ok to add_item(inv and "Phoenix Feather" and 1)
            display "    💎 Dropped: Phoenix Feather!"
        else if roll <= 45:
            set ok to add_item(inv and "Shadow Essence" and 1)
            display "    💎 Dropped: Shadow Essence!"
        else if roll <= 65:
            set ok to add_item(inv and "Crystal Shard" and 1)
            display "    ✨ Dropped: Crystal Shard!"
    else if tier >= 3:
        if roll <= 20:
            set ok to add_item(inv and "Crystal Shard" and 1)
            display "    ✨ Dropped: Crystal Shard!"
        else if roll <= 40:
            set ok to add_item(inv and "Iron Ore" and 1)
            display "    🪨 Dropped: Iron Ore!"
        else if roll <= 55:
            set ok to add_item(inv and "Herb" and 1)
            display "    🌿 Dropped: Herb!"
    else if tier >= 2:
        if roll <= 25:
            set ok to add_item(inv and "Iron Ore" and 1)
            display "    🪨 Dropped: Iron Ore!"
        else if roll <= 45:
            set ok to add_item(inv and "Herb" and 1)
            display "    🌿 Dropped: Herb!"
        else if roll <= 60:
            set ok to add_item(inv and "Raw Meat" and 1)
            display "    🥩 Dropped: Raw Meat!"
    else:
        if roll <= 30:
            set ok to add_item(inv and "Herb" and 1)
            display "    🌿 Dropped: Herb!"
        else if roll <= 50:
            set ok to add_item(inv and "Raw Meat" and 1)
            display "    🥩 Dropped: Raw Meat!"

# ───────────── 18. Element / Special Attack System ─────────────

define get_element_bonus with atk_elem as Str and def_elem as Str returning Int:
    if atk_elem == "fire" && def_elem == "ice":
        return 1
    if atk_elem == "ice" && def_elem == "poison":
        return 1
    if atk_elem == "poison" && def_elem == "physical":
        return 1
    if atk_elem == "physical" && def_elem == "fire":
        return 1
    if atk_elem == def_elem:
        return 0
    if atk_elem == "ice" && def_elem == "fire":
        return -1
    if atk_elem == "poison" && def_elem == "ice":
        return -1
    if atk_elem == "physical" && def_elem == "poison":
        return -1
    if atk_elem == "fire" && def_elem == "physical":
        return -1
    return 0

define monster_special_attack with m as Monster and p as Player and player_effects as Map returning Int:
    set base_dmg to m.attack * 3 / 2
    display f"  ⚡ {m.name} uses {m.special_attack}!"

    if m.special_attack == "Spore Cloud" || m.special_attack == "Pandemic":
        set ok to apply_status(player_effects and "poison" and 3 and m.attack / 2)
        display f"    You are POISONED for 3 turns!"
        return base_dmg / 2

    else if m.special_attack == "Lava Burst" || m.special_attack == "Flame Jet" || m.special_attack == "Dragons Wrath":
        set ok to apply_status(player_effects and "burn" and 2 and m.attack / 3)
        display f"    You are BURNING for 2 turns!"
        return base_dmg

    else if m.special_attack == "Frost Breath" || m.special_attack == "Absolute Zero":
        set ok to apply_status(player_effects and "freeze" and 1 and 0)
        display f"    You are FROZEN! You skip your next action!"
        return base_dmg / 2

    else if m.special_attack == "Cursed Blade" || m.special_attack == "Void Annihilation":
        set ok to apply_status(player_effects and "weaken" and 3 and 3)
        display f"    You are WEAKENED for 3 turns!"
        return base_dmg

    else if m.special_attack == "Divine Judgment":
        display f"    Holy light sears you!"
        return base_dmg * 3 / 2

    else if m.special_attack == "Thunder Apocalypse":
        display f"    Lightning fills the chamber!"
        return base_dmg + m.attack / 2

    return base_dmg

# ───────────── 19. Combat Engine ─────────────

define run_combat with p as Player and c as Companion and m as Monster and inv as Map and quests as List and achievements as Map and memory as List and llm_on as Int returning Int:
    # Returns: 1 = player won, 0 = player died
    display ""
    if m.is_boss == 1:
        set ok to sfx_boss()
        display f"  ══════════════════════════════════════"
        display f"    BOSS BATTLE: {m.name}!"
        display f"    HP: {m.health}  ATK: {m.attack}  DEF: {m.defense}"
        display f"  ══════════════════════════════════════"
        set ok to show_boss_art(m.name)
    else:
        display f"  A wild {m.name} appears!"
        display f"    HP: {m.health}  ATK: {m.attack}  Element: {m.element}"
        set ok to show_monster_art(m.name)

    set player_effects to create_status_map()
    set monster_effects to create_status_map()
    set combat_turn to 0
    set p.defend_active to 0

    repeat while m.health > 0 && p.health > 0:
        set combat_turn to combat_turn + 1
        display ""
        set p_bar to health_bar(p.health and p.max_health and 15)
        set m_bar to health_bar(m.health and m.max_health and 15)
        display f"  -- Turn {combat_turn} --"
        display f"  You:     {p_bar} {p.health}/{p.max_health} HP"
        display f"  {m.name}: {m_bar} {m.health}/{m.max_health} HP"
        if c.stage >= 1:
            set c_bar to health_bar(c.health and c.max_health and 10)
            set cemoji to get_species_emoji(c.species)
            display f"  {cemoji} {c.name}: {c_bar} {c.health}/{c.max_health} HP"

        # Tick status effects
        set player_dot to tick_status_effects(player_effects and p.name)
        set p.health to p.health - player_dot
        if p.health <= 0:
            display f"  You succumbed to status effects!"
            return 0

        set monster_dot to tick_status_effects(monster_effects and m.name)
        set m.health to m.health - monster_dot
        if m.health <= 0:
            display f"  The {m.name} succumbed to status effects!"
            set m.health to 0

        if m.health > 0:
            # Check if player is frozen
            if has_status(player_effects and "freeze"):
                display "  You are frozen and cannot act!"
            else:
                # Player action menu
                display ""
                display "  1) Attack"
                display "  2) Defend"
                display "  3) Use Item"
                if c.stage >= 1:
                    display f"  4) {c.name} Ability"
                display "  5) Flee"

                set input to read_line()
                set pick to string_to_int(input)

                if pick == 1:
                    # Attack
                    set base_dmg to p.attack + p.weapon_damage
                    if p.defend_active == 1:
                        set base_dmg to base_dmg * 3 / 2
                        display "  Counter-attack bonus from defending!"
                        set p.defend_active to 0

                    set elem_bonus to get_element_bonus(p.weapon_element and m.element)
                    if elem_bonus == 1:
                        set base_dmg to base_dmg * 3 / 2
                        display "  Elemental advantage!"
                    else if elem_bonus == -1:
                        set base_dmg to base_dmg * 2 / 3
                        display "  Elemental disadvantage..."

                    if has_status(player_effects and "bless"):
                        set bless_pot to get_status_potency(player_effects and "bless")
                        set base_dmg to base_dmg + bless_pot

                    if has_status(player_effects and "weaken"):
                        set weak_pot to get_status_potency(player_effects and "weaken")
                        set base_dmg to base_dmg - weak_pot
                        if base_dmg < 1:
                            set base_dmg to 1

                    set crit_roll to ep_random_int(1 and 100)
                    set crit_chance to 5 + p.speed * 2
                    if crit_roll <= crit_chance:
                        set base_dmg to base_dmg * 2
                        set ok to sfx_critical()
                        display "  CRITICAL HIT!"

                    set actual_dmg to base_dmg - m.defense
                    if actual_dmg < 1:
                        set actual_dmg to 1
                    set m.health to m.health - actual_dmg
                    set ok to sfx_attack()
                    display f"  You strike the {m.name} for {actual_dmg} damage!"

                else if pick == 2:
                    set p.defend_active to 1
                    set p.shield_turns to p.shield_turns + 1
                    display "  You brace yourself! (Damage halved, next attack 1.5x)"

                else if pick == 3:
                    set potion_count to get_item_count(inv and "Healing Potion")
                    set bomb_count to get_item_count(inv and "Bomb")
                    set antidote_count to get_item_count(inv and "Antidote")
                    set elixir_count to get_item_count(inv and "Elixir")
                    display f"    1) Healing Potion x{potion_count}"
                    display f"    2) Bomb x{bomb_count}"
                    display f"    3) Antidote x{antidote_count}"
                    display f"    4) Elixir x{elixir_count}"
                    set item_pick to string_to_int(read_line())
                    if item_pick == 1 && potion_count > 0:
                        set heal to 30 + p.level * 2
                        set p.health to p.health + heal
                        if p.health > p.max_health:
                            set p.health to p.max_health
                        set ok to remove_item(inv and "Healing Potion" and 1)
                        set ok to sfx_heal()
                        display f"  Healed {heal} HP!"
                    else if item_pick == 2 && bomb_count > 0:
                        set bomb_dmg to 25 + p.level * 3
                        set m.health to m.health - bomb_dmg
                        set ok to remove_item(inv and "Bomb" and 1)
                        display f"  Bomb deals {bomb_dmg} damage!"
                    else if item_pick == 3 && antidote_count > 0:
                        set ok to map_insert(player_effects and "poison" and 0)
                        set ok to map_insert(player_effects and "burn" and 0)
                        set ok to remove_item(inv and "Antidote" and 1)
                        display "  Cured all status effects!"
                    else if item_pick == 4 && elixir_count > 0:
                        set p.health to p.max_health
                        set ok to map_insert(player_effects and "poison" and 0)
                        set ok to map_insert(player_effects and "burn" and 0)
                        set ok to map_insert(player_effects and "freeze" and 0)
                        set ok to remove_item(inv and "Elixir" and 1)
                        display "  Fully restored!"
                    else:
                        display "  You fumble with your bag..."

                else if pick == 4 && c.stage >= 1:
                    display f"    1) {c.ability1}"
                    display f"    2) {c.ability2}"
                    if c.ability3 != "none":
                        display f"    3) {c.ability3}"
                    set ab_pick to string_to_int(read_line())
                    set ab_result to use_companion_ability(c and ab_pick and m and p)
                    set ab_dmg to string_to_int(get_list(ab_result and 0))
                    set ab_heal to string_to_int(get_list(ab_result and 1))
                    set ab_self to string_to_int(get_list(ab_result and 2))
                    set ab_shield to string_to_int(get_list(ab_result and 3))
                    set m.health to m.health - ab_dmg
                    set p.health to p.health + ab_heal
                    if p.health > p.max_health:
                        set p.health to p.max_health
                    set c.health to c.health - ab_self
                    if ab_shield > 0:
                        set p.shield_turns to p.shield_turns + ab_shield
                    set c.kills_assisted to c.kills_assisted + 1

                else if pick == 5:
                    set flee_roll to ep_random_int(1 and 100)
                    set flee_chance to 30 + (p.speed - m.speed) * 5
                    if flee_roll <= flee_chance:
                        set ok to sfx_flee()
                        display "  You escaped!"
                        return 1
                    display "  Could not escape!"

                else:
                    display "  You hesitate..."

            # Monster turn
            if m.health > 0:
                if m.is_boss == 1:
                    set hp_pct to percentage(m.health and m.max_health)
                    if hp_pct <= 25 && m.phase == 1:
                        set m.phase to 2
                        display f"  {m.name} enters a DESPERATE RAGE!"
                        set m.attack to m.attack + m.attack / 3

                set m_roll to ep_random_int(1 and 10)
                set use_special to 0
                if m.is_boss == 1 && m_roll <= 4:
                    set use_special to 1
                else if m_roll <= 2:
                    set use_special to 1

                set m_dmg to 0
                if use_special == 1 && m.special_attack != "none":
                    set m_dmg to monster_special_attack(m and p and player_effects)
                else:
                    set m_dmg to m.attack + ep_random_int(0 and m.attack / 3)
                    display f"  {m.name} attacks you!"

                if p.defend_active == 1 || p.shield_turns > 0:
                    set m_dmg to m_dmg / 2
                    display "  Your shield absorbs some damage!"
                    if p.shield_turns > 0:
                        set p.shield_turns to p.shield_turns - 1

                set m_dmg to m_dmg - p.armor_defense
                if m_dmg < 1:
                    set m_dmg to 1

                set p.health to p.health - m_dmg
                set ok to sfx_hit()
                display f"  You take {m_dmg} damage!"

                if c.stage >= 1 && c.health > 0:
                    set c_auto to c.attack / 2
                    if c_auto < 1:
                        set c_auto to 1
                    set m.health to m.health - c_auto
                    set cemoji to get_species_emoji(c.species)
                    display f"  {cemoji} {c.name} bites for {c_auto} damage!"

                    set c_hit to ep_random_int(1 and 10)
                    if c_hit <= 3:
                        set c_dmg to m.attack / 3
                        if c_dmg < 1:
                            set c_dmg to 1
                        set c.health to c.health - c_dmg
                        display f"  {c.name} takes {c_dmg} damage!"
                        if c.health <= 0:
                            set c.health to 0
                            display f"  {c.name} is knocked out!"

    if p.health <= 0:
        return 0

    # Victory
    display ""
    display f"  You defeated the {m.name}!"
    set p.gold to p.gold + m.gold_reward
    set p.xp to p.xp + m.xp_reward
    set p.lifetime_kills to p.lifetime_kills + 1
    display f"    +{m.gold_reward} gold, +{m.xp_reward} XP"

    if c.stage >= 1:
        set c to gain_companion_xp(c and m.xp_reward)
        set c.bond to c.bond + 1
        if c.bond > 100:
            set c.bond to 100

    set quest_gold to update_quest_progress(quests and 0 and 1)
    set p.gold to p.gold + quest_gold

    if m.is_boss == 1:
        set p.boss_kills to p.boss_kills + 1
        set quest_gold to update_quest_progress(quests and 3 and 1)
        set p.gold to p.gold + quest_gold
        set ok to unlock_achievement(achievements and "Dragon Slayer")

    if p.lifetime_kills == 1:
        set ok to unlock_achievement(achievements and "First Blood")

    set ok to get_loot_drop(m.loot_tier and inv)

    # Level up
    set xp_needed to p.level * 25
    if p.xp >= xp_needed:
        set p.level to p.level + 1
        set p.xp to p.xp - xp_needed
        set p.max_health to p.max_health + 5
        set p.health to p.max_health
        set p.attack to p.attack + 2
        set p.defense to p.defense + 1
        set p.speed to p.speed + 1
        set ok to sfx_levelup()
        display f"  LEVEL UP! You are now level {p.level}!"

    set journal_ctx to journal_get_recent(3)
    set msg to companion_speak(c and "battle_won" and llm_on and memory and journal_ctx)
    display msg

    return 1

# ───────────── 20. Encounter Handlers ─────────────

define encounter_treasure with p as Player and inv as Map:
    set ok to sfx_loot()
    display ""
    display "  You found a treasure chest!"
    set roll to ep_random_int(1 and 100)
    if roll <= 30:
        set gold_found to 15 + p.floor * 3 + ep_random_int(1 and 20)
        set p.gold to p.gold + gold_found
        display f"    Found {gold_found} gold!"
    else if roll <= 50:
        set ok to add_item(inv and "Healing Potion" and 1)
        display "    Found a Healing Potion!"
    else if roll <= 65:
        set ok to add_item(inv and "Crystal Shard" and 1)
        display "    Found a Crystal Shard!"
    else if roll <= 75:
        set ok to add_item(inv and "Iron Ore" and 1)
        display "    Found Iron Ore!"
    else if roll <= 85:
        set ok to add_item(inv and "Bomb" and 1)
        display "    Found a Bomb!"
    else if roll <= 92:
        set ok to add_item(inv and "Dungeon Key" and 1)
        display "    Found a Dungeon Key!"
    else:
        set ok to add_item(inv and "Elixir" and 1)
        display "    Found a rare Elixir!"

define encounter_rest with p as Player and c as Companion:
    display ""
    display "  You find a peaceful rest site."
    set heal to p.max_health / 4
    set p.health to p.health + heal
    if p.health > p.max_health:
        set p.health to p.max_health
    display f"    Recovered {heal} HP."
    if c.stage >= 1:
        set c.health to c.max_health
        display f"    {c.name} rests and fully recovers."
    set c.happiness to c.happiness + 5
    if c.happiness > 100:
        set c.happiness to 100

define encounter_trap with p as Player:
    display ""
    set roll to ep_random_int(1 and 4)
    if roll == 1:
        set dmg to 5 + p.floor * 2
        set p.health to p.health - dmg
        set ok to sfx_trap()
        display f"  You triggered a spike trap! Took {dmg} damage!"
    else if roll == 2:
        set dmg to 3 + p.floor
        set p.health to p.health - dmg
        display f"  Poison darts! Took {dmg} damage!"
    else if roll == 3:
        set gold_lost to p.gold / 10
        set p.gold to p.gold - gold_lost
        display f"  A thief steals {gold_lost} gold!"
    else:
        display "  A boulder nearly crushes you! You dodge just in time."
    if p.health <= 0:
        set p.health to 1
        display "    You barely survive..."

define encounter_npc with p as Player and c as Companion and inv as Map:
    display ""
    set roll to ep_random_int(1 and 5)
    if roll == 1:
        display "  A wandering merchant offers supplies."
        display "    1) Buy Healing Potion (15g)"
        display "    2) Buy Bomb (25g)"
        display "    3) Decline"
        set pick to string_to_int(read_line())
        if pick == 1 && p.gold >= 15:
            set p.gold to p.gold - 15
            set ok to add_item(inv and "Healing Potion" and 1)
            display "    Purchased Healing Potion!"
        else if pick == 2 && p.gold >= 25:
            set p.gold to p.gold - 25
            set ok to add_item(inv and "Bomb" and 1)
            display "    Purchased Bomb!"
        else:
            display "    You wave goodbye."
    else if roll == 2:
        display "  A wise hermit blesses you."
        set p.max_health to p.max_health + 5
        set p.health to p.health + 5
        display "    +5 max HP!"
    else if roll == 3:
        display "  An elf sharpens your weapon."
        set p.weapon_damage to p.weapon_damage + 1
        display f"    {p.weapon_name} improved! +1 damage"
    else if roll == 4:
        set gold_gift to 10 + p.floor * 2
        set p.gold to p.gold + gold_gift
        display f"  A grateful princess rewards you with {gold_gift} gold!"
    else:
        display "  A mysterious cat follows you, then vanishes."
        set c.happiness to c.happiness + 10
        if c.happiness > 100:
            set c.happiness to 100

define encounter_shrine with p as Player and c as Companion:
    set ok to sfx_shrine()
    display ""
    display "  You discover an ancient shrine."
    display "    1) Pray (random blessing)"
    display "    2) Offer gold (stat boost)"
    display "    3) Leave"
    set pick to string_to_int(read_line())
    if pick == 1:
        set roll to ep_random_int(1 and 4)
        if roll == 1:
            set p.attack to p.attack + 2
            display "    Attack +2!"
        else if roll == 2:
            set p.defense to p.defense + 2
            display "    Defense +2!"
        else if roll == 3:
            set p.speed to p.speed + 2
            display "    Speed +2!"
        else:
            set p.health to p.max_health
            display "    Fully restored!"
    else if pick == 2:
        set cost to 20 + p.floor * 2
        if p.gold >= cost:
            set p.gold to p.gold - cost
            set p.max_health to p.max_health + 10
            set p.health to p.health + 10
            set p.attack to p.attack + 1
            set p.defense to p.defense + 1
            display f"    Offering of {cost}g accepted! +10 HP, +1 ATK, +1 DEF"
        else:
            display "    Not enough gold."
    else:
        display "    You leave the shrine."

define encounter_mystery with p as Player and c as Companion:
    display ""
    set roll to ep_random_int(1 and 5)
    if roll == 1:
        display "  A time warp! You feel stronger."
        set p.xp to p.xp + 15 + p.floor * 2
        display "    Gained bonus XP!"
    else if roll == 2:
        display "  A falling star lands nearby!"
        set c.bond to c.bond + 5
        if c.bond > 100:
            set c.bond to 100
        display f"    Bond with {c.name} deepens!"
    else if roll == 3:
        display "  You find a gambling den!"
        display "    Bet 10 gold? (1=yes, 2=no)"
        set pick to string_to_int(read_line())
        if pick == 1 && p.gold >= 10:
            set p.gold to p.gold - 10
            set win to ep_random_int(1 and 3)
            if win <= 1:
                set p.gold to p.gold + 30
                display "    You won 30 gold!"
            else:
                display "    You lost your bet..."
        else:
            display "    You walk away."
    else if roll == 4:
        display "  A wizard offers an enchantment."
        display "    1) +3 ATK  2) +3 DEF  3) +5 SPD"
        set pick to string_to_int(read_line())
        if pick == 1:
            set p.attack to p.attack + 3
            display "    Attack +3!"
        else if pick == 2:
            set p.defense to p.defense + 3
            display "    Defense +3!"
        else:
            set p.speed to p.speed + 5
            display "    Speed +5!"
    else:
        display "  A rainbow bridge appears! You feel blessed."
        set p.health to p.max_health
        set c.health to c.max_health
        display "    Everyone is fully healed!"

# ───────────── 21. Shop System ─────────────

define run_shop with p as Player and c as Companion and inv as Map:
    set ok to sfx_shop()
    display ""
    display "  ======== SHOP ========"
    set shopping to 1
    repeat while shopping == 1:
        display ""
        display f"  Gold: {p.gold}"
        display "  --- BUY ---"
        display "  1) Healing Potion   - 15g"
        display "  2) Antidote         - 10g"
        display "  3) Bomb             - 25g"
        display "  4) Elixir           - 60g"
        display "  5) Raw Meat         - 8g"
        display "  6) Herb             - 5g"
        display "  --- WEAPONS ---"
        display "  7) Iron Sword       - 50g  (+5 dmg)"
        display "  8) Fire Blade       - 80g  (+7 dmg, fire)"
        display "  9) Frost Edge       - 80g  (+7 dmg, ice)"
        display "  --- ARMOR ---"
        display "  10) Chain Mail      - 45g  (+4 def)"
        display "  11) Plate Armor     - 90g  (+7 def)"
        display "  --- OTHER ---"
        display "  12) Feed companion  (Raw Meat)"
        display "  13) Play with companion"
        display "  0) Leave shop"

        set pick to string_to_int(read_line())
        if pick == 0:
            set shopping to 0
        else if pick == 1 && p.gold >= 15:
            set p.gold to p.gold - 15
            set ok to add_item(inv and "Healing Potion" and 1)
            display "  Purchased Healing Potion!"
        else if pick == 2 && p.gold >= 10:
            set p.gold to p.gold - 10
            set ok to add_item(inv and "Antidote" and 1)
            display "  Purchased Antidote!"
        else if pick == 3 && p.gold >= 25:
            set p.gold to p.gold - 25
            set ok to add_item(inv and "Bomb" and 1)
            display "  Purchased Bomb!"
        else if pick == 4 && p.gold >= 60:
            set p.gold to p.gold - 60
            set ok to add_item(inv and "Elixir" and 1)
            display "  Purchased Elixir!"
        else if pick == 5 && p.gold >= 8:
            set p.gold to p.gold - 8
            set ok to add_item(inv and "Raw Meat" and 1)
            display "  Purchased Raw Meat!"
        else if pick == 6 && p.gold >= 5:
            set p.gold to p.gold - 5
            set ok to add_item(inv and "Herb" and 1)
            display "  Purchased Herb!"
        else if pick == 7 && p.gold >= 50:
            set p.gold to p.gold - 50
            set p.weapon_name to "Iron Sword"
            set p.weapon_damage to 5
            set p.weapon_element to "physical"
            display "  Equipped Iron Sword!"
        else if pick == 8 && p.gold >= 80:
            set p.gold to p.gold - 80
            set p.weapon_name to "Fire Blade"
            set p.weapon_damage to 7
            set p.weapon_element to "fire"
            display "  Equipped Fire Blade!"
        else if pick == 9 && p.gold >= 80:
            set p.gold to p.gold - 80
            set p.weapon_name to "Frost Edge"
            set p.weapon_damage to 7
            set p.weapon_element to "ice"
            display "  Equipped Frost Edge!"
        else if pick == 10 && p.gold >= 45:
            set p.gold to p.gold - 45
            set p.armor_name to "Chain Mail"
            set p.armor_defense to 4
            display "  Equipped Chain Mail!"
        else if pick == 11 && p.gold >= 90:
            set p.gold to p.gold - 90
            set p.armor_name to "Plate Armor"
            set p.armor_defense to 7
            display "  Equipped Plate Armor!"
        else if pick == 12:
            set meat_count to get_item_count(inv and "Raw Meat")
            if meat_count > 0:
                set ok to remove_item(inv and "Raw Meat" and 1)
                set c.hunger to c.hunger + 20
                if c.hunger > 100:
                    set c.hunger to 100
                set c.happiness to c.happiness + 5
                set c.bond to c.bond + 2
                if c.bond > 100:
                    set c.bond to 100
                set cemoji to get_species_emoji(c.species)
                display f"  {cemoji} {c.name} happily eats the meat!"
                set c to check_evolution(c)
            else:
                display "  No Raw Meat in inventory!"
        else if pick == 13:
            set c.happiness to c.happiness + 10
            if c.happiness > 100:
                set c.happiness to 100
            set c.bond to c.bond + 3
            if c.bond > 100:
                set c.bond to 100
            set cemoji to get_species_emoji(c.species)
            display f"  {cemoji} {c.name} plays with you happily!"
            set c to check_evolution(c)
        else:
            display "  Not enough gold or invalid choice."

    # Companion reacts to shop
    set journal_ctx to journal_get_recent(2)
    set msg to companion_speak(c and "shop" and 0 and memory_create() and journal_ctx)
    display msg

# ───────────── 22. Save / Load System ─────────────

define save_game with p as Player and c as Companion:
    # Encode player + companion state as pipe-separated values
    set data to f"{p.name}|{p.health}|{p.max_health}|{p.attack}|{p.defense}|{p.speed}"
    set data to f"{data}|{p.gold}|{p.floor}|{p.turns_total}|{p.weapon_name}|{p.weapon_damage}"
    set data to f"{data}|{p.weapon_element}|{p.armor_name}|{p.armor_defense}"
    set data to f"{data}|{p.xp}|{p.level}|{p.lifetime_kills}|{p.lifetime_gold}"
    set data to f"{data}|{p.lifetime_floors}|{p.runs_completed}|{p.prestige_level}|{p.boss_kills}"
    set data to f"{data}|{c.name}|{c.species}|{c.health}|{c.max_health}|{c.hunger}"
    set data to f"{data}|{c.happiness}|{c.bond}|{c.xp}|{c.level}|{c.stage}"
    set data to f"{data}|{c.attack}|{c.ability1}|{c.ability2}|{c.ability3}"
    set data to f"{data}|{c.personality}|{c.trust}|{c.kills_assisted}"
    set ok to file_write(get_save_path() and data)
    display "  Game saved!"

define load_game_exists returning Int:
    return file_exists(get_save_path())

# ───────────── 23. Prestige / Ascension System ─────────────

define can_prestige with p as Player returning Int:
    if p.floor >= get_prestige_floor():
        return 1
    return 0

define do_prestige with p as Player and c as Companion and achievements as Map:
    display ""
    set ok to sfx_prestige()
    display "  =================================================="
    display "    PRESTIGE ASCENSION"
    display "    You have conquered 100 floors!"
    display "    Your legend echoes through eternity."
    display "  =================================================="
    display ""
    display f"    Prestige Level: {p.prestige_level} -> {p.prestige_level + 1}"
    display "    Bonuses per prestige:"
    display "      +5 base ATK, +5 base DEF, +3 base SPD"
    display "      +20 base max HP"
    display "      Companion bond preserved"
    display ""
    display "  Begin prestige reset? (1=yes, 2=no)"
    set pick to string_to_int(read_line())
    if pick == 1:
        set p.prestige_level to p.prestige_level + 1
        set p.runs_completed to p.runs_completed + 1
        set p.lifetime_floors to p.lifetime_floors + p.floor

        # Reset with bonuses
        set bonus_atk to p.prestige_level * 5
        set bonus_def to p.prestige_level * 5
        set bonus_spd to p.prestige_level * 3
        set bonus_hp to p.prestige_level * 20

        set p.health to 100 + bonus_hp
        set p.max_health to 100 + bonus_hp
        set p.attack to 8 + bonus_atk
        set p.defense to 5 + bonus_def
        set p.speed to 5 + bonus_spd
        set p.gold to 30
        set p.floor to 1
        set p.xp to 0
        set p.level to 1
        set p.weapon_name to "Rusty Blade"
        set p.weapon_damage to 3
        set p.weapon_element to "physical"
        set p.armor_name to "Worn Leather"
        set p.armor_defense to 2
        set p.shield_turns to 0
        set p.defend_active to 0

        # Companion keeps bond + trust + personality
        set c.health to c.max_health

        set ok to unlock_achievement(achievements and "Prestige I")

        display ""
        display f"  Ascended to Prestige {p.prestige_level}!"
        display f"  Base stats boosted! ATK+{bonus_atk} DEF+{bonus_def} SPD+{bonus_spd} HP+{bonus_hp}"
        display "  Your journey begins anew..."
        set ok to journal_add("PRESTIGE ASCENSION!" and p.floor and p.turns_total)

# ───────────── 24. Display Functions ─────────────

define show_status with p as Player and c as Companion:
    display ""
    set biome to get_biome(p.floor)
    set biome_emoji to get_biome_emoji(biome)
    display f"  ========================================"
    set status_line to concat("  " and p.name)
    set status_line to concat(status_line and " — Level ")
    set status_line to concat(status_line and int_to_string(p.level))
    set status_line to concat(status_line and " | Floor ")
    set status_line to concat(status_line and int_to_string(p.floor))
    set status_line to concat(status_line and " | ")
    set status_line to concat(status_line and biome_emoji)
    set status_line to concat(status_line and " ")
    set status_line to concat(status_line and biome)
    display status_line
    display f"  ========================================"
    set p_bar to health_bar(p.health and p.max_health and 20)
    display f"  HP:   {p_bar} {p.health}/{p.max_health}"
    display f"  ATK: {p.attack} (+{p.weapon_damage} {p.weapon_name})"
    display f"  DEF: {p.defense} (+{p.armor_defense} {p.armor_name})"
    display f"  SPD: {p.speed}  |  Gold: {p.gold}  |  XP: {p.xp}/{p.level * 25}"
    if p.prestige_level > 0:
        display f"  Prestige: {p.prestige_level}"

    if c.stage >= 1:
        set cemoji to get_species_emoji(c.species)
        set stage_name to get_stage_name(c.stage)
        set c_bar to health_bar(c.health and c.max_health and 15)
        display ""
        set c_line to concat("  " and cemoji)
        set c_line to concat(c_line and " ")
        set c_line to concat(c_line and c.name)
        set c_line to concat(c_line and " — ")
        set c_line to concat(c_line and stage_name)
        set c_line to concat(c_line and " ")
        set c_line to concat(c_line and c.species)
        set c_line to concat(c_line and " (Lv.")
        set c_line to concat(c_line and int_to_string(c.level))
        set c_line to concat(c_line and ")")
        display c_line
        display f"  HP:   {c_bar} {c.health}/{c.max_health}"
        display f"  ATK: {c.attack}  Bond: {c.bond}/100  Trust: {c.trust}/100"
        set mood_text to get_mood_text(c.happiness)
        display f"  Mood: {mood_text} | Hunger: {c.hunger}/100"
        if c.ability1 != "none":
            set ab_str to c.ability1
            if c.ability2 != "none":
                set ab_str to f"{ab_str}, {c.ability2}"
            if c.ability3 != "none":
                set ab_str to f"{ab_str}, {c.ability3}"
            display f"  Abilities: {ab_str}"
    else:
        set stage_emoji to get_stage_emoji(c.stage)
        set stage_nm to get_stage_name(c.stage)
        set egg_line to concat("  " and stage_emoji)
        set egg_line to concat(egg_line and " ")
        set egg_line to concat(egg_line and c.name)
        set egg_line to concat(egg_line and " — ")
        set egg_line to concat(egg_line and stage_nm)
        set egg_line to concat(egg_line and " (Bond: ")
        set egg_line to concat(egg_line and int_to_string(c.bond))
        set egg_line to concat(egg_line and "/100)")
        display egg_line
    display f"  ========================================"

define show_title:
    display ""
    display "  ╔══════════════════════════════════════════╗"
    display "  ║                                          ║"
    display "  ║   CREATURE QUEST: INFINITE               ║"
    display "  ║   The Never-Ending Roguelite RPG         ║"
    display "  ║                                          ║"
    display "  ║   Written 100% in ErnosPlain             ║"
    display "  ║   Demo 4 — The Definitive Edition        ║"
    display "  ║                                          ║"
    display "  ╚══════════════════════════════════════════╝"
    display ""
    display "        __/\\_/\\__       /\\_/\\"
    display "       /  o   o  \\     ( ^.^ )"
    display "      | \\  ___  / |     )   ("
    display "       \\  \\/ \\/  /    (_____)"
    display "        \\__/\\__/"

# ───────────── 25. Companion Interaction Menu ─────────────

define companion_menu with p as Player and c as Companion and inv as Map and memory as List and llm_on as Int:
    set pick to 0
    repeat while pick != 5:
        display ""
        set cemoji to get_species_emoji(c.species)
        display f"  {cemoji} ====== {c.name} ======"
        set ok to show_companion_art(c.species and c.stage and c.name)
        display f"  Bond: {c.bond}/100  Trust: {c.trust}/100  Hunger: {c.hunger}/100"
        display ""
        display "  1) Feed (uses Raw Meat)"
        display "  2) Play"
        display "  3) Pet"
        display "  4) Talk"
        display "  5) Back"

        set pick to string_to_int(read_line())
        if pick == 1:
            set meat to get_item_count(inv and "Raw Meat")
            if meat > 0:
                set ok to remove_item(inv and "Raw Meat" and 1)
                set c.hunger to c.hunger + 25
                if c.hunger > 100:
                    set c.hunger to 100
                set c.happiness to c.happiness + 8
                set c.bond to c.bond + 3
                if c.bond > 100:
                    set c.bond to 100
                set journal_ctx to journal_get_recent(2)
                set msg to companion_speak(c and "feed" and llm_on and memory and journal_ctx)
                display msg
                set c to check_evolution(c)
            else:
                display "  No Raw Meat!"
        else if pick == 2:
            set c.happiness to c.happiness + 12
            if c.happiness > 100:
                set c.happiness to 100
            set c.bond to c.bond + 4
            if c.bond > 100:
                set c.bond to 100
            set journal_ctx to journal_get_recent(2)
            set msg to companion_speak(c and "play" and llm_on and memory and journal_ctx)
            display msg
            set c to check_evolution(c)
        else if pick == 3:
            set c.happiness to c.happiness + 5
            set c.bond to c.bond + 2
            if c.bond > 100:
                set c.bond to 100
            if c.happiness > 100:
                set c.happiness to 100
            display f"  *{c.name} leans into your touch*"
            set c to check_evolution(c)
        else if pick == 4:
            if llm_on == 1 && c.stage >= 1:
                display "  What do you want to say?"
                set user_msg to read_line()
                set memory to memory_add(memory and "You" and user_msg)
                set journal_ctx to journal_get_recent(4)
                set response to companion_speak(c and f"player_said: {user_msg}" and llm_on and memory and journal_ctx)
                display response
                # Extract companion reply for memory
                set memory to memory_add(memory and c.name and response)
                set ok to save_memory(memory)
                set c.bond to c.bond + 1
                if c.bond > 100:
                    set c.bond to 100
            else if c.stage == 0:
                display f"  *{c.name} glows warmly but cannot speak yet*"
            else:
                set journal_ctx to journal_get_recent(3)
                set msg to companion_speak(c and "talk" and 0 and memory and journal_ctx)
                display msg
        else if pick != 5:
            display "  Invalid choice."
    # Bond checks happen in the main loop

# ───────────── 26. Game Over & Death Screen ─────────────

define show_game_over with p as Player and c as Companion:
    display ""
    set ok to sfx_death()
    display "  =================================================="
    display "    GAME OVER"
    display "  =================================================="
    display f"  You fell on Floor {p.floor} after {p.turns_total} turns."
    display f"  Level: {p.level}  |  Kills: {p.lifetime_kills}"
    display f"  Gold earned: {p.lifetime_gold}  |  Boss kills: {p.boss_kills}"
    if p.prestige_level > 0:
        display f"  Prestige Level: {p.prestige_level}"
    if c.stage >= 1:
        set cemoji to get_species_emoji(c.species)
        display f"  {cemoji} {c.name} — {get_stage_name(c.stage)} {c.species} (Bond: {c.bond})"
    display "  =================================================="
    display ""
    display "  1) Start new run (keep companion + prestige)"
    display "  2) Quit"

# ═══════════════════════════════════════════════════════════════════════
#  MAIN GAME LOOP
# ═══════════════════════════════════════════════════════════════════════

define main:
    set ok to show_title()

    # ── Check LLM availability ──
    set llm_on to test_ollama_connection()
    if llm_on == 1:
        display "  AI Companion: ONLINE (Ollama detected)"
    else:
        display "  AI Companion: OFFLINE (using built-in personality)"
    display ""

    # ── Load persistent memory ──
    set memory to load_memory()

    # ── Character creation ──
    display "  What is your name, adventurer?"
    set player_name to read_line()
    if string_length(player_name) < 1:
        set player_name to "Hero"

    set p to create Player:
        name is player_name

    # ── Companion selection ──
    display ""
    display "  A mysterious egg appears before you..."
    display "  What species do you sense within?"
    display ""
    set d1 to get_species_desc("Drake")
    set d2 to get_species_desc("Kitsune")
    set d3 to get_species_desc("Griffin")
    set d4 to get_species_desc("Phantom")
    set d5 to get_species_desc("Wyrm")
    set d6 to get_species_desc("Golem")
    display concat("    1) " and d1)
    display concat("    2) " and d2)
    display concat("    3) " and d3)
    display concat("    4) " and d4)
    display concat("    5) " and d5)
    display concat("    6) " and d6)
    display ""
    set sp_pick to string_to_int(read_line())
    if sp_pick < 1 || sp_pick > 6:
        set sp_pick to 1
    set chosen_species to "Drake"
    if sp_pick == 2:
        set chosen_species to "Kitsune"
    else if sp_pick == 3:
        set chosen_species to "Griffin"
    else if sp_pick == 4:
        set chosen_species to "Phantom"
    else if sp_pick == 5:
        set chosen_species to "Wyrm"
    else if sp_pick == 6:
        set chosen_species to "Golem"

    display ""
    display "  Name your companion:"
    set comp_name to read_line()
    if string_length(comp_name) < 1:
        set comp_name to "Luna"

    set c to create Companion:
        name is comp_name
        species is chosen_species

    set cemoji to get_species_emoji(c.species)
    set join_msg to concat("  " and cemoji)
    set join_msg to concat(join_msg and " A glowing ")
    set join_msg to concat(join_msg and chosen_species)
    set join_msg to concat(join_msg and " egg named ")
    set join_msg to concat(join_msg and c.name)
    set join_msg to concat(join_msg and " joins your journey!")
    display join_msg
    display ""

    # ── Initialize systems ──
    set inv to create_inventory()
    set recipes to create_recipes()
    set quests to create_quests()
    set achievements to create_achievements()
    set game_running to 1

    set ok to journal_add(f"Adventure begins! {p.name} sets out with {c.name} the {c.species}." and 1 and 0)

    # ═══ MAIN GAME LOOP ═══
    repeat while game_running == 1:
        set p.turns_total to p.turns_total + 1

        # ── Companion hunger decay ──
        if p.turns_total % 5 == 0:
            set c.hunger to c.hunger - 3
            if c.hunger < 0:
                set c.hunger to 0
            if c.hunger < 20:
                set c.happiness to c.happiness - 5
                if c.happiness < 0:
                    set c.happiness to 0

        # ── Floor achievements ──
        if p.floor >= 25:
            set ok to unlock_achievement(achievements and "Floor 25")
        if p.floor >= 50:
            set ok to unlock_achievement(achievements and "Floor 50")
        if p.floor >= 100:
            set ok to unlock_achievement(achievements and "Floor 100")
        if p.lifetime_gold >= 1000:
            set ok to unlock_achievement(achievements and "Wealthy")
        if p.lifetime_kills >= 100:
            set ok to unlock_achievement(achievements and "Veteran")

        # ── Show status ──
        set ok to show_status(p and c)

        # ── Room description ──
        set biome to get_biome(p.floor)
        set biome_emoji to get_biome_emoji(biome)
        set room_desc to get_room_desc(p.floor and p.turns_total)
        set room_line to concat("  " and biome_emoji)
        set room_line to concat(room_line and " ")
        set room_line to concat(room_line and room_desc)
        display room_line

        # ── Companion ambient comment ──
        if p.turns_total % 3 == 0:
            set journal_ctx to journal_get_recent(2)
            set ambient to companion_speak(c and "explore" and llm_on and memory and journal_ctx)
            display ambient

        # ── Action menu ──
        display ""
        display "  What do you do?"
        display "  1) Explore (enter next room)"
        display "  2) Companion"
        display "  3) Inventory"
        display "  4) Craft"
        display "  5) Quests"
        display "  6) Achievements"
        display "  7) Camp (heal)"
        if can_prestige(p) == 1:
            display "  8) PRESTIGE (reset with bonuses)"
        display "  0) Save & Quit"

        set action to string_to_int(read_line())

        if action == 0:
            set ok to save_game(p and c)
            set ok to save_memory(memory)
            display "  Farewell, adventurer!"
            set game_running to 0

        else if action == 1:
            # ── EXPLORE: Generate encounter ──
            set enc_roll to ep_random_int(1 and 100)
            set did_boss to 0

            # Boss every 5 floors
            if p.floor % 5 == 0 and enc_roll <= 80:
                set boss to create_boss(p.floor)
                set ok to journal_add(f"Boss battle: {boss.name} on floor {p.floor}" and p.floor and p.turns_total)
                set result to run_combat(p and c and boss and inv and quests and achievements and memory and llm_on)
                if result == 0:
                    # Death
                    set ok to show_game_over(p and c)
                    set ok to journal_add("Fell in battle..." and p.floor and p.turns_total)
                    set death_pick to string_to_int(read_line())
                    if death_pick == 1:
                        # Restart run, keep companion and prestige
                        set p.health to p.max_health
                        set p.gold to 30
                        set p.floor to 1
                        set p.xp to 0
                        set p.level to 1
                        set p.weapon_name to "Rusty Blade"
                        set p.weapon_damage to 3
                        set p.weapon_element to "physical"
                        set p.armor_name to "Worn Leather"
                        set p.armor_defense to 2
                        set p.runs_completed to p.runs_completed + 1
                        set c.health to c.max_health
                        set inv to create_inventory()
                        set quests to create_quests()
                        display "  A new journey begins..."
                        set ok to journal_add("Rose again for a new run." and 1 and p.turns_total)
                    else:
                        set game_running to 0
                else:
                    # Boss defeated — advance floor
                    set p.floor to p.floor + 1
                    set ok to update_quest_progress(quests and 1 and 1)
                    set ok to journal_add(f"Defeated boss on floor {p.floor - 1}!" and p.floor and p.turns_total)
                    display f"  You descend to Floor {p.floor}..."
                    set new_biome to get_biome(p.floor)
                    set ok to show_biome_banner(new_biome)
                set did_boss to 1

            # Normal encounters (always triggers on non-boss turns)
            if did_boss == 0:
                # Re-roll for normal encounter distribution
                set enc_roll to ep_random_int(1 and 100)
                if enc_roll <= 60:
                    # Normal combat (60%)
                    set monster to create_monster(p.floor)
                    set result to run_combat(p and c and monster and inv and quests and achievements and memory and llm_on)
                    if result == 0:
                        set ok to show_game_over(p and c)
                        set ok to journal_add("Fell in battle..." and p.floor and p.turns_total)
                        set death_pick to string_to_int(read_line())
                        if death_pick == 1:
                            set p.health to p.max_health
                            set p.gold to 30
                            set p.floor to 1
                            set p.xp to 0
                            set p.level to 1
                            set p.weapon_name to "Rusty Blade"
                            set p.weapon_damage to 3
                            set p.weapon_element to "physical"
                            set p.armor_name to "Worn Leather"
                            set p.armor_defense to 2
                            set p.runs_completed to p.runs_completed + 1
                            set c.health to c.max_health
                            set inv to create_inventory()
                            set quests to create_quests()
                            display "  A new journey begins..."
                            set ok to journal_add("Rose again." and 1 and p.turns_total)
                        else:
                            set game_running to 0
                else if enc_roll <= 72:
                    set ok to encounter_treasure(p and inv)
                else if enc_roll <= 82:
                    set ok to encounter_rest(p and c)
                else if enc_roll <= 88:
                    set ok to encounter_trap(p)
                    if p.health <= 0:
                        set p.health to 1
                else if enc_roll <= 93:
                    set ok to encounter_npc(p and c and inv)
                else if enc_roll <= 97:
                    set ok to encounter_shrine(p and c)
                else:
                    set ok to encounter_mystery(p and c)

            # ── Advance floor periodically ──
            if p.turns_total % 4 == 0 and p.floor % 5 != 0:
                set p.floor to p.floor + 1
                set ok to update_quest_progress(quests and 1 and 1)
                set new_biome to get_biome(p.floor)
                set new_emoji to get_biome_emoji(new_biome)
                display f"  {new_emoji} You descend to Floor {p.floor} — {new_biome}"
                set ok to show_biome_banner(new_biome)

        else if action == 2:
            set ok to companion_menu(p and c and inv and memory and llm_on)

        else if action == 3:
            set ok to show_inventory(inv)

        else if action == 4:
            set ok to show_recipes(recipes and inv)
            display "  Choose recipe number (0 to cancel):"
            set craft_pick to string_to_int(read_line())
            if craft_pick > 0:
                set recipe_names to map_keys(recipes)
                if craft_pick <= length_list(recipe_names):
                    set rname to get_list(recipe_names and craft_pick - 1)
                    set recipe_str to ep_auto_to_string(map_get_val(recipes and rname))
                    set crafted to do_craft(inv and recipe_str and rname)
                    if crafted == 1:
                        set ok to update_quest_progress(quests and 4 and 1)
                        set ok to journal_add(f"Crafted {rname}" and p.floor and p.turns_total)
                        # Apply crafted weapons/armor
                        if rname == "Iron Blade":
                            set p.weapon_name to "Iron Blade"
                            set p.weapon_damage to 6
                            set p.weapon_element to "physical"
                            display "  Equipped Iron Blade!"
                        else if rname == "Crystal Edge":
                            set p.weapon_name to "Crystal Edge"
                            set p.weapon_damage to 9
                            set p.weapon_element to "ice"
                            display "  Equipped Crystal Edge!"
                        else if rname == "Dragon Fang":
                            set p.weapon_name to "Dragon Fang"
                            set p.weapon_damage to 12
                            set p.weapon_element to "fire"
                            display "  Equipped Dragon Fang!"
                        else if rname == "Shadow Cloak":
                            set p.armor_name to "Shadow Cloak"
                            set p.armor_defense to 8
                            display "  Equipped Shadow Cloak!"
                        else if rname == "Phoenix Charm":
                            set p.max_health to p.max_health + 25
                            set p.health to p.health + 25
                            display "  Phoenix Charm: +25 max HP!"
                        else if rname == "Companion Feast":
                            set c.hunger to 100
                            set c.happiness to 100
                            set c.bond to c.bond + 10
                            if c.bond > 100:
                                set c.bond to 100
                            display f"  {c.name} devours the feast!"
                            set c to check_evolution(c)

                    set journal_ctx to journal_get_recent(2)
                    set msg to companion_speak(c and "craft" and llm_on and memory and journal_ctx)
                    display msg

        else if action == 5:
            set ok to show_quests(quests)

        else if action == 6:
            set ok to show_achievements(achievements)

        else if action == 7:
            # Camp
            display ""
            display "  You set up camp..."
            set heal to p.max_health / 3
            set p.health to p.health + heal
            if p.health > p.max_health:
                set p.health to p.max_health
            display f"  Recovered {heal} HP."
            if c.stage >= 1:
                set c.health to c.max_health
                display f"  {c.name} rests and recovers."
            set journal_ctx to journal_get_recent(3)
            set msg to companion_speak(c and "rest" and llm_on and memory and journal_ctx)
            display msg

            # Shop opportunity at camp
            set shop_roll to ep_random_int(1 and 3)
            if shop_roll == 1:
                display "  A merchant approaches your campfire..."
                set ok to run_shop(p and c and inv)

        else if action == 8 && can_prestige(p) == 1:
            set ok to do_prestige(p and c and achievements)
            set inv to create_inventory()
            set quests to create_quests()

        else:
            display "  Invalid choice."

    # ── End of game ──
    set ok to save_memory(memory)
    display ""
    display "  Thank you for playing Creature Quest: Infinite!"
    display f"  Total turns: {p.turns_total}"
    display f"  Achievements: {count_achievements(achievements)}/{map_size(achievements)}"
    display f"  Written 100% in ErnosPlain."
    return 0
