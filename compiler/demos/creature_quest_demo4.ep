# ───────────── 2. String / Math Helpers ─────────────

define repeat_char with ch as Str and count as Int returning Str:
    set result to ""
    set i to 0
    repeat while i < count:
        set result to concat(result and ch)
        set i to i + 1
    return result

define pad_right with text as Str and width as Int returning Str:
    set len to string_length(text)
    if len >= width:
        return text
    set spaces to repeat_char(" " and width - len)
    return concat(text and spaces)

define clamp with val as Int and low as Int and high as Int returning Int:
    if val < low:
        return low
    if val > high:
        return high
    return val

define min_val with a as Int and b as Int returning Int:
    if a < b:
        return a
    return b

define max_val with a as Int and b as Int returning Int:
    if a > b:
        return a
    return b

define abs_val with x as Int returning Int:
    if x < 0:
        return 0 - x
    return x

define health_bar with current as Int and maximum as Int and width as Int returning Str:
    set filled to current * width / maximum
    if filled < 0:
        set filled to 0
    if filled > width:
        set filled to width
    set empty to width - filled
    set bar to repeat_char("█" and filled)
    set bar to concat(bar and repeat_char("░" and empty))
    return f"[{bar}]"

define percentage with current as Int and maximum as Int returning Int:
    if maximum == 0:
        return 0
    return current * 100 / maximum

# ───────────── 3. JSON / HTTP Helpers ─────────────

define escape_json with text as Str returning Str:
    set result to string_replace(text and "\\" and "\\\\")
    set result to string_replace(result and "\"" and "\\\"")
    set result to string_replace(result and "\n" and "\\n")
    return result

define test_ollama_connection returning Int:
    set body to ep_http_request("GET" and "http://localhost:11434/api/version" and "" and "")
    if string_length(body) < 5:
        return 0
    if string_contains(body and "version"):
        return 1
    return 0

define ask_llm with prompt as Str returning Str:
    set escaped to escape_json(prompt)
    set model to get_model_name()
    set url to get_ollama_url()
    set body to concat("{\"model\":\"" and model)
    set body to concat(body and "\",\"prompt\":\"")
    set body to concat(body and escaped)
    set body to concat(body and "\",\"stream\":false}")
    set headers to "Content-Type: application/json\r\n"
    set raw_resp to try ep_http_request("POST" and url and headers and body)
    if raw_resp == 0:
        return ""
    set response to ep_auto_to_string(raw_resp)
    if string_length(response) < 10:
        return ""
    set raw_ans to try json_get_string(response and "response")
    if raw_ans == 0:
        return ""
    set answer to ep_auto_to_string(raw_ans)
    return answer

# ───────────── 4. Enums ─────────────

# Game state machine
define choice GamePhase:
    variant Exploring
    variant InCombat
    variant Camping
    variant Shopping
    variant GameOver

# Combat actions
define choice CombatAction:
    variant AttackAction
    variant DefendAction
    variant UseItemAction with item_id as Int
    variant UseAbilityAction with ability_id as Int
    variant FleeAction

# Encounter types
define choice EncounterKind:
    variant BattleEncounter with tier as Int
    variant TreasureEncounter with loot_tier as Int
    variant RestEncounter
    variant NpcEncounter with npc_id as Int
    variant TrapEncounter with trap_type as Int
    variant MysteryEncounter
    variant ShopEncounter
    variant ShrineEncounter

# Damage elements
define choice Element:
    variant Physical
    variant Fire
    variant Ice
    variant Poison
    variant Holy

# Result type for safe operations
define choice SafeResult:
    variant Success with value as Str
    variant Failure with reason as Str

