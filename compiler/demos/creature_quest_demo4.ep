    # Default / Enchanted Meadow
    if roll <= 2:
        return create Monster:
            name is "Giant Rat"
            health is base_hp - 5
            max_health is base_hp - 5
            attack is base_atk
            defense is base_def
            speed is base_spd + 2
            xp_reward is 6 + floor * 2
            gold_reward is 4 + floor
            element is "physical"
            special_attack is "Gnaw"
            loot_tier is tier
    else if roll <= 4:
        return create Monster:
            name is "Wild Boar"
            health is base_hp + 5
            max_health is base_hp + 5
            attack is base_atk + 1
            defense is base_def + 1
            speed is base_spd
            xp_reward is 8 + floor * 2
