# demos/creature_quest_demo5.ep
# Creature Quest: Concurrency & Cosmos — Demo 5
# Evolving Demo 4 by integrating all advanced ErnosPlain features:
# 1. Async LLM calls: Non-blocking background generation of lore via async/await and http.
# 2. Background Autosave: Background thread saving game statistics using channels and spawn.
# 3. Polymorphic Combat: Unified combat system using the Combatant trait, methods, and Choice enums.

external define ep_sleep_ms with ms
external define ep_random_int with min and max returning Int

# --- Structs ---
define structure Player:
    field name as Str
    field hp as Int
    field max_hp as Int
    field atk as Int
    field gold as Int
    field floor as Int

define structure Monster:
    field name as Str
    field hp as Int
    field max_hp as Int
    field atk as Int
    field species as Str

# --- Choice Enum for Polymorphic Combatants ---
define choice CombatantObj:
    variant PlayerType with val as Player
    variant MonsterType with val as Monster

# --- Trait Definition ---
define trait Combatant:
    define get_name returning Str
    define get_hp returning Int
    define take_damage with damage as Int returning Int
    define attack_target with target as CombatantObj returning Int
    define is_alive returning Bool

# --- Trait Implementations ---
implement Combatant for Player:
    define get_name returning Str:
        return self.name
    define get_hp returning Int:
        return self.hp
    define take_damage with damage as Int returning Int:
        set self.hp to self.hp - damage
        if self.hp < 0:
            set self.hp to 0
        return self.hp
    define attack_target with target as CombatantObj returning Int:
        set dmg to self.atk + ep_random_int(-3 and 3)
        display f"⚔️  {self.name} strikes {target.get_name()} for {dmg} damage!"
        set r to target.take_damage(dmg)
        return r
    define is_alive returning Bool:
        return self.hp > 0

implement Combatant for Monster:
    define get_name returning Str:
        return self.name
    define get_hp returning Int:
        return self.hp
    define take_damage with damage as Int returning Int:
        set self.hp to self.hp - damage
        if self.hp < 0:
            set self.hp to 0
        return self.hp
    define attack_target with target as CombatantObj returning Int:
        set dmg to self.atk + ep_random_int(-2 and 2)
        display f"👹  [{self.species}] {self.name} attacks {target.get_name()} for {dmg} damage!"
        set r to target.take_damage(dmg)
        return r
    define is_alive returning Bool:
        return self.hp > 0

# --- Choice Enum Method Dispatch Delegators ---
define get_name on CombatantObj returning Str:
    check self:
        if PlayerType with p:
            return p.get_name()
        if MonsterType with m:
            return m.get_name()
    return ""

define get_hp on CombatantObj returning Int:
    check self:
        if PlayerType with p:
            return p.get_hp()
        if MonsterType with m:
            return m.get_hp()
    return 0

define take_damage on CombatantObj with damage as Int returning Int:
    check self:
        if PlayerType with p:
            return p.take_damage(damage)
        if MonsterType with m:
            return m.take_damage(damage)
    return 0

define attack_target on CombatantObj with target as CombatantObj returning Int:
    check self:
        if PlayerType with p:
            return p.attack_target(target)
        if MonsterType with m:
            return m.attack_target(target)
    return 0

define is_alive on CombatantObj returning Bool:
    check self:
        if PlayerType with p:
            return p.is_alive()
        if MonsterType with m:
            return m.is_alive()
    return false


# --- Async Ollama LLM Lore Generator ---
async define generate_lore_async with floor as Int and monster_name as Str returning Str:
    set dummy to ep_sleep_ms(300) # Simulate network/API latency
    
    # Try calling Ollama version API first to check connectivity
    set check_conn to ep_http_request("GET" and "http://localhost:11434/api/version" and "" and "")
    display f"DEBUG: check_conn is: '{check_conn}'"
    display f"DEBUG: has_error is: {string_contains(check_conn and "Error:")}"
    display f"DEBUG: floor is: {floor}"
    if string_length(check_conn) > 5 and also string_contains(check_conn and "Error:") == 0:
        set prompt to f"Write a short immersive description of a dungeon room on floor {floor} containing a {monster_name}."
        set body to concat("{\"model\":\"llama3.2:1b\",\"prompt\":\"" and prompt)
        set body to concat(body and "\",\"stream\":false}")
        set headers to "Content-Type: application/json\r\n"
        set resp to ep_http_request("POST" and "http://localhost:11434/api/generate" and headers and body)
        set start_idx to string_index_of(resp and "{")
        if start_idx >= 0:
            set resp to substring(resp and start_idx and string_length(resp) - start_idx)
        if string_length(resp) > 10:
            set ans to json_get_string(resp and "response")
            return ans

    # Fallback procedural generation
    if floor == 1:
        return "A damp, mossy cavern smelling of ancient decay. In the shadows, a hostile scout lurks near a stone pedestal."
    if floor == 2:
        return "A ruined cathedral hall with shattered stained glass. A fearsome knight guards the desecrated altar."
    if floor == 3:
        return "A fiery volcanic chamber with bubbling rivers of lava. A massive dragon blocks the exit portal."
    return "A mysterious chamber. A wild creature awaits you."


# --- Background Autosave Thread ---
define autosave_worker with chan as Int:
    repeat while true:
        set signal to receive from chan
        if signal == -1:
            display "💾 [Autosave] Background worker shutting down."
            return 0
        else:
            set save_data to f"Floor: {signal}\nStatus: Active\nTimestamp: OK"
            set ok to file_write(".creature_quest5_save.dat" and save_data)
            display f"💾 [Autosave] Autosave completed for floor {signal}."
    return 0


define main:
    display "============================================="
    display "🌟 CREATURE QUEST V: CONCURRENCY & COSMOS 🌟"
    display "============================================="
    
    # Start the autosave worker thread
    set save_chan to create_channel()
    spawn autosave_worker(save_chan)
    
    # Initialize the hero
    set hero_struct to create Player:
        name is "Cosmo Ranger"
        hp is 150
        max_hp is 150
        atk is 28
        gold is 0
        floor is 1

    set hero to PlayerType with hero_struct

    # Main Dungeon Floors Loop
    set max_floors to 3
    repeat while hero.is_alive() and also hero_struct.floor <= max_floors:
        set floor to hero_struct.floor
        
        # Decide monster for this floor
        set m_name to "Goblin Scout"
        set m_hp to 50
        set m_atk to 12
        set m_species to "Goblinoid"
        
        if floor == 2:
            set m_name to "Skeleton Knight"
            set m_hp to 90
            set m_atk to 18
            set m_species to "Undead"
            
        if floor == 3:
            set m_name to "Red Dragon Hatchling"
            set m_hp to 140
            set m_atk to 25
            set m_species to "Dragonkin"

        display f"\n✨ Entering Floor {floor}..."
        
        # Trigger background async LLM room description generation
        set lore_fut to generate_lore_async(floor and m_name)
        
        display "🧙‍♂️ [Lore Engine] Commencing async lore generation..."
        set dummy to ep_sleep_ms(200) # Do some work in parallel
        
        # Await room lore description
        set lore to await lore_fut
        display f"\n📜 ROOM LORE:\n\"{lore}\"\n"

        # Initialize monster
        set monster_struct to create Monster:
            name is m_name
            hp is m_hp
            max_hp is m_hp
            atk is m_atk
            species is m_species
            
        set enemy to MonsterType with monster_struct

        # Turn-based combat loop
        display f"⚔️ Battle initiated: {hero.get_name()} vs {enemy.get_name()} ({m_species})!"
        repeat while hero.is_alive() and also enemy.is_alive():
            # Hero attacks
            set r1 to hero.attack_target(enemy)
            
            # Enemy attacks back if alive
            if enemy.is_alive():
                set r2 to enemy.attack_target(hero)
                
            set dummy2 to ep_sleep_ms(100) # Short delay between turns
            
        if hero.is_alive():
            display f"🎉 Defeated the {enemy.get_name()}!"
            set hero_struct.gold to hero_struct.gold + 50 * floor
            display f"💰 Gained {50 * floor} gold. Total gold: {hero_struct.gold}"
            
            # Trigger background autosave via channel
            send floor to save_chan
            
            # Progress to next floor
            set hero_struct.floor to hero_struct.floor + 1
            set dummy3 to ep_sleep_ms(300) # Wait slightly for autosave display
        else:
            display "💀 Game Over! You fell in battle."

    if hero.is_alive():
        display "\n🌟 Congratulations! You completed the Creature Quest V demo! 🌟"
        
    # Shutdown background autosave thread
    send -1 to save_chan
    set dummy4 to ep_sleep_ms(100) # Let worker exit gracefully
    
    display "============================================="
    display "Simulation terminated."
    return 0
