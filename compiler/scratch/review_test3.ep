# Review Test 3: Concurrency, channels, string formatting, and plain English syntax

define worker with id as Int and ch:
    set result to id * id * 100
    send result to ch
    return 0

define main:
    # Test f-strings
    set name to "ErnosPlain"
    set version to 1
    display f"Testing {name} version {version}"

    # Test plain English arithmetic
    set a to 10
    set b to 20
    set sum to a plus b
    set product to a multiplied by b
    display f"Sum: {sum}"
    display f"Product: {product}"

    # Test concurrency with channels
    set ch to channel
    set num_workers to 4
    set i to 1
    while i <= num_workers:
        spawn worker(i and ch)
        set i to i + 1

    # Collect results
    set total to 0
    set j to 0
    while j < num_workers:
        set val to receive from ch
        set total to total + val
        set j to j + 1

    display f"Total from {num_workers} workers: {total}"

    # Test string operations
    set greeting to "Hello, World!"
    display f"Length: {string_length(greeting)}"
    set upper to string_upper(greeting)
    display upper
    set lower to string_lower(greeting)
    display lower

    # Test comparisons with English words
    set x to 42
    if x is greater than 40:
        display "x is greater than 40"
    if x is not equal to 43:
        display "x is not 43"

    return 0
