# scratch/test_async_param.ep
async define fetch_lore with floor as Int returning Str:
    if floor == 1:
        return "Floor 1 Lore"
    if floor == 2:
        return "Floor 2 Lore"
    return "Fallback Lore"

define main:
    set fut to fetch_lore(1)
    set res to await fut
    display res
    return 0
