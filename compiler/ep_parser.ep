# ErnosPlain Self-Hosted Parser Module

# AST Node Type Constants
# NODE_INT = 1
# NODE_STR = 2
# NODE_IDENT = 3
# NODE_BINARY = 4
# NODE_COMP = 5
# NODE_CALL = 6
# NODE_SET = 7
# NODE_RETURN = 8
# NODE_DISPLAY = 9
# NODE_IF = 10
# NODE_REPEAT_WHILE = 11
# NODE_FUNC = 12
# NODE_PROGRAM = 13
# NODE_LOGICAL = 14
# NODE_SPAWN = 15
# NODE_SEND = 16
# NODE_CHANNEL = 17
# NODE_RECEIVE = 18
# NODE_EXTERNAL = 19
# NODE_BORROW = 20
# NODE_AWAIT = 21
# NODE_FIELD_ACCESS = 22
# NODE_FIELD_SET = 23
# NODE_STRUCT_CREATE = 24
# NODE_METHOD_CALL = 25
# NODE_ENUM_CREATE = 26
# NODE_MATCH = 27
# NODE_FOR_EACH = 28
# NODE_BREAK = 29
# NODE_CONTINUE = 30
# NODE_BOOL_LIT = 31
# NODE_UNARY_NOT = 32
# NODE_TRY = 33
# NODE_CLOSURE = 34
# NODE_LIST_LIT = 35
# NODE_EXPR_STMT = 36
# NODE_STRUCT_DEF = 37
# NODE_ENUM_DEF = 38
# NODE_METHOD_DEF = 39
# NODE_TRAIT_DEF = 40
# NODE_TRAIT_IMPL = 41

# Helper: parse integer from string
define parse_int with s:
    set val to 0
    set len to string_length(s)
    set idx to 0
    repeat while idx < len:
        set ch to get_character(s and idx)
        set digit to ch - 48
        set val to val * 10 + digit
        set idx to idx + 1
    return val

# AST Node Constructors
define make_node_int with val:
    set node to create_list()
    set ok to append_list(node and 1)
    set ok to append_list(node and val)
    return node

define make_node_str with val:
    set node to create_list()
    set ok to append_list(node and 2)
    set ok to append_list(node and val)
    return node

