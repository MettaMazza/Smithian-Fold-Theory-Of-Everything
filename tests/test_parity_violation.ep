# Confirms parity violation is forced: the fold's two preimages of 1/2 are 1/4
# (left) and 3/4 (right), opposite-handed, both folding back -- so a one-handed
# (weak) coupling violates parity.
import "../constants/parity_violation.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
        display concat("    got:  " and got)
        display concat("    want: " and want)
    return 0

define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define main:
    display "=== parity violation ==="

    set ok to expect_equal("lower preimage (left hand) = 1/4" and fraction_to_text(lower_preimage()) and "1/4")
    set ok to expect_equal("upper preimage (right hand) = 3/4" and fraction_to_text(upper_preimage()) and "3/4")
    set ok to expect_equal("fold(1/4) = 1/2 (folds to the image)" and fraction_to_text(lower_preimage_folds_to_image()) and "1/2")
    set ok to expect_equal("fold(3/4) = 1/2 (folds to the image)" and fraction_to_text(upper_preimage_folds_to_image()) and "1/2")
    set ok to expect_true("lower preimage is left-handed (below 1/2)" and lower_is_left_handed())
    set ok to expect_true("upper preimage is right-handed (above 1/2)" and upper_is_right_handed())

    display "=== done ==="
    return 0
