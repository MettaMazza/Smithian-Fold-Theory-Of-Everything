import "../constants/binding_problem.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the binding problem (two streams, one experience) ==="
    set ok to expect_equal("first process = 1/3" and fraction_to_text(first_process()) and "1/3")
    set ok to expect_equal("second process = 2/3" and fraction_to_text(second_process()) and "2/3")
    set ok to expect_bool("first folds to second (one shared cycle)" and first_folds_to_second())
    set ok to expect_bool("second folds back to first (period 2)" and second_folds_to_first())
    set ok to expect_equal("together they partition the One" and fraction_to_text(processes_partition_one()) and "1")
    set ok to expect_equal("lock threshold = their balance = 1/2" and fraction_to_text(lock_threshold()) and "1/2")
    set ok to expect_equal("the lock folds to unison (one bound whole)" and fraction_to_text(lock_reaches_unison()) and "1")
    display "=== done ==="
    return 0
