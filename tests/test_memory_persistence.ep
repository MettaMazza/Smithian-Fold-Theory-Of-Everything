import "../constants/memory_persistence.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== memory persistence (a held orbit) ==="
    set ok to expect_equal("memory state = 1/3, refresh = 2/3" and fraction_to_text(memory_state()) and "1/3")
    set ok to expect_equal("refresh state = 2/3" and fraction_to_text(refresh_state()) and "2/3")
    set ok to expect_bool("memory folds to refresh" and memory_folds_to_refresh())
    set ok to expect_bool("refresh folds back to memory (perpetual cycle)" and refresh_folds_to_memory())
    set ok to expect_bool("the held pattern returns after two folds (period 2)" and pattern_returns_after_two())
    set ok to expect_equal("memory + refresh partition the One" and fraction_to_text(memory_plus_refresh()) and "1")
    display "=== done ==="
    return 0
