import "../constants/weak_mass_ratio.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the weak mass ratio ==="
    set ok to expect_equal("charged mass-part (m=3) = 1/3" and fraction_to_text(charged_mass_part(3)) and "1/3")
    set ok to expect_equal("neutral mass-part (m=3) = 2/3" and fraction_to_text(neutral_mass_part(3)) and "2/3")
    set ok to expect_equal("mass ratio (m=2, electroweak) = 1" and fraction_to_text(mass_ratio(2)) and "1")
    set ok to expect_equal("mass ratio (m=3) = 1/2" and fraction_to_text(mass_ratio(3)) and "1/2")
    set ok to expect_equal("mass ratio (m=4) = 1/3" and fraction_to_text(mass_ratio(4)) and "1/3")
    set ok to expect_bool("mass ratio = 1/(m-1) at m=2,3,4" and mass_ratio_is_one_over_m_minus_one(4))
    set ok to expect_bool("mass ratio equals the mixing ratio (m=3)" and mass_ratio_equals_mixing(3))
    display "=== done ==="
    return 0
