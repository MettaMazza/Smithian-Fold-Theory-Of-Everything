import "../constants/proton_stability.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== proton stability ==="
    set ok to expect_number("quark fibre = colour = 3" and quark_fibre() and 3)
    set ok to expect_number("lepton fibre = binary = 2" and lepton_fibre() and 2)
    set ok to expect_bool("the fibres are distinct (3 != 2, no crossing)" and fibres_are_distinct())
    set ok to expect_equal("proton baryon number = 3 * 1/3 = 1 (conserved whole)" and fraction_to_text(proton_baryon_number()) and "1")
    set ok to expect_bool("baryon number is conserved (= the One)" and baryon_number_is_conserved())
    set ok to expect_bool("the proton is STABLE (no decay path to leptons)" and proton_is_stable())
    display "=== done ==="
    return 0
