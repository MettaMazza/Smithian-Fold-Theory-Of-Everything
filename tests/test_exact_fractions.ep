# Confirms the exact-fraction layer is correct, and reproduces a real forced
# Fold constant exactly: the inverse fine-structure constant.
import "../foundation/exact_fractions.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
        display concat("    got:  " and got)
        display concat("    want: " and want)
    return 0

define main:
    display "=== exact fractions ==="

    # reduction to lowest terms: 6/4 -> 3/2
    set six_quarters to fraction_from_ratio(6 and 4)
    set ok to expect_equal("6/4 reduces" and fraction_to_text(six_quarters) and "3/2")

    # sign moves onto the numerator: 3 / -9 -> -1/3
    set neg_third to fraction_from_ratio(3 and -9)
    set ok to expect_equal("3/-9 normalises" and fraction_to_text(neg_third) and "-1/3")

    # addition:  1/2 + 1/3 = 5/6
    set a_half to fraction_from_ratio(1 and 2)
    set a_third to fraction_from_ratio(1 and 3)
    set sum to fraction_add(a_half and a_third)
    set ok to expect_equal("1/2 + 1/3" and fraction_to_text(sum) and "5/6")

    # multiplication:  (2/3) * (3/4) = 1/2
    set two_thirds to fraction_from_ratio(2 and 3)
    set three_quarters to fraction_from_ratio(3 and 4)
    set product to fraction_multiply(two_thirds and three_quarters)
    set ok to expect_equal("2/3 * 3/4" and fraction_to_text(product) and "1/2")
    # The forced fine-structure constant is built, with every count forced from
    # the two generators, in constants/fine_structure_constant.ep -- not here.
    # This module only proves the exact-fraction arithmetic it relies on.

    display "=== done ==="
    return 0
