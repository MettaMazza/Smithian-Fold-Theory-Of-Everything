import "../constants/information_compression.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))
define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== Fold compression ==="
    set ok to expect_number("relative compression uses three labels" and fold_compression_length(3) and 3)
    set ok to expect_true("compressed rank 73 round-trips" and fold_compression_round_trip(73 and 7 and 3))
    set ok to expect_true("the three-label description is minimal" and fold_compression_is_minimal(3))
    set ok to expect_true("the complete compression census holds" and complete_fold_compression_census())
    set ok to expect_true("a shortened description is rejected" and shortened_compression_is_rejected(3))
    set ok to expect_true("a changed compressed label is rejected" and changed_compressed_label_is_rejected(73 and 7 and 3))
    return 0
