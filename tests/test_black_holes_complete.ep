import "../constants/black_holes_complete.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== black holes (Hawking radiation, not a perfect trap) ==="
    set ok to expect_equal("the horizon = the gravitational balance 1/2" and fraction_to_text(horizon()) and "1/2")
    set ok to expect_equal("Hawking temperature = 1/4 (second-order, one fold below)" and fraction_to_text(hawking_temperature()) and "1/4")
    set ok to expect_bool("the temperature is strictly positive (no perfect trap)" and temperature_is_strictly_positive())
    set ok to expect_equal("one fold lifts it to the horizon (1/4 -> 1/2)" and fraction_to_text(temperature_folds_to_horizon()) and "1/2")
    set ok to expect_equal("a second fold reaches unison (1/2 -> 1)" and fraction_to_text(temperature_reaches_unison()) and "1")
    set ok to expect_equal("two temperatures make the horizon balance" and fraction_to_text(two_temperatures_make_horizon()) and "1/2")
    display "=== done ==="
    return 0
