import "../constants/grand_lock.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the Grand Lock: the constants are one object ==="
    set ok to expect_equal("derived down-depth at c=3: cover(27)" and int_to_string(lock_down_depth(3)) and "5")
    set ok to expect_equal("derived up-depth at c=3: cover(81)" and int_to_string(lock_up_depth(3)) and "7")
    set ok to expect_equal("1/alpha from the generators alone" and fraction_to_text(lock_alpha(3)) and "34259/250")
    set ok to expect_equal("lepton third invariant 1/(2*3^5 - 1)" and fraction_to_text(lock_lepton_third(3)) and "1/485")
    set ok to expect_equal("up-quark invariant 1/(3*2^7 - 1)" and fraction_to_text(lock_quark_up(3)) and "1/383")
    set ok to expect_equal("down-quark invariant 1/(3*2^5 - 1)" and fraction_to_text(lock_quark_down(3)) and "1/95")
    set ok to expect_equal("dark-to-baryon ratio 27/5" and fraction_to_text(lock_dark_to_baryon(3)) and "27/5")
    set ok to expect_equal("dark fraction 27/32" and fraction_to_text(lock_dark_fraction(3)) and "27/32")
    set ok to expect_equal("Hubble calibration ratio 13/12" and fraction_to_text(lock_hubble(3)) and "13/12")
    set ok to expect_equal("Planck-hierarchy exponent 127/2" and fraction_to_text(lock_planck_exponent(3)) and "127/2")
    set ok to expect_equal("cosmological-constant floor 1/2^20" and fraction_to_text(lock_lambda_floor(3)) and "1/1048576")
    set ok to expect_equal("the half-One coupling family" and fraction_to_text(lock_half_one()) and "1/2")
    set ok to expect_bool("CROSS-DOMAIN LOCK: alpha and the dark fraction share the counted d_down" and alpha_and_dark_share_down_depth())
    set ok to expect_equal("perturbed depths at c=4: cover(64)" and int_to_string(lock_down_depth(4)) and "6")
    set ok to expect_equal("perturbed depths at c=4: cover(256)" and int_to_string(lock_up_depth(4)) and "8")
    set ok to expect_bool("THE LOCK, BY PERTURBATION: colour 3 -> 4 moves EVERY c-dependent constant" and perturbation_moves_all())
    set ok to expect_bool("THE CONTRAST: the half-One coupling stays put (carries no colour)" and half_one_is_unmoved())
    display "=== done ==="
    return 0
