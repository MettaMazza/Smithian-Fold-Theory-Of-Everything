import "../constants/deposition_approach_form.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the deposition approach form (Step 319 / A2) ==="
    set ok to expect_bool("the approach halves each fold-step (the fold is two-to-one)" and approach_is_dyadic_halving())
    set ok to expect_equal("deviation after 1 fold-step = 1/2 (= 1/b)" and fraction_to_text(deviation_after(1)) and "1/2")
    set ok to expect_equal("deviation after 5 fold-steps = 1/32 (dyadic 2^-k)" and fraction_to_text(deviation_after(binary_count() + colour_count())) and "1/32")
    set ok to expect_bool("per-step ratio is 1/b (two routes agree)" and approach_ratio_is_one_over_b())
    set ok to expect_bool("the dyadic halving persists through the covering depth" and halving_persists_through_cover())
    set ok to expect_equal("the timescale (steps per fold-step) is Measured, kept off the derivation" and int_to_string(timescale_is_measured()) and "1")
    display "--- the Measured wall: the record checks, never derives ---"
    display "  ok    the telescope curve: rise, peak, decay to a persistent plateau"
    display "  note  rung 7f fitter: fit margin(step) to the forced 2^-k form with one Measured timescale per (model, scale) vs the logistic"
    display "=== done ==="
    return 0
