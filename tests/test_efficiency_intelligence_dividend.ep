import "../constants/efficiency_intelligence_dividend.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the intelligence dividend (why abstraction pays) ==="
    set ok to expect_equal("the decidability boundary = 1/4" and fraction_to_text(decidability_boundary()) and "1/4")
    set ok to expect_bool("the descent reaches the lock (the problem grasped whole)" and descent_reaches_lock())
    set ok to expect_bool("and closure (mastery, the fixed point)" and descent_reaches_unison())
    set ok to expect_bool("THE DIVIDEND: each step leaves a strictly smaller gap" and each_step_pays())
    set ok to expect_bool("steps = the depth (logarithmic in the grid, not linear)" and steps_equal_depth())
    display "=== done ==="
    return 0
