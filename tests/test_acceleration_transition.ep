import "../constants/acceleration_transition.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the acceleration transition (when the universe sped up) ==="
    set ok to expect_equal("vacuum 2/3, matter 1/3 -> ratio = 2" and fraction_to_text(vacuum_matter_ratio()) and "2")
    set ok to expect_equal("matter-vacuum equality at a^3 = 1/2" and fraction_to_text(equality_scale_cube()) and "1/2")
    set ok to expect_equal("acceleration onset (q=0) at a^3 = 1/4 (z ~ 0.6)" and fraction_to_text(acceleration_scale_cube()) and "1/4")
    set ok to expect_bool("onset precedes today (smaller scale-cube)" and onset_precedes_today())
    display "=== done ==="
    return 0
