import "../constants/thermodynamics.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the chaotic rate (Lyapunov and entropy, exact) ==="
    set ok to expect_equal("the gap before folding: 1/5 - 1/7 = 2/35" and fraction_to_text(gap_before()) and "2/35")
    set ok to expect_equal("the gap after one fold: 4/35" and fraction_to_text(gap_after()) and "4/35")
    set ok to expect_equal("the MEASURED expansion factor = 2, exactly" and fraction_to_text(expansion_factor()) and "2")
    set ok to expect_bool("the constructed preimages 1/6, 2/3 both land on 1/3" and preimages_land_on_target())
    set ok to expect_equal("the branch count = 2 (one bit erased per step)" and int_to_string(branch_count()) and "2")
    set ok to expect_bool("three routes, one number: expansion = branches = binary" and three_routes_agree())
    display "=== done ==="
    return 0
