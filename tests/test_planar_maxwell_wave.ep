import "../constants/planar_maxwell_wave.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the planar light wave (Maxwell closes in 2D) ==="
    set ok to expect_equal("the spatial Laplacian: two axes of exact 2 = 4" and fraction_to_text(spatial_laplacian()) and "4")
    set ok to expect_equal("the temporal curvature: one axis = 2" and fraction_to_text(temporal_curvature()) and "2")
    set ok to expect_equal("the wave ratio = 2 = the planar dimension" and fraction_to_text(wave_ratio()) and "2")
    set ok to expect_bool("the ratio equals the measured fold expansion (the wave closes)" and wave_closes())
    set ok to expect_equal("the wave speed squared = 1 (light at c in the plane)" and fraction_to_text(wave_speed_squared()) and "1")
    display "=== done ==="
    return 0
