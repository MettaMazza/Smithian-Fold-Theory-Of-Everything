# Machine-check Fold randomized algorithms.
import "../constants/algorithms_randomized.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))

define expect_fraction with label as Str and got as Fraction and want as Fraction:
    return expect_equal(label and fraction_to_text(got) and fraction_to_text(want))

define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define main:
    display "=== Fold randomized algorithms ==="
    set ok to expect_number("complete rank-search work is 8256" and fold_randomized_search_total_comparisons(7) and 8256)
    set ok to expect_fraction("equal-share expected comparisons are 129/2" and fold_randomized_search_expected_comparisons(7) and fraction_from_ratio(129 and 2))
    set ok to expect_true("enumerated and closed expectation routes agree" and fold_randomized_search_expectation_is_exact(7))
    set ok to expect_fraction("a 32-history budget succeeds on one quarter" and fold_randomized_search_success_share(32 and 7) and fraction_from_ratio(1 and 4))
    set ok to expect_true("the complete randomized census holds" and complete_fold_randomized_algorithm_census())
    set ok to expect_true("a biased branch share is rejected" and biased_randomized_search_is_rejected(7))
    set ok to expect_true("an omitted target cannot give certainty" and omitted_random_target_is_rejected(7))
    display "=== done ==="
    return 0
