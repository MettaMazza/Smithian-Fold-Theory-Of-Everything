import "../constants/bio_frontier.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== biology from the fold: aging, the spike, cancer, ecosystems ==="
    set ok to expect_equal("AGING: the replicative limit of soma 1/48 (2-adic valuation)" and int_to_string(replicative_limit(48)) and "4")
    set ok to expect_equal("the germ line 1/3 is eternal: zero decay" and int_to_string(replicative_limit(3)) and "0")
    set ok to expect_bool("MORTAL soma (1/64 decays) vs IMMORTAL germ (1/3 eternal)" and soma_is_mortal_germ_is_immortal())
    set ok to expect_equal("the NEURAL SPIKE threshold: the lock 1/2" and fraction_to_text(spike_threshold()) and "1/2")
    set ok to expect_bool("the spike is ATOMIC: all-or-nothing fold to unison" and spike_is_atomic())
    set ok to expect_bool("CANCER = lost descent: cycling where a mortal transient was required" and cancer_is_lost_descent())
    set ok to expect_bool("ECOSYSTEM: the 3/5 predator-prey orbit is periodic (stable)" and ecosystem_orbit_is_periodic())
    display "=== done ==="
    return 0
