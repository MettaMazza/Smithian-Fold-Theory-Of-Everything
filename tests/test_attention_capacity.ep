import "../constants/attention_capacity.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== attention capacity (one focus) ==="
    set ok to expect_equal("the focus lock = 1/2" and fraction_to_text(focus_lock()) and "1/2")
    set ok to expect_bool("a single focus fully holds the lock (self-antipodal)" and single_focus_is_complete())
    set ok to expect_equal("one focus folds to unison (one bound experience)" and fraction_to_text(focus_folds_to_unison()) and "1")
    set ok to expect_equal("splitting attention halves the lock -> 1/4" and fraction_to_text(split_focus()) and "1/4")
    set ok to expect_bool("a split focus is NOT self-antipodal (binds nothing fully)" and split_focus_incomplete())
    display "=== done ==="
    return 0
