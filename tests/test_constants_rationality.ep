import "../constants/constants_rationality.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the rationality of the constants ==="
    set ok to expect_equal("representative constant 1/alpha = 34259/250" and fraction_to_text(representative_constant()) and "34259/250")
    set ok to expect_bool("its denominator is a positive whole number (a ratio p/q)" and denominator_is_positive())
    set ok to expect_bool("the rational polynomial holds: q*x = p (250*x = 34259)" and rational_polynomial_holds())
    display "=== done ==="
    return 0
