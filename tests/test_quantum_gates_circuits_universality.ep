import "../constants/quantum_gates_circuits_universality.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))

define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define main:
    display "=== Fold quantum gates, circuits, and universality ==="
    set ok to expect_number("one gate reaches the forced lower-grid image" and fold_quantum_gate_image(73 and 7) and lower_grid_index(73 and 7))
    set ok to expect_true("a gate plus its label record is reversible" and fold_quantum_gate_is_reversible(73 and 7))
    set ok to expect_true("the gate theory covers every branch" and fold_quantum_gate_theory_holds(7))
    set ok to expect_true("the quantum circuit has exact branch semantics" and fold_quantum_circuit_semantics_holds(73 and 7 and 3))
    set ok to expect_true("circuit images and histories reconstruct support" and fold_quantum_circuit_support_holds(7 and 3))
    set ok to expect_true("the one Fold gate is universal on admitted processes" and fold_quantum_universality_holds())
    set ok to expect_true("the complete gate/circuit census holds" and complete_fold_quantum_gate_circuit_census())
    set ok to expect_true("a shifted gate is rejected" and shifted_quantum_gate_is_rejected(73 and 7))
    set ok to expect_true("a shortened circuit is rejected" and shortened_quantum_circuit_semantics_is_rejected(73 and 7))
    set ok to expect_true("collapsed circuit support is rejected" and collapsed_quantum_circuit_support_is_rejected(7 and 3))
    display "=== done ==="
    return 0
