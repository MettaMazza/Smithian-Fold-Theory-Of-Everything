# Confirms the proton-to-Planck hierarchy 2^(127/2) is forced from the deepest
# covering of the One, and that its exact square 2^127 agrees with the measured
# (Planck/proton)^2 to about a quarter of a percent on the ratio.
import "../constants/absolute_scale.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
        display concat("    got:  " and got)
        display concat("    want: " and want)
    return 0

define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))

define main:
    display "=== the absolute scale (proton-to-Planck hierarchy) ==="

    set ok to expect_number("deepest covering depth d_up = 7" and up_depth() and 7)
    set ok to expect_number("Fock count 2^7 = 128" and fock_count() and 128)
    set ok to expect_number("massive states 128 - 1 = 127" and massive_states() and 127)
    set ok to expect_equal("gravitational coupling = 1/2" and fraction_to_text(gravitational_coupling()) and "1/2")
    set ok to expect_equal("hierarchy exponent = 127/2" and fraction_to_text(hierarchy_exponent()) and "127/2")
    set ok to expect_equal("(Planck/proton)^2 = 2^127" and exact_integer_to_text(planck_to_proton_squared()) and "170141183460469231731687303715884105728")

    display "--- comparison to measurement (squared, so no irrational root) ---"
    # measured Planck mass 2.176434e-8 kg, proton mass 1.67262192e-27 kg.
    # ratio = (2176434 / 10^14) / (167262192 / 10^35) = 2176434 * 10^21 / 167262192.
    set ratio_top to exact_integer_from_messy_digits(1 and "2176434000000000000000000000")
    set ratio_bottom to exact_integer_from_messy_digits(1 and "167262192")
    set measured_ratio to fraction_make(ratio_top and ratio_bottom)
    set measured_ratio_squared to fraction_multiply(measured_ratio and measured_ratio)

    set forced_squared to fraction_make(planck_to_proton_squared() and exact_integer_one())

    # relative difference of the forced square from the measured square
    set gap to fraction_subtract(forced_squared and measured_ratio_squared)
    set relative to fraction_divide(gap and measured_ratio_squared)
    display concat("  relative gap (squared) = " and fraction_to_decimal(relative and 5))

    set tolerance to fraction_from_ratio(1 and 200)
    if fraction_compare(relative and tolerance) < 0:
        display "  ok    forced 2^127 matches measured (Planck/proton)^2 within 1/200"
    else:
        display "  FAIL  forced 2^127 outside 1/200 of measured (Planck/proton)^2"

    display "=== done ==="
    return 0
