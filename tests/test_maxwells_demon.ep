import "../constants/maxwells_demon.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== Maxwell's demon (the ledger pays the bit back) ==="
    set ok to expect_equal("memory states: slow = 1/4" and fraction_to_text(memory_slow()) and "1/4")
    set ok to expect_equal("memory states: fast = 3/4" and fraction_to_text(memory_fast()) and "3/4")
    set ok to expect_equal("reset sends slow to the ready state 1/2" and fraction_to_text(slow_resets_to()) and "1/2")
    set ok to expect_equal("reset sends fast to the SAME ready state" and fraction_to_text(fast_resets_to()) and "1/2")
    set ok to expect_bool("the reset erases exactly the held bit (irreversible)" and reset_erases_the_bit())
    set ok to expect_equal("demon + gas books balance at the One" and fraction_to_text(books_balance_at_one()) and "1")
    display "=== done ==="
    return 0
