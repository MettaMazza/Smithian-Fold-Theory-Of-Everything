import "../constants/acids_bases.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== acids and bases ==="
    set ok to expect_equal("neutral point = 1/2 (self-antipodal balance)" and fraction_to_text(neutral_point()) and "1/2")
    set ok to expect_equal("acid share = 1/3" and fraction_to_text(acid_share()) and "1/3")
    set ok to expect_equal("conjugate base share = 2/3" and fraction_to_text(base_share()) and "2/3")
    set ok to expect_bool("conjugate pair partitions the One (pKa + pKb = pKw)" and conjugate_pair_partitions_one())
    set ok to expect_bool("neutrality is self-antipodal (One - 1/2 = 1/2)" and neutral_is_self_antipodal())
    set ok to expect_equal("the neutral point folds up to the One" and fraction_to_text(neutral_folds_to_one()) and "1")
    display "=== done ==="
    return 0
