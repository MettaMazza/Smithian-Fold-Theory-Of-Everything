# Machine-check Fold average and worst cases.
import "../constants/complexity_average_worst.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))

define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define main:
    display "=== Fold average and worst cases ==="
    set ok to expect_number("depth-7 total halt work is 769" and fold_total_halt_work(7) and 769)
    set ok to expect_equal("the exact depth-7 average is 769/128" and fraction_to_text(fold_average_halt_time(7)) and "769/128")
    set ok to expect_true("enumerated and closed-form average routes agree" and fold_average_routes_agree(7))
    set ok to expect_number("the depth-7 worst case is seven" and fold_worst_case_halt_time(7) and 7)
    set ok to expect_true("the average does not exceed the worst case" and fold_average_does_not_exceed_worst(7))
    set ok to expect_true("the complete average/worst census holds" and complete_fold_average_worst_census())
    set ok to expect_true("a false average-equals-worst claim is rejected" and false_average_equals_worst_is_rejected(7))
    set ok to expect_true("a shorter worst case is rejected" and false_shorter_worst_case_is_rejected(7))
    display "=== done ==="
    return 0
