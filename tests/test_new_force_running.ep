import "../constants/new_force_running.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the new forces run: all four converge to unison ==="
    set ok to expect_equal("the strong coupling at d=0: g_3(1) = 3/4" and fraction_to_text(running_coupling(3 and 0)) and "3/4")
    set ok to expect_equal("the PENTA coupling at d=0: g_5(1) = 5/6" and fraction_to_text(running_coupling(5 and 0)) and "5/6")
    set ok to expect_equal("the HEPTA coupling at d=0: g_7(1) = 7/8" and fraction_to_text(running_coupling(7 and 0)) and "7/8")
    set ok to expect_bool("THE ANCHOR: the corpus strong-EW gap 1/((2+R)(3+R)), d = 0..10" and corpus_anchor_holds())
    set ok to expect_equal("the anchor gap at d=0: g_3 - g_2 = 1/12" and fraction_to_text(built_gap(2 and 3 and 0)) and "1/12")
    set ok to expect_bool("ALL SIX sector pairs: built gap = closed form (j-i)/((i+R)(j+R))" and all_six_gaps_forced())
    set ok to expect_equal("the NEW-FORCE gap at d=0: g_7 - g_5 = 1/24" and fraction_to_text(built_gap(5 and 7 and 0)) and "1/24")
    set ok to expect_equal("the new-force gap closed form at d=3: 2/((5+8)(7+8))" and fraction_to_text(closed_gap(5 and 7 and 3)) and "2/195")
    set ok to expect_bool("ALL FOUR forces rise strictly toward unison, below the One at every finite scale" and all_four_converge())
    set ok to expect_bool("the strong-EW gap shrinks with scale" and gaps_shrink_for(2 and 3))
    set ok to expect_bool("the new-force gap shrinks with scale" and gaps_shrink_for(5 and 7))
    display "=== done ==="
    return 0
