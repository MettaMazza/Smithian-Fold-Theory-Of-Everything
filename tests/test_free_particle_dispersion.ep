import "../constants/free_particle_dispersion.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== free-particle dispersion (de Broglie) ==="
    set ok to expect_equal("kinetic dispersion = fold(1/4) = 1/2" and fold_value_to_text(kinetic_dispersion()) and "1/2")
    set ok to expect_equal("momentum doubled = 1/4 + 1/4 = 1/2" and fold_value_to_text(momentum_doubled()) and "1/2")
    set ok to expect_bool("dispersion equals momentum doubled (fold(p) = p + p)" and dispersion_equals_two_steps())
    set ok to expect_equal("phase after one step = 1/3 + 1/2 = 5/6" and fold_value_to_text(phase_after_step()) and "5/6")
    display "=== done ==="
    return 0
