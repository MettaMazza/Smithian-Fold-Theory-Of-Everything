import "../constants/generation_mass_splitting.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== generation mass-splitting ==="
    set ok to expect_number("generation count = colour = 3" and generation_count() and 3)
    set ok to expect_equal("generation 0 = 1/6" and fraction_to_text(generation_position(0)) and "1/6")
    set ok to expect_equal("generation 1 = 1/2" and fraction_to_text(generation_position(1)) and "1/2")
    set ok to expect_equal("generation 2 = 5/6" and fraction_to_text(generation_position(2)) and "5/6")
    set ok to expect_equal("gap between generations = 1/3" and fraction_to_text(generation_gap(0)) and "1/3")
    set ok to expect_bool("the gap is 1/colour = 1/3" and gap_is_one_over_colour())
    set ok to expect_bool("the spacing is uniform (gap 0->1 = gap 1->2)" and spacing_is_uniform())
    display "=== done ==="
    return 0
