import "../constants/stellar_nucleosynthesis.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== stellar nucleosynthesis (the two-fold ignition) ==="
    set ok to expect_equal("ignition share = 1/4 (two folds below unison)" and fraction_to_text(ignition_share()) and "1/4")
    set ok to expect_equal("first fold crosses the Coulomb barrier (-> 1/2)" and fraction_to_text(ignition_crosses_barrier()) and "1/2")
    set ok to expect_equal("second fold completes the burn (-> the One)" and fraction_to_text(burn_completes()) and "1")
    set ok to expect_equal("two ignition shares make one barrier" and fraction_to_text(two_shares_make_the_barrier()) and "1/2")
    display "=== done ==="
    return 0
