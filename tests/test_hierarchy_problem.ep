import "../constants/hierarchy_problem.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the hierarchy problem (discrete rungs -> no fine-tuning) ==="
    set ok to expect_equal("each tower step is a factor of binary = 2" and int_to_string(tower_step_factor()) and "2")
    set ok to expect_equal("electroweak/Planck rung N = 56 (comparison-side)" and int_to_string(electroweak_planck_depth()) and "56")
    set ok to expect_bool("2^56 = 2^20 * 2^20 * 2^16 (tower self-consistency)" and depth_splits_into_rungs())
    set ok to expect_bool("adjacent rungs are exactly a factor of 2 apart (discrete)" and rungs_are_factor_two_apart())
    display "=== done ==="
    return 0
