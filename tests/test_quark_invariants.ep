import "../constants/quark_invariants.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the quark first invariants (1/12, 1/8, depths 7 and 5) ==="
    set ok to expect_equal("up channels: colour 3 + unbroken 3 = 6" and int_to_string(up_channel_count()) and "6")
    set ok to expect_equal("down channels: colour 3 + broken neutral 1 = 4" and int_to_string(down_channel_count()) and "4")
    set ok to expect_equal("I1_up = 1/(2*6) = 1/12" and fraction_to_text(up_first_invariant()) and "1/12")
    set ok to expect_equal("I1_down = 1/(2*4) = 1/8" and fraction_to_text(down_first_invariant()) and "1/8")
    set ok to expect_bool("Route B products agree: (1/4)(1/3) and (1/4)(1/2)" and invariant_routes_agree())
    set ok to expect_equal("d_up, counted: minimal cover of 81 = 7" and int_to_string(up_depth()) and "7")
    set ok to expect_equal("d_down, counted: minimal cover of 27 = 5" and int_to_string(down_depth()) and "5")
    set ok to expect_bool("Route B periods agree: period(1/127) = 7, period(1/31) = 5" and depth_routes_agree())
    display "=== done ==="
    return 0
