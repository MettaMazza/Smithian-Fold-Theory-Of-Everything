import "../constants/unison_order.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the order of the forces (strong above weak above EM) ==="
    set ok to expect_equal("the strong coupling at depth 3: (3+8-1)/(3+8) = 10/11" and fraction_to_text(running_coupling(3 and 3)) and "10/11")
    set ok to expect_equal("the weak coupling at depth 3: 9/10" and fraction_to_text(running_coupling(2 and 3)) and "9/10")
    set ok to expect_bool("both routes agree at every depth 0..11 (both sectors)" and routes_agree_everywhere())
    set ok to expect_bool("the strong binds closer to unison at EVERY depth (no crossing)" and strong_binds_closer_everywhere())
    set ok to expect_bool("the weak sits strictly above the flat EM half at every depth" and weak_above_em_everywhere())
    display "=== done ==="
    return 0
