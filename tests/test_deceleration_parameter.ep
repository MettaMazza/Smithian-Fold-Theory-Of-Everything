import "../constants/deceleration_parameter.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the deceleration parameter ==="
    set ok to expect_equal("vacuum share = 2/3" and fraction_to_text(vacuum_fraction()) and "2/3")
    set ok to expect_equal("matter share = 1/3" and fraction_to_text(matter_fraction()) and "1/3")
    set ok to expect_equal("matter contribution = 1/6" and fraction_to_text(matter_half()) and "1/6")
    set ok to expect_equal("deceleration magnitude |q0| = 1/2" and fraction_to_text(deceleration_magnitude()) and "1/2")
    set ok to expect_bool("the universe ACCELERATES (q0 < 0)" and universe_accelerates())
    display "=== done ==="
    return 0
