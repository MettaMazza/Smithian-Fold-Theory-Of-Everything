import "../constants/nonlinear_optics.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== nonlinear optics (the Kerr effect) ==="
    set ok to expect_equal("strong field = 3/4" and fraction_to_text(strong_field()) and "3/4")
    set ok to expect_equal("Kerr self-action: fold(3/4) = 1/2" and fraction_to_text(kerr_self_action()) and "1/2")
    set ok to expect_bool("the Kerr effect shifts the field (self-action, not linear)" and kerr_shifts_the_field())
    set ok to expect_equal("input wave f = 1/6" and fraction_to_text(input_wave()) and "1/6")
    set ok to expect_equal("third harmonic = 3 * f = 1/2 (odd Kerr harmonic)" and fraction_to_text(third_harmonic()) and "1/2")
    display "=== done ==="
    return 0
