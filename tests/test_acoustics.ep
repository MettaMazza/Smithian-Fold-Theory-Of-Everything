import "../constants/acoustics.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== acoustics (the harmonic series) ==="
    set ok to expect_equal("sound signal speed = the One" and fold_value_to_text(sound_signal_speed()) and "1")
    set ok to expect_equal("fundamental f0 = 1/6" and fraction_to_text(fundamental()) and "1/6")
    set ok to expect_equal("1st harmonic = 1/6" and fraction_to_text(harmonic(1)) and "1/6")
    set ok to expect_equal("2nd harmonic = 2 * f0 = 1/3" and fraction_to_text(harmonic(2)) and "1/3")
    set ok to expect_equal("3rd harmonic = 3 * f0 = 1/2" and fraction_to_text(harmonic(3)) and "1/2")
    set ok to expect_bool("the 3rd harmonic is a whole multiple of the fundamental" and nth_harmonic_is_whole_multiple(3))
    display "=== done ==="
    return 0
