    set clock_state to starting_state()
    set clock_state to make_move(clock_state and (6 * 64) + 21)
    set ok to expect_equal("the fifty-move clock counts a quiet knight move" and int_to_string(get_list(clock_state and 70)) and "1")
    set clock_state to make_move(clock_state and (52 * 64) + 36)
    set ok to expect_equal("and RESETS on a pawn move (the rule?s own reset)" and int_to_string(get_list(clock_state and 70)) and "0")
