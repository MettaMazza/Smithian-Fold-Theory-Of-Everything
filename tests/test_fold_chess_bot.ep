import "../constants/fold_chess_bot.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the fold chess bot: whole-board play from counted values ==="
    set state to starting_state()
    set ok to expect_equal("THE ORACLE, depth 1: 20 legal moves from the start" and int_to_string(perft(state and 1)) and "20")
    set state_two to starting_state()
    set ok to expect_equal("THE ORACLE, depth 2: 400" and int_to_string(perft(state_two and 2)) and "400")
    set state_three to starting_state()
    set ok to expect_equal("THE ORACLE, depth 3: 8902 (the published census, zero disagreements)" and int_to_string(perft(state_three and 3)) and "8902")
    set ok to expect_equal("COUNTED: a knight in the corner commands 2" and int_to_string(counted_reach(2 and 0 and 0)) and "2")
    set ok to expect_equal("COUNTED: a knight in the centre commands 8" and int_to_string(counted_reach(2 and 27 and 0)) and "8")
    set ok to expect_equal("COUNTED: a rook commands 14 from anywhere" and int_to_string(counted_reach(4 and 0 and 0)) and "14")
    set ok to expect_equal("COUNTED: a queen commands 21 from the corner" and int_to_string(counted_reach(5 and 0 and 0)) and "21")
    set ok to expect_equal("COUNTED: a queen commands 27 from the centre" and int_to_string(counted_reach(5 and 27 and 0)) and "27")
    set ok to expect_bool("THE LOCK: the starting position is EXACTLY the half-One" and start_is_at_the_lock())
    set ok to expect_equal("the bot finds the fool's-mate strike Qd8-h4 (move 3807)" and int_to_string(finds_fools_mate()) and "3807")
    set ok to expect_bool("the strike carries a MATE value (the One-approach, above every share)" and fools_mate_is_seen_as_mate())
    set ok to expect_bool("and it IS mate on the board: no reply, king in check" and fools_mate_is_real())
    set ok to expect_equal("SELF-PLAY: twenty plies of legal chess, final position legal" and int_to_string(self_play_plies(20)) and "20")
    display "=== done ==="
    return 0
