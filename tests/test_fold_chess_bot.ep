    set ok to expect_equal("COUNTED: a clear passed pawn carries its future queen (reach 21 from e8)" and int_to_string(pawn_promotion_potential(lone_pawn and 44 and 0)) and "21")
    set blocked_pawn to empty_state()
    set ok2 to set_list(blocked_pawn and 44 and 1)
    set ok2 to set_list(blocked_pawn and 51 and 7)
