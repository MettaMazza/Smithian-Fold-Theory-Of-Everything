import "../constants/laser.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the laser (light above threshold turns coherent) ==="
    set ok to expect_equal("lasing threshold = gain=loss balance = 1/2" and fraction_to_text(lasing_threshold()) and "1/2")
    set ok to expect_bool("the threshold is self-antipodal (gain balances loss)" and threshold_is_balanced())
    set ok to expect_equal("above threshold: folds to the One (one shared mode)" and fraction_to_text(threshold_folds_to_one()) and "1")
    set ok to expect_equal("gain + loss = the One at threshold" and fraction_to_text(gain_plus_loss()) and "1")
    display "=== done ==="
    return 0
