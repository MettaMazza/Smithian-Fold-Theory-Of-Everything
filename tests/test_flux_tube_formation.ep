import "../constants/flux_tube_formation.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the flux tube (confinement) ==="
    set ok to expect_equal("bare source charge = 1/2" and fraction_to_text(source_charge()) and "1/2")
    set ok to expect_equal("gluon self-charge = the One (carries colour)" and fraction_to_text(carrier_self_charge()) and "1")
    set ok to expect_equal("accumulated source at length 1 = 3/2" and fraction_to_text(accumulated_source(1)) and "3/2")
    set ok to expect_equal("accumulated source at length 2 = 5/2 (grows)" and fraction_to_text(accumulated_source(2)) and "5/2")
    set ok to expect_bool("the strong force CONFINES (charge grows with length)" and strong_confines())
    set ok to expect_bool("electromagnetism does NOT confine (charge constant)" and electromagnetism_does_not_confine())
    display "=== done ==="
    return 0
