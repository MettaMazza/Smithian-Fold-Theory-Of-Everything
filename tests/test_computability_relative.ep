# Machine-check Fold relative computation.
import "../constants/computability_relative.ep"

define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))

define expect_true with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0

define main:
    display "=== Fold relative-computation law ==="
    set ok to expect_true("an unassisted observation cannot distinguish a fibre pair" and unassisted_fold_observation_is_indistinguishable(1 and 7))
    set ok to expect_true("the held Fold label distinguishes the pair" and relative_fold_label_distinguishes_pair(1 and 7))
    set ok to expect_number("the held upper label reconstructs the upper source" and relative_fold_reconstruct_source(1 and 7 and 2) and 65)
    set ok to expect_true("every admitted source reconstructs relatively" and complete_relative_fold_census())
    set ok to expect_true("an outside held label is rejected" and outside_relative_label_is_rejected(7))
    set ok to expect_true("changing the held label changes the reconstructed source" and changed_relative_label_changes_source(7))
    display "=== done ==="
    return 0
