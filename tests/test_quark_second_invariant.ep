import "../constants/quark_second_invariant.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the quark second invariant (the dual, two routes) ==="
    set ok to expect_equal("ROUTE A at d=5: 1/(3*32-1) = 1/95" and fraction_to_text(dual_invariant_direct(5)) and "1/95")
    set ok to expect_equal("ROUTE A at d=7: 1/(3*128-1) = 1/383" and fraction_to_text(dual_invariant_direct(7)) and "1/383")
    set ok to expect_bool("the floors carry their depths: period(1/31)=5, period(1/127)=7" and floors_carry_their_depths())
    set ok to expect_bool("ROUTE B (orbit floors) agrees at BOTH depths" and routes_agree_at_both_depths())
    set ok to expect_bool("the duality is a swap: the lepton form gives 1/485" and duality_is_a_swap())
    display "=== done ==="
    return 0
