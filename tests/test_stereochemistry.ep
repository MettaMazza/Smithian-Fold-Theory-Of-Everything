import "../constants/stereochemistry.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== stereochemistry (mirror molecules) ==="
    set ok to expect_equal("left enantiomer = 1/4" and fraction_to_text(left_enantiomer()) and "1/4")
    set ok to expect_equal("right enantiomer = 3/4" and fraction_to_text(right_enantiomer()) and "3/4")
    set ok to expect_bool("achiral properties identical (same fold image 1/2)" and achiral_properties_identical())
    set ok to expect_bool("a chiral probe distinguishes them (different preimages)" and chiral_probe_distinguishes())
    set ok to expect_equal("a racemic mixture is the whole (1/4 + 3/4 = 1)" and fraction_to_text(racemic_is_the_whole()) and "1")
    display "=== done ==="
    return 0
