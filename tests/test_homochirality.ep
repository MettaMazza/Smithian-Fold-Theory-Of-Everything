import "../constants/homochirality.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== homochirality (why life uses one hand) ==="
    set ok to expect_equal("left hand = 1/4" and fraction_to_text(left_hand()) and "1/4")
    set ok to expect_equal("right hand = 3/4" and fraction_to_text(right_hand()) and "3/4")
    set ok to expect_bool("both hands fold to the same target (1/2)" and hands_share_target())
    set ok to expect_equal("hand separation = 1/2 (equidistant about the balance)" and fraction_to_text(hand_separation()) and "1/2")
    set ok to expect_bool("the pair is degenerate (tie broken by forced parity violation)" and pair_is_degenerate())
    display "=== done ==="
    return 0
