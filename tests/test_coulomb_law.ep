import "../constants/coulomb_law.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_number with label as Str and got as Int and want as Int:
    return expect_equal(label and int_to_string(got) and int_to_string(want))
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== Coulomb's law ==="
    set ok to expect_number("field falloff exponent = spatial - 1 = 2" and field_falloff_exponent() and 2)
    set ok to expect_bool("Gauss flux conserved through both shells (= source charge)" and flux_is_conserved())
    set ok to expect_equal("field ratio inner/outer = 4 = 2^2 (inverse-square)" and fraction_to_text(field_ratio_inner_to_outer()) and "4")
    set ok to expect_equal("potential at r=1/4: 1 - q/r = 1/2" and fraction_to_text(potential_at_radius(fraction_from_ratio(1 and 4))) and "1/2")
    set ok to expect_equal("potential at r=1/2: 1 - q/r = 3/4" and fraction_to_text(potential_at_radius(fraction_from_ratio(1 and 2))) and "3/4")
    display "=== done ==="
    return 0
