import "../constants/generation_ladder.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the generation ladder (three sites = colour-fold preimages of the vacuum) ==="
    set ok to expect_equal("first generation site = 1/6" and fraction_to_text(first_generation_site()) and "1/6")
    set ok to expect_equal("second generation site = 1/2 (the vacuum itself)" and fraction_to_text(second_generation_site()) and "1/2")
    set ok to expect_equal("third generation site = 5/6" and fraction_to_text(third_generation_site()) and "5/6")
    set ok to expect_bool("each site folds back to the vacuum (a genuine preimage)" and site_returns_to_vacuum(0))
    set ok to expect_equal("the site count = three generations" and int_to_string(generation_count_from_ladder()) and "3")
    set ok to expect_equal("the ladder has binary * colour = 6 sites" and int_to_string(ladder_site_count()) and "6")
    display "=== done ==="
    return 0
