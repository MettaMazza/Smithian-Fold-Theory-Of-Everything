import "../constants/matter_fraction_evolution.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the matter fraction's history (exact curve) ==="
    set ok to expect_equal("the dilution exponent = the counted d = 3" and int_to_string(dilution_exponent()) and "3")
    set ok to expect_bool("today the curve returns the forced budget: Omega_m(1) = 1/3" and today_returns_budget())
    set ok to expect_equal("at half scale: Omega_m(2) = 4/5 (matter was 80 percent)" and fraction_to_text(matter_fraction_at(2)) and "4/5")
    set ok to expect_equal("at third scale: Omega_m(3) = 27/29" and fraction_to_text(matter_fraction_at(3)) and "27/29")
    set ok to expect_bool("the fraction grows strictly into the past (matter domination)" and fraction_grows_into_past())
    display "=== done ==="
    return 0
