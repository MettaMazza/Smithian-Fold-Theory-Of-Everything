import "../constants/dalembert_wave.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the d'Alembert wave ==="
    set ok to expect_equal("initial disturbance U0 = 1/2" and fraction_to_text(initial_disturbance()) and "1/2")
    set ok to expect_equal("right-moving packet = U0/b = 1/4" and fraction_to_text(right_moving_packet()) and "1/4")
    set ok to expect_equal("left-moving packet = 1/4" and fraction_to_text(left_moving_packet()) and "1/4")
    set ok to expect_bool("split conserves the disturbance (right + left = U0)" and split_conserves_disturbance())
    set ok to expect_bool("split is even (the two halves equal)" and split_is_even())
    set ok to expect_equal("each packet travels at the One (signal speed)" and fold_value_to_text(packet_speed()) and "1")
    display "=== done ==="
    return 0
