import "../constants/socio_economic_dynamics.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== socio-economic cycles (boom and bust) ==="
    set ok to expect_equal("bust phase = 1/3, boom = 2/3" and fraction_to_text(bust_phase()) and "1/3")
    set ok to expect_equal("boom phase = 2/3" and fraction_to_text(boom_phase()) and "2/3")
    set ok to expect_bool("bust folds to boom" and bust_folds_to_boom())
    set ok to expect_bool("boom folds back to bust (closed cycle, never rests)" and boom_folds_to_bust())
    set ok to expect_equal("the notional equilibrium is the crossing balance 1/2" and fraction_to_text(equilibrium_balance()) and "1/2")
    set ok to expect_equal("boom and bust partition the whole economy" and fraction_to_text(phases_partition_the_whole()) and "1")
    display "=== done ==="
    return 0
