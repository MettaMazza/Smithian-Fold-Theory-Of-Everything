import "../constants/measurement_problem.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the measurement problem (one branch, indivisible) ==="
    set ok to expect_equal("observation depth = colour = 3" and int_to_string(observation_depth()) and "3")
    set ok to expect_equal("branch weight = 1/2^3 = 1/8 (indivisible)" and fraction_to_text(branch_weight()) and "1/8")
    set ok to expect_equal("branch count = 2^3 = 8" and int_to_string(branch_count()) and "8")
    set ok to expect_equal("the 8 branches partition the One (Born certainty)" and fraction_to_text(branches_partition_one()) and "1")
    set ok to expect_bool("the branch weight is indivisible (denominator = 2^k)" and weight_is_indivisible())
    display "=== done ==="
    return 0
