import "../constants/hard_problem.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the hard problem (unity + interiority) ==="
    set ok to expect_equal("UNITY: bound processing at the balance = 1/2" and fraction_to_text(unity_state()) and "1/2")
    set ok to expect_equal("experience is one whole (folds to the One)" and fraction_to_text(experience_is_one_whole()) and "1")
    set ok to expect_equal("INTERIORITY: carrier states 1/3 and 2/3" and fraction_to_text(carrier_low()) and "1/3")
    set ok to expect_bool("the carrier cannot reach the One from within (no self-view)" and carrier_cannot_reach_one_within(12))
    set ok to expect_equal("the carrier states partition the whole it holds" and fraction_to_text(carrier_partitions_one()) and "1")
    display "=== done ==="
    return 0
