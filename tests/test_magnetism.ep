import "../constants/magnetism.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== magnetism ==="
    set ok to expect_equal("single spin = 1/2" and fraction_to_text(single_spin()) and "1/2")
    set ok to expect_equal("aligned net moment = 1/2 + 1/2 = the One" and fraction_to_text(aligned_net_moment()) and "1")
    set ok to expect_bool("ferromagnetic: aligned spins reach a net moment" and is_ferromagnetic())
    set ok to expect_equal("alignment reaches unison (fold(1/2) = 1)" and fraction_to_text(alignment_reaches_unison()) and "1")
    set ok to expect_equal("Curie ordering threshold = 1/2 (balance point)" and fraction_to_text(curie_threshold()) and "1/2")
    display "=== done ==="
    return 0
