import "../constants/mass_ratio_family.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the mass-ratio family (heavy over light = 2*3^d - 1) ==="
    set ok to expect_equal("the ladder size at d=1: N = 6" and int_to_string(ladder_size(1)) and "6")
    set ok to expect_equal("the d=1 diagonal: light 1/6" and fraction_to_text(light_part(1)) and "1/6")
    set ok to expect_equal("heavy = the complement 5/6" and fraction_to_text(heavy_part(1)) and "5/6")
    set ok to expect_equal("the family ratio at d=1: 5" and fraction_to_text(family_ratio(1)) and "5")
    set ok to expect_equal("at d=2: 17" and fraction_to_text(family_ratio(2)) and "17")
    set ok to expect_equal("at d=3: 53" and fraction_to_text(family_ratio(3)) and "53")
    set ok to expect_bool("the family holds: ratio = N_d - 1 at every depth (both routes)" and family_holds())
    display "=== done ==="
    return 0
