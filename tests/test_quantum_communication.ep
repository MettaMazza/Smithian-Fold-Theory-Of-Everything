import "../constants/quantum_communication.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the channel cycle (no smuggled signal) ==="
    set ok to expect_equal("the two channels partition the One (2/3 + 1/3)" and fraction_to_text(channels_partition_one()) and "1")
    set ok to expect_bool("the fold cycles them: fold(1/3) = 2/3, fold(2/3) = 1/3" and channels_cycle())
    set ok to expect_bool("CLOSURE: the difference is again a channel -- no third thing" and difference_stays_in_cycle())
    display "=== done ==="
    return 0
