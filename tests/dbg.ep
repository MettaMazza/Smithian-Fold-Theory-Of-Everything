import "../constants/endgame_oracle.ep"
define main:
    set state to krk_mate_in_one_position()
    set d to 1
    repeat while d < 4:
        set answer to search_best(state and d)
        set mv to get_list(answer and 0)
        set from_sq to (mv - (mv / 4096) * 4096) / 64
        set to_sq to mv - (mv / 64) * 64
        display concat("depth " and concat(int_to_string(d) and concat(" move from " and concat(int_to_string(from_sq) and concat(" to " and concat(int_to_string(to_sq) and concat(" val " and concat(int_to_string(get_list(answer and 1)) and concat("/" and int_to_string(get_list(answer and 2)))))))))))
        set d to d + 1
    return 0
