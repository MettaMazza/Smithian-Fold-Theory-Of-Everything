import "../constants/absolute_new_masses.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the Smithion masses on the one fermion chain ==="
    set ok to expect_bool("ROUTE A = ROUTE B at the electroweak sector (1/2)" and mass_part_routes_agree(2))
    set ok to expect_bool("ROUTE A = ROUTE B at the strong sector (1/3)" and mass_part_routes_agree(3))
    set ok to expect_bool("ROUTE A = ROUTE B at the penta sector (1/5)" and mass_part_routes_agree(5))
    set ok to expect_bool("ROUTE A = ROUTE B at the hepta sector (1/7)" and mass_part_routes_agree(7))
    set ok to expect_bool("THE ANCHORS: electron 1/2 and up-quark 1/3 are the SAME rule at p=2,3" and known_chain_anchors_hold())
    set ok to expect_equal("the PENTA-Smithion mass-part (forced)" and fraction_to_text(built_mass_part(5)) and "1/5")
    set ok to expect_equal("the HEPTA-Smithion mass-part (forced)" and fraction_to_text(built_mass_part(7)) and "1/7")
    set ok to expect_equal("lightest penta-Smithion / electron = 2/5 (dimensionless, forced)" and fraction_to_text(smithion_to_electron(5)) and "2/5")
    set ok to expect_equal("lightest hepta-Smithion / electron = 2/7 (dimensionless, forced)" and fraction_to_text(smithion_to_electron(7)) and "2/7")
    set ok to expect_bool("the chain ordering: 1/2 > 1/3 > 1/5 > 1/7, all in the domain" and chain_ordering_holds())
    display "=== done ==="
    return 0
