import "../constants/evolution_descent.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== evolution by descent ==="
    set ok to expect_equal("rare beneficial variant = 1/4" and fraction_to_text(rare_beneficial()) and "1/4")
    set ok to expect_equal("after one generation of selection = 1/2" and fraction_to_text(after_one_generation()) and "1/2")
    set ok to expect_equal("after two generations = 1 (fixation)" and fraction_to_text(after_two_generations()) and "1")
    set ok to expect_bool("selection AMPLIFIES the variant (it climbs)" and selection_amplifies())
    set ok to expect_bool("the variant reaches fixation at the One" and reaches_fixation())
    display "=== done ==="
    return 0
