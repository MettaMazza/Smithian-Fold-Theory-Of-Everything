import "../constants/inter_sector_mass_pattern.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the inter-sector mass pattern (electron, up, down, no neutrino) ==="
    set ok to expect_equal("the electron's mass-part = 1 - 1/2 = 1/2" and fraction_to_text(electron_mass_part()) and "1/2")
    set ok to expect_equal("the up quark's mass-part = 1 - 2/3 = 1/3" and fraction_to_text(up_mass_part()) and "1/3")
    set ok to expect_equal("the down quark's mass-part = the complement = 2/3" and fraction_to_text(down_mass_part()) and "2/3")
    set ok to expect_bool("Route B: the electron's part is the fold preimage of the One" and electron_is_preimage())
    set ok to expect_bool("Route B: the quark pair is the period-2 orbit" and quark_pair_is_orbit())
    set ok to expect_bool("FORCED: the down outweighs the up (why hydrogen is stable)" and down_outweighs_up())
    set ok to expect_bool("the neutrino's part sits at the excluded boundary (unmakeable)" and neutrino_part_is_excluded())
    display "=== done ==="
    return 0
