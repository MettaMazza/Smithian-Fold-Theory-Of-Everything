import "../constants/generation_depth.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the generation depth (all three fold home in two steps) ==="
    set ok to expect_equal("generation site 1 = 1/6" and fraction_to_text(generation_site(1)) and "1/6")
    set ok to expect_equal("site 1 folds home: triple then double = 1" and fraction_to_text(fold_home(1)) and "1")
    set ok to expect_bool("ALL three generations reach the One in the same two steps" and all_generations_reach_home())
    set ok to expect_bool("all three triple to the SAME waypoint 1/2 (one shared gate)" and all_triple_to_same_waypoint())
    set ok to expect_equal("the structural depth: exponent sum of 6 = 2^1*3^1 -> 2" and int_to_string(structural_depth()) and "2")
    set ok to expect_bool("the walked depth equals the factor count" and depth_matches_factor_count())
    display "=== done ==="
    return 0
