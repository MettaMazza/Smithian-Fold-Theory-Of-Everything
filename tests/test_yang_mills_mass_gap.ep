import "../constants/yang_mills_mass_gap.ep"
define expect_equal with label as Str and got as Str and want as Str:
    if got equals want:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and concat(label and concat(" got " and got)))
    return 0
define expect_bool with label as Str and got as Bool:
    if got:
        display concat("  ok    " and label)
    else:
        display concat("  FAIL  " and label)
    return 0
define main:
    display "=== the Yang-Mills mass gap (gap > 0, forced by the domain) ==="
    set ok to expect_equal("mass gap = 1/3 (the tripling position)" and fraction_to_text(mass_gap()) and "1/3")
    set ok to expect_bool("the gap is strictly positive (No-Zero floor)" and gap_is_strictly_positive())
    set ok to expect_equal("self-coupling = 2/3" and fraction_to_text(strong_self_coupling()) and "2/3")
    set ok to expect_bool("gap folds to coupling (closed cycle)" and gap_folds_to_coupling())
    set ok to expect_bool("coupling folds back to gap (period 2)" and coupling_folds_to_gap())
    set ok to expect_equal("gap + coupling = the One" and fraction_to_text(gap_plus_coupling()) and "1")
    set ok to expect_equal("the sector balance folds to unison" and fraction_to_text(sector_balance_reaches_unison()) and "1")
    display "=== done ==="
    return 0
