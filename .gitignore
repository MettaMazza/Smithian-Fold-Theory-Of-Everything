# macOS
.DS_Store

# Compiled ErnosPlain output (binaries + generated C live next to sources)
*_compiled.c
tests/test_*
!tests/test_*.ep

# verify/ holds committed generated C (test_*.c) so anyone can build with cc alone;
# ignore only the binaries that `make` produces there.
verify/test_*
!verify/test_*.c

# The ErnosPlain language itself is a separate project, kept local for reference
language/
data/kqkr_cache.txt
tests/kqkr_cert
tests/kqkr_spot
fold_ai/gpt2_model.safetensors
fold_ai/diet/
fold_ai/grower_log.txt
fold_ai/teacher_log.txt
fold_ai/lessons/lessons_live.txt
fold_ai/lessons/facts.tsv
fold_ai/lessons/lessons_feedback.txt
fold_ai/store.pkl
fold_ai/store_rung5_snapshot.pkl
fold_ai/store_log.txt
fold_ai/logs/
Videos/
articles/

# scratch, logs, one-off patches, session transcripts — kept local, not published
transcript*.jsonl
patch*.py
scratch*.py

# The chronological transparency spine must always remain publishable.
!One.md
!OneFoldMaster.md
scratch/
gtp_logs/
probe_reports/
beam.log
.temp_validate.py
perplexity_out.txt
spectral_probe_out.txt
fix_cutoff.py
# ── Secrets — never commit ──
.env
*.env

# ── Unison omni: generated brain / curriculum / logs / sessions (runtime state) ──
graph_memory.json
graph_memory.json.tmp
omni/graph_memory.json
omni/curricula_generated.json
omni/boundary_store.json
omni/logs/
omni/sessions/
omni/__pycache__/
omni/*.safetensors
omni/*.gguf

# ── Local snapshots taken during development ──
omni_backup_*.tar.gz

# ── Python bytecode ──
__pycache__/
*.pyc

# ── Protein-folding scratch artifacts ──
*.pdb
*_init.npz
